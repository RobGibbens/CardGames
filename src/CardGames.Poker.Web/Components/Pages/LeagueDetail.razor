	private async Task CreateSeasonAsync()
	{
		if (string.IsNullOrWhiteSpace(_seasonName))
		{
			_message = "Season name is required.";
			_isError = true;
			return;
		}

		_isSubmittingSeason = true;
		try
		{
			var response = await LeaguesApi.CreateSeasonAsync(LeagueId, new CreateLeagueSeasonRequest
			{
				Name = _seasonName.Trim(),
				PlannedEventCount = _seasonPlannedEventCount,
				StartsAtUtc = _seasonStartsDate.HasValue ? new DateTimeOffset(DateTime.SpecifyKind(_seasonStartsDate.Value,
DateTimeKind.Utc)) : null,
				EndsAtUtc = _seasonEndsDate.HasValue ? new DateTimeOffset(DateTime.SpecifyKind(_seasonEndsDate.Value, DateTimeKind.Utc))
: null
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_seasonName = string.Empty;
				_seasonPlannedEventCount = null;
				_seasonStartsDate = null;
				_seasonEndsDate = null;
				_showSeasonModal = false;
				_message = "Season created.";
				_isError = false;
				await LoadSeasonsAsync();
			}
			else
			{
				_message = "Failed to create season.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create season for league {LeagueId}", LeagueId);
			_message = "Failed to create season.";
			_isError = true;
		}
		finally
		{
			_isSubmittingSeason = false;
		}
	}

