	public async ValueTask DisposeAsync()
	{
		if (_isLeagueHubSubscriptionInitialized)
		{
			LeagueHubClient.OnLeagueJoinRequestSubmitted -= HandleLeagueJoinRequestSubmittedAsync;
			LeagueHubClient.OnLeagueJoinRequestUpdated -= HandleLeagueJoinRequestUpdatedAsync;
			_isLeagueHubSubscriptionInitialized = false;
		}

		try
		{
			await LeagueHubClient.SetManagedLeaguesAsync([]);
			await LeagueHubClient.DisconnectAsync();
		}
		catch (Exception ex)
		{
			Logger.LogDebug(ex, "Error disconnecting league hub client for league detail page");
		}

		if (_leagueDetailModule is not null)
		{
			try
			{
				await _leagueDetailModule.DisposeAsync();
			}
			catch (JSDisconnectedException)
			{
				// Ignore circuit disconnects during teardown.
			}
		}
	}

