@code {
	[Parameter]
	public Guid LeagueId { get; set; }

	private bool _isLoading;
	private bool _isError;
	private string? _message;

	private LeagueDetailDto? _leagueDetail;
	private List<LeagueMemberDto> _members = [];
	private List<LeagueMembershipHistoryItemDto> _membershipHistory = [];
	private List<LeagueInviteSummaryDto> _invites = [];
	private List<LeagueJoinRequestQueueItemDto> _pendingJoinRequests = [];

	private DateTime _inviteExpiryDate = DateTime.UtcNow.Date.AddDays(7);
	private bool _isSubmittingInvite;
	private bool _isSubmittingRevokeInvite;
	private bool _isSubmittingPromote;
	private bool _isSubmittingDemote;
	private bool _isSubmittingTransferOwnership;
	private bool _isSubmittingRemove;
	private string? _actingMemberUserId;
	private bool _isLoadingJoinRequests;
	private bool _isSubmittingJoinRequest;
	private Guid? _actingJoinRequestId;
	private readonly Dictionary<Guid, string> _joinRequestReasons = [];
	private string? _createdInviteUrl;
	private bool _isInviteUrlCopied;
	private int _inviteCopyFeedbackVersion;
	private bool _showInviteModal;

	private List<LeagueSeasonDto> _seasons = [];
	private Guid? _selectedSeasonId;
	private List<LeagueSeasonEventDto> _seasonEvents = [];
	private List<LeagueOneOffEventDto> _oneOffEvents = [];
	private List<LeagueStandingEntryDto> _standings = [];

	private string _seasonName = string.Empty;
	private int? _seasonPlannedEventCount;
	private DateTime? _seasonStartsDate;
	private DateTime? _seasonEndsDate;
	private bool _isSubmittingSeason;
	private bool _showSeasonModal;

	private string _seasonEventName = string.Empty;
	private int? _seasonEventSequence;
	private DateTime? _seasonEventScheduledDate;
	private string? _seasonEventNotes;
	private bool _isSubmittingSeasonEvent;
	private bool _showSeasonEventModal;

	private string _oneOffName = string.Empty;
	private DateTime _oneOffScheduledDate = DateTime.UtcNow.Date.AddDays(1);
	private LeagueOneOffEventType _oneOffType = LeagueOneOffEventType.GameNight;
	private string? _oneOffNotes;
	private bool _isSubmittingOneOff;
	private bool _showOneOffModal;
	private Guid? _launchingSeasonEventId;
	private Guid? _launchingOneOffEventId;
	private bool _showRecordResultsModal;
	private bool _isSubmittingResults;
	private Guid? _recordingSeasonEventId;
	private string _recordingSeasonEventName = string.Empty;
	private List<SeasonEventResultDraft> _resultDrafts = [];
	private string? _currentUserId;
	private Dictionary<string, int> _rankMovementByUserId = new(StringComparer.Ordinal);
	private LeagueStandingEntryDto? _myStanding;
	private List<LeagueSeasonEventDto> _recentCompletedEvents = [];

	private ScheduleTab _activeScheduleTab = ScheduleTab.Seasons;

	private enum ScheduleTab
	{
		Seasons,
		OneOffEvents
	}

	private sealed class SeasonEventResultDraft
	{
		public required string MemberUserId { get; init; }

		public required string MemberDisplayName { get; init; }

		public bool Include { get; set; } = true;

		public int Placement { get; set; }

		public int Points { get; set; }

		public int ChipsDelta { get; set; }
	}

	private bool IsManager => _leagueDetail?.MyRole == LeagueRole.Manager;
	private bool CanManageLeague => _leagueDetail?.MyRole == LeagueRole.Admin || _leagueDetail?.MyRole == LeagueRole.Manager;
	private List<LeagueMembershipHistoryItemDto> GovernanceAuditEntries => _membershipHistory
		.Where(x => x.EventType is LeagueMembershipHistoryEventType.MemberPromotedToAdmin
			or LeagueMembershipHistoryEventType.MemberDemotedFromAdmin
			or LeagueMembershipHistoryEventType.LeagueOwnershipTransferred
			or LeagueMembershipHistoryEventType.MemberLeft)
		.OrderByDescending(x => x.OccurredAtUtc)
		.Take(20)
		.ToList();

	protected override async Task OnParametersSetAsync()
	{
		await LoadAllAsync();
	}

	private async Task LoadAllAsync()
	{
		_isLoading = true;
		_message = null;
		_isError = false;

		try
		{
			await LoadCurrentUserAsync();
			await LoadDetailAsync();
			await LoadMembersAsync();
			await LoadMembershipHistoryAsync();
			await LoadInvitesAsync();
			await LoadStandingsAsync();
			await LoadSeasonsAsync();
			await LoadOneOffEventsAsync();
			await LoadPendingJoinRequestsAsync();

			if (_selectedSeasonId.HasValue)
			{
				await LoadSeasonEventsAsync(_selectedSeasonId.Value);
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed loading league detail page for {LeagueId}", LeagueId);
			_message = "Unable to load this league right now.";
			_isError = true;
		}
		finally
		{
			_isLoading = false;
		}
	}

	private async Task LoadDetailAsync()
	{
		var response = await LeaguesApi.GetLeagueDetailAsync(LeagueId);
		_leagueDetail = response.IsSuccessStatusCode ? response.Content : null;
	}

	private async Task LoadMembersAsync()
	{
		var response = await LeaguesApi.GetLeagueMembersAsync(LeagueId);
		_members = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadInvitesAsync()
	{
		var response = await LeaguesApi.GetInvitesAsync(LeagueId);
		_invites = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadMembershipHistoryAsync()
	{
		var response = await LeaguesApi.GetMembershipHistoryAsync(LeagueId);
		_membershipHistory = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadPendingJoinRequestsAsync()
	{
		if (!CanManageLeague)
		{
			_pendingJoinRequests = [];
			_joinRequestReasons.Clear();
			return;
		}

		_isLoadingJoinRequests = true;
		try
		{
			var response = await LeaguesApi.GetPendingJoinRequestsAsync(LeagueId);
			_pendingJoinRequests = response.IsSuccessStatusCode && response.Content is not null
				? response.Content.OrderBy(x => x.CreatedAtUtc).ToList()
				: [];

			var validIds = _pendingJoinRequests.Select(x => x.JoinRequestId).ToHashSet();
			foreach (var staleId in _joinRequestReasons.Keys.Where(x => !validIds.Contains(x)).ToList())
			{
				_joinRequestReasons.Remove(staleId);
			}
		}
		finally
		{
			_isLoadingJoinRequests = false;
		}
	}

	private async Task LoadSeasonsAsync()
	{
		var response = await LeaguesApi.GetSeasonsAsync(LeagueId);
		_seasons = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];

		if (!_selectedSeasonId.HasValue && _seasons.Count > 0)
		{
			var defaultSeason = _seasons
				.OrderByDescending(x => x.Status == LeagueSeasonStatus.InProgress)
				.ThenByDescending(x => x.CreatedAtUtc)
				.First();

			_selectedSeasonId = defaultSeason.SeasonId;
		}

		if (_selectedSeasonId.HasValue && _seasons.All(x => x.SeasonId != _selectedSeasonId.Value))
		{
			_selectedSeasonId = null;
			_seasonEvents = [];
			_recentCompletedEvents = [];
		}
	}

	private async Task LoadSeasonEventsAsync(Guid seasonId)
	{
		var response = await LeaguesApi.GetSeasonEventsAsync(LeagueId, seasonId);
		_seasonEvents = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
		_recentCompletedEvents = _seasonEvents
			.Where(x => x.Status == LeagueSeasonEventStatus.Completed)
			.OrderByDescending(x => x.ScheduledAtUtc ?? x.CreatedAtUtc)
			.Take(5)
			.ToList();
	}

	private async Task LoadOneOffEventsAsync()
	{
		var response = await LeaguesApi.GetOneOffEventsAsync(LeagueId);
		_oneOffEvents = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadStandingsAsync()
	{
		var previousRankByUserId = _standings.ToDictionary(x => x.UserId, x => x.Rank, StringComparer.Ordinal);

		var response = await LeaguesApi.GetLeagueStandingsAsync(LeagueId);
		if (response.IsSuccessStatusCode && response.Content is not null)
		{
			_standings = response.Content.ToList();
			_rankMovementByUserId = new Dictionary<string, int>(StringComparer.Ordinal);

			foreach (var standing in _standings)
			{
				if (previousRankByUserId.TryGetValue(standing.UserId, out var previousRank))
				{
					_rankMovementByUserId[standing.UserId] = previousRank - standing.Rank;
				}
			}

			_myStanding = _standings.FirstOrDefault(IsCurrentUserStanding);
			return;
		}

		_standings = [];
		_rankMovementByUserId.Clear();
		_myStanding = null;
	}

	private async Task LoadCurrentUserAsync()
	{
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var user = authState.User;

		if (user.Identity?.IsAuthenticated != true)
		{
			_currentUserId = null;
			return;
		}

		_currentUserId = user.FindFirstValue(ClaimTypes.NameIdentifier)
			?? user.FindFirstValue("sub")
			?? user.Identity?.Name;
	}

	private async Task SelectSeasonAsync(Guid seasonId)
	{
		_selectedSeasonId = seasonId;
		await LoadSeasonEventsAsync(seasonId);
	}

	private async Task CreateInviteAsync()
	{
		_isSubmittingInvite = true;
		try
		{
			var expiryUtc = new DateTimeOffset(DateTime.SpecifyKind(_inviteExpiryDate, DateTimeKind.Utc));
			var response = await LeaguesApi.CreateInviteAsync(LeagueId, new CreateLeagueInviteRequest
			{
				ExpiresAtUtc = expiryUtc
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_createdInviteUrl = NavigationManager.ToAbsoluteUri(response.Content.InviteUrl).ToString();
				_message = "Invite created.";
				_isError = false;
				await LoadInvitesAsync();
			}
			else
			{
				_message = "Failed to create invite.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create invite for league {LeagueId}", LeagueId);
			_message = "Failed to create invite.";
			_isError = true;
		}
		finally
		{
			_isSubmittingInvite = false;
		}
	}

	private void OpenInviteModal()
	{
		_createdInviteUrl = null;
		_showInviteModal = true;
	}

	private async Task CopyCreatedInviteUrlAsync()
	{
		if (string.IsNullOrWhiteSpace(_createdInviteUrl))
		{
			return;
		}

		try
		{
			await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _createdInviteUrl);
			var feedbackVersion = ++_inviteCopyFeedbackVersion;
			_isInviteUrlCopied = true;
			_message = "Invite link copied.";
			_isError = false;

			await Task.Delay(1500);
			if (feedbackVersion == _inviteCopyFeedbackVersion)
			{
				_isInviteUrlCopied = false;
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed to copy invite link for league {LeagueId}", LeagueId);
			_isInviteUrlCopied = false;
			_message = "Unable to copy invite link.";
			_isError = true;
		}
	}

	private void CloseInviteModal()
	{
		if (_isSubmittingInvite)
		{
			return;
		}

		_showInviteModal = false;
		_createdInviteUrl = null;
		_isInviteUrlCopied = false;
	}

	private async Task RevokeInviteAsync(Guid inviteId)
	{
		_isSubmittingRevokeInvite = true;
		try
		{
			var response = await LeaguesApi.RevokeInviteAsync(LeagueId, inviteId);
			if (response.IsSuccessStatusCode)
			{
				_message = "Invite revoked.";
				_isError = false;
				await LoadInvitesAsync();
			}
			else
			{
				_message = "Failed to revoke invite.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to revoke invite {InviteId} for league {LeagueId}", inviteId, LeagueId);
			_message = "Failed to revoke invite.";
			_isError = true;
		}
		finally
		{
			_isSubmittingRevokeInvite = false;
		}
	}

	private bool CanPromote(LeagueMemberDto member)
	{
		return CanManageLeague && member.IsActive && member.Role == LeagueRole.Member;
	}

	private bool CanDemote(LeagueMemberDto member)
	{
		return CanManageLeague && member.IsActive && member.Role == LeagueRole.Admin;
	}

	private bool CanTransferOwnership(LeagueMemberDto member)
	{
		return IsManager && member.IsActive && member.Role != LeagueRole.Manager;
	}

	private bool CanRemove(LeagueMemberDto member)
	{
		return CanManageLeague && member.IsActive;
	}

	private bool IsActingOnMember(string memberUserId)
	{
		return string.Equals(_actingMemberUserId, memberUserId, StringComparison.Ordinal);
	}

	private string GetModerationReason(Guid joinRequestId)
	{
		return _joinRequestReasons.TryGetValue(joinRequestId, out var reason)
			? reason
			: string.Empty;
	}

	private void SetModerationReason(Guid joinRequestId, string? reason)
	{
		_joinRequestReasons[joinRequestId] = reason?.Trim() ?? string.Empty;
	}

	private async Task ApproveJoinRequestAsync(Guid joinRequestId)
	{
		await ModerateJoinRequestAsync(
			joinRequestId,
			(joinRequestIdValue, request) => LeaguesApi.ApproveJoinRequestAsync(LeagueId, joinRequestIdValue, request),
			"Join request approved.",
			"Failed to approve join request.");
	}

	private async Task DenyJoinRequestAsync(Guid joinRequestId)
	{
		await ModerateJoinRequestAsync(
			joinRequestId,
			(joinRequestIdValue, request) => LeaguesApi.DenyJoinRequestAsync(LeagueId, joinRequestIdValue, request),
			"Join request denied.",
			"Failed to deny join request.");
	}

	private async Task ModerateJoinRequestAsync(
		Guid joinRequestId,
		Func<Guid, ModerateLeagueJoinRequestRequest, Task<Refit.IApiResponse>> moderationAction,
		string successMessage,
		string fallbackErrorMessage)
	{
		_actingJoinRequestId = joinRequestId;
		_isSubmittingJoinRequest = true;

		try
		{
			var response = await moderationAction(joinRequestId, new ModerateLeagueJoinRequestRequest
			{
				Reason = string.IsNullOrWhiteSpace(GetModerationReason(joinRequestId))
					? null
					: GetModerationReason(joinRequestId)
			});

			if (response.IsSuccessStatusCode)
			{
				_joinRequestReasons.Remove(joinRequestId);
				_message = successMessage;
				_isError = false;
				await LoadPendingJoinRequestsAsync();
				await LoadMembersAsync();
				await LoadMembershipHistoryAsync();
				await LoadDetailAsync();
				return;
			}

			_message = TryExtractApiErrorMessage(response) ?? fallbackErrorMessage;
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to moderate join request {JoinRequestId} for league {LeagueId}", joinRequestId, LeagueId);
			_message = fallbackErrorMessage;
			_isError = true;
		}
		finally
		{
			_isSubmittingJoinRequest = false;
			_actingJoinRequestId = null;
		}
	}

	private static string? TryExtractApiErrorMessage(Refit.IApiResponse response)
	{
		var content = response.Error?.Content;
		if (string.IsNullOrWhiteSpace(content))
		{
			return response.Error?.Message;
		}

		try
		{
			using var document = JsonDocument.Parse(content);
			if (document.RootElement.ValueKind == JsonValueKind.Object)
			{
				if (document.RootElement.TryGetProperty("message", out var messageProperty))
				{
					return messageProperty.GetString();
				}

				if (document.RootElement.TryGetProperty("Message", out var messagePascalCaseProperty))
				{
					return messagePascalCaseProperty.GetString();
				}
			}
		}
		catch (JsonException)
		{
		}

		return content;
	}

	private async Task PromoteMemberAsync(string memberUserId)
	{
		_actingMemberUserId = memberUserId;
		_isSubmittingPromote = true;
		try
		{
			var response = await LeaguesApi.PromoteMemberToAdminAsync(LeagueId, memberUserId);
			if (response.IsSuccessStatusCode)
			{
				_message = "Member promoted to admin.";
				_isError = false;
				await LoadMembersAsync();
				await LoadMembershipHistoryAsync();
				await LoadDetailAsync();
			}
			else
			{
				_message = "Failed to promote member.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to promote member for league {LeagueId}", LeagueId);
			_message = "Failed to promote member.";
			_isError = true;
		}
		finally
		{
			_isSubmittingPromote = false;
			_actingMemberUserId = null;
		}
	}

	private async Task DemoteMemberAsync(string memberUserId)
	{
		_actingMemberUserId = memberUserId;
		_isSubmittingDemote = true;
		try
		{
			var response = await LeaguesApi.DemoteAdminToMemberAsync(LeagueId, memberUserId);
			if (response.IsSuccessStatusCode)
			{
				_message = "Admin demoted to member.";
				_isError = false;
				await LoadMembersAsync();
				await LoadMembershipHistoryAsync();
				await LoadDetailAsync();
			}
			else
			{
				_message = "Failed to demote admin.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to demote admin for league {LeagueId}", LeagueId);
			_message = "Failed to demote admin.";
			_isError = true;
		}
		finally
		{
			_isSubmittingDemote = false;
			_actingMemberUserId = null;
		}
	}

	private async Task TransferOwnershipAsync(string memberUserId)
	{
		_actingMemberUserId = memberUserId;
		_isSubmittingTransferOwnership = true;
		try
		{
