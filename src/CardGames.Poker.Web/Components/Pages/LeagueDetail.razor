	private bool IsManager => HasManagerAuthorityRole(_leagueDetail?.MyRole);
	private bool CanManageLeague => HasLeagueManagementRole(_leagueDetail?.MyRole);
	private bool HasLeagueAccess => _leagueDetail is not null;

	private static bool HasLeagueManagementRole(LeagueRole? role)
	{
		return role is LeagueRole.Admin or LeagueRole.Manager or LeagueRole.Owner;
	}

	private static bool HasManagerAuthorityRole(LeagueRole? role)
	{
		return role is LeagueRole.Manager or LeagueRole.Owner;
	}
