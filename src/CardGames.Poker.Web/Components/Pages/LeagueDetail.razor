	private async Task LoadUpcomingEventsPageAsync(int pageNumber)
	{
		_isLoadingUpcomingEventsPage = true;
		try
		{
			var response = await LeaguesApi.GetUpcomingEventsPageAsync(LeagueId, LobbyPageSize, pageNumber);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_upcomingEventsPage = response.Content;
				_upcomingEventsPageNumber = response.Content.PageNumber;
				return;
			}

			Logger.LogWarning("Failed loading upcoming events page for league {LeagueId}. StatusCode={StatusCode}. Error={Error}. Falling back to existing event feeds.",
				LeagueId,
				response.StatusCode,
				TryExtractApiErrorMessage(response));

			await LoadUpcomingEventsFallbackPageAsync(pageNumber);
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Exception loading upcoming events page for league {LeagueId}. Falling back to existing event feeds.", LeagueId);
			await LoadUpcomingEventsFallbackPageAsync(pageNumber);
		}
		finally
		{
			_isLoadingUpcomingEventsPage = false;
		}
	}

	private async Task LoadUpcomingEventsFallbackPageAsync(int pageNumber)
	{
		try
		{
			await EnsureOneOffEventsLoadedAsync();

			if (_selectedSeasonId.HasValue)
			{
				await EnsureSeasonEventsLoadedAsync();
			}

			var upcomingItems = new List<UpcomingEventFallbackItem>();

			upcomingItems.AddRange(_oneOffEvents
				.Where(oneOffEvent => oneOffEvent.Status != LeagueOneOffEventStatus.Completed
					&& !oneOffEvent.LaunchedGameId.HasValue
					&& oneOffEvent.Status != LeagueOneOffEventStatus.Canceled)
				.Select(oneOffEvent => new UpcomingEventFallbackItem(
					oneOffEvent.ScheduledAtUtc,
					oneOffEvent.CreatedAtUtc,
					oneOffEvent.Name,
					new LeagueUpcomingEventEntryDto
					{
						SortAt = oneOffEvent.ScheduledAtUtc,
						SeasonEvent = null,
						OneOffEvent = oneOffEvent
					})));

			if (_selectedSeasonId.HasValue)
			{
				upcomingItems.AddRange(_seasonEvents
					.Where(seasonEvent => seasonEvent.Status != LeagueSeasonEventStatus.Completed
						&& !seasonEvent.LaunchedGameId.HasValue
						&& seasonEvent.Status != LeagueSeasonEventStatus.Canceled)
					.Select(seasonEvent => new UpcomingEventFallbackItem(
						seasonEvent.ScheduledAtUtc ?? seasonEvent.CreatedAtUtc,
						seasonEvent.CreatedAtUtc,
						seasonEvent.Name,
						new LeagueUpcomingEventEntryDto
						{
							SortAt = seasonEvent.ScheduledAtUtc ?? seasonEvent.CreatedAtUtc,
							SeasonEvent = seasonEvent,
							OneOffEvent = null
						})));
			}

			var totalCount = upcomingItems.Count;
			var totalPages = Math.Max(1, (int)Math.Ceiling(totalCount / (double)LobbyPageSize));
			var resolvedPageNumber = Math.Min(Math.Max(pageNumber, 1), totalPages);
			var skip = (resolvedPageNumber - 1) * LobbyPageSize;

			_upcomingEventsPage = new LeagueUpcomingEventsPageDto
			{
				Entries = upcomingItems
					.OrderBy(item => item.SortAt)
					.ThenBy(item => item.CreatedAtUtc)
					.ThenBy(item => item.Name)
					.Skip(skip)
					.Take(LobbyPageSize)
					.Select(item => item.Entry)
					.ToList(),
				HasMore = resolvedPageNumber < totalPages,
				TotalCount = totalCount,
				PageNumber = resolvedPageNumber,
				PageSize = LobbyPageSize,
				TotalPages = totalPages
			};
			_upcomingEventsPageNumber = _upcomingEventsPage.PageNumber;
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Fallback loading for upcoming events failed for league {LeagueId}", LeagueId);
			_upcomingEventsPage = CreateEmptyUpcomingEventsPage(pageNumber);
			_upcomingEventsPageNumber = _upcomingEventsPage.PageNumber;
		}
	}

