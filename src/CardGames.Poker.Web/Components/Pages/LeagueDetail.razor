	private async Task LoadSeasonEventsPageAsync(int pageNumber)
	{
		if (!_selectedSeasonId.HasValue)
		{
			_scheduleSeasonEventsPageNumber = 1;
			_scheduleSeasonEventsPage = CreateEmptySeasonEventsPage();
			_hasLoadedScheduleSeasonEventsPage = false;
			_loadedScheduleSeasonEventsSeasonId = null;
			return;
		}

		_isLoadingScheduleSeasonEventsPage = true;
		try
		{
			var response = await LeaguesApi.GetSeasonEventsPageAsync(LeagueId, _selectedSeasonId.Value, SchedulePageSize, pageNumber);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_scheduleSeasonEventsPage = response.Content;
				_scheduleSeasonEventsPageNumber = response.Content.PageNumber;
				_hasLoadedScheduleSeasonEventsPage = true;
				_loadedScheduleSeasonEventsSeasonId = _selectedSeasonId.Value;
				return;
			}

			_scheduleSeasonEventsPage = CreateEmptySeasonEventsPage(pageNumber);
			_scheduleSeasonEventsPageNumber = _scheduleSeasonEventsPage.PageNumber;
			_hasLoadedScheduleSeasonEventsPage = true;
			_loadedScheduleSeasonEventsSeasonId = _selectedSeasonId.Value;
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed loading season events page for league {LeagueId} season {SeasonId}", LeagueId, _selectedSeasonId.Value);
			_scheduleSeasonEventsPage = CreateEmptySeasonEventsPage(pageNumber);
			_scheduleSeasonEventsPageNumber = _scheduleSeasonEventsPage.PageNumber;
			_hasLoadedScheduleSeasonEventsPage = true;
			_loadedScheduleSeasonEventsSeasonId = _selectedSeasonId.Value;
		}
		finally
		{
			_isLoadingScheduleSeasonEventsPage = false;
		}
	}

	private async Task LoadOneOffEventsPageAsync(int pageNumber)
	{
		_isLoadingScheduleOneOffEventsPage = true;
		try
