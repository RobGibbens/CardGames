	private async Task LoadPendingJoinRequestsAsync()
	{
		if (!CanManageLeague)
		{
			_pendingJoinRequests = [];
			_joinRequestReasons.Clear();
			_confirmingDenyJoinRequestId = null;
			return;
		}

		_isLoadingJoinRequests = true;
		try
		{
			var response = await LeaguesApi.GetPendingJoinRequestsAsync(LeagueId);
			_pendingJoinRequests = response.IsSuccessStatusCode && response.Content is not null
				? response.Content.OrderBy(x => x.CreatedAtUtc).ToList()
				: [];

			var validIds = _pendingJoinRequests.Select(x => x.JoinRequestId).ToHashSet();
			foreach (var staleId in _joinRequestReasons.Keys.Where(x => !validIds.Contains(x)).ToList())
			{
				_joinRequestReasons.Remove(staleId);
			}

			if (_confirmingDenyJoinRequestId.HasValue && !validIds.Contains(_confirmingDenyJoinRequestId.Value))
			{
				_confirmingDenyJoinRequestId = null;
			}
		}
		finally
		{
			_isLoadingJoinRequests = false;
		}
	}

	private async Task LoadSeasonsAsync()
	{
		var response = await LeaguesApi.GetSeasonsAsync(LeagueId);
		_seasons = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];

		if (!_selectedSeasonId.HasValue && _seasons.Count > 0)
		{
			var defaultSeason = _seasons
				.OrderByDescending(x => x.Status == LeagueSeasonStatus.InProgress)
				.ThenByDescending(x => x.CreatedAtUtc)
				.First();

			_selectedSeasonId = defaultSeason.SeasonId;
		}

		if (_selectedSeasonId.HasValue && _seasons.All(x => x.SeasonId != _selectedSeasonId.Value))
		{
			_selectedSeasonId = null;
			_seasonEvents = [];
			_recentCompletedEvents = [];
		}
	}

	private async Task LoadSeasonEventsAsync(Guid seasonId)
	{
		var response = await LeaguesApi.GetSeasonEventsAsync(LeagueId, seasonId);
		_seasonEvents = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
		_recentCompletedEvents = _seasonEvents
			.Where(x => x.Status == LeagueSeasonEventStatus.Completed)
			.OrderByDescending(x => x.ScheduledAtUtc ?? x.CreatedAtUtc)
			.Take(5)
			.ToList();
	}

	private async Task LoadOneOffEventsAsync()
	{
		var response = await LeaguesApi.GetOneOffEventsAsync(LeagueId);
		_oneOffEvents = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadStandingsAsync()
	{
		var previousRankByUserId = _standings.ToDictionary(x => x.UserId, x => x.Rank, StringComparer.Ordinal);

		var response = await LeaguesApi.GetLeagueStandingsAsync(LeagueId, _selectedSeasonId);
		if (response.IsSuccessStatusCode && response.Content is not null)
		{
			_standings = response.Content.ToList();
			_rankMovementByUserId = new Dictionary<string, int>(StringComparer.Ordinal);

			foreach (var standing in _standings)
			{
				if (previousRankByUserId.TryGetValue(standing.UserId, out var previousRank))
				{
					_rankMovementByUserId[standing.UserId] = previousRank - standing.Rank;
				}
			}

			_myStanding = _standings.FirstOrDefault(IsCurrentUserStanding);
			return;
		}

		_standings = [];
		_rankMovementByUserId.Clear();
		_myStanding = null;
	}

	private async Task LoadCurrentUserAsync()
	{
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var user = authState.User;

		if (user.Identity?.IsAuthenticated != true)
		{
			_currentUserId = null;
			return;
		}

		_currentUserId = user.FindFirstValue(ClaimTypes.NameIdentifier)
			?? user.FindFirstValue("sub")
			?? user.Identity?.Name;
	}

