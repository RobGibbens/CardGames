@page "/leagues/{LeagueId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Shared
@using CardGames.Poker.Web.Services
@using Microsoft.AspNetCore.Authorization
@using System.Net
@using System.ComponentModel
@using System.Text.Json
@using System.Security.Claims
@using CardGames.Contracts.SignalR

@inject ILeaguesApi LeaguesApi
@inject LeagueHubClient LeagueHubClient
@inject ILogger<LeagueDetail> Logger
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>League Detail - Friday Night Poker</PageTitle>

<AuthenticatedNavBar />

<main class="lobby-main">
	<div class="lobby-container">

		@* ───── LEAGUE DETAIL HEADER ───── *@
		<div class="league-detail-header">
			<div class="league-detail-header-left">
				<div class="league-detail-icon">
					<i class="fa-solid fa-shield-halved"></i>
				</div>
				<div class="league-detail-header-info">
					<h1 class="league-detail-name">@(_leagueDetail?.Name ?? "League")</h1>
					@if (!string.IsNullOrWhiteSpace(_leagueDetail?.Description))
					{
						<p class="league-detail-description">@_leagueDetail.Description</p>
					}
					<div class="league-detail-meta">
						Created by @(_leagueDetail?.CreatedByDisplayName ?? _leagueDetail?.CreatedByUserId) &bull; @(_leagueDetail?.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy"))
					</div>
				</div>
			</div>
			<div class="league-detail-header-right">
				<div class="league-detail-members-avatars">
					@if (_members.Count > 0)
					{
						@foreach (var member in _members.Take(5))
						{
							var initial = (member.UserDisplayName ?? member.UserId)?[..1].ToUpperInvariant() ?? "?";
							<div class="league-detail-avatar" title="@(member.UserDisplayName ?? member.UserId)">@initial</div>
						}
						@if (_leagueDetail?.ActiveMemberCount > 5)
						{
							<div class="league-detail-avatar league-detail-avatar-more">+@(_leagueDetail.ActiveMemberCount - 5)</div>
						}
					}
				</div>
				<span class="league-detail-role-badge">@_leagueDetail?.MyRole</span>
				<div class="league-detail-header-actions">
					@if (CanManageLeague)
					{
						<button class="league-detail-btn league-detail-btn-share" @onclick="OpenInviteModal">
							<i class="fa-solid fa-share-nodes"></i>
							<span>Share</span>
						</button>
						<button class="league-detail-btn league-detail-btn-create" @onclick="OpenSeasonModal">
							<i class="fa-solid fa-plus"></i>
							<span>Create</span>
						</button>
					}
					<button class="league-detail-btn league-detail-btn-refresh" aria-label="Refresh" @onclick="LoadAllAsync" disabled="@_isLoading">
						<i class="fa-solid fa-rotate-right"></i>
					</button>
				</div>
			</div>
		</div>

		@* ───── MESSAGE BANNER ───── *@
		@if (!string.IsNullOrWhiteSpace(_message))
		{
			<div class="league-detail-message @(_isError ? "league-detail-message-error" : "league-detail-message-success")" role="alert">
				<i class="fa-solid @(_isError ? "fa-triangle-exclamation" : "fa-circle-check")"></i>
				<span>@_message</span>
			</div>
		}

		@* ───── LOADING / AWAITING / ERROR STATES ───── *@
		@if (_isLoading)
		{
			<div class="league-detail-loading">
				<i class="fa-solid fa-spinner fa-spin"></i>
				<span>Loading league...</span>
			</div>
		}
		else if (_isAwaitingApproval)
		{
			<div class="league-detail-awaiting">
				<i class="fa-solid fa-clock"></i>
				<div>
					<div class="fw-semibold mb-1">Join request submitted</div>
					<div class="small">Your request to join this league is waiting for manager approval. You'll be able to view league details after approval.</div>
				</div>
			</div>
		}
		else if (_leagueDetail is null)
		{
			<div class="league-detail-loading">
				<i class="fa-solid fa-circle-exclamation"></i>
				<span>Unable to load this league.</span>
			</div>
		}
		else if (HasLeagueAccess)
		{
			@* ───── TAB NAVIGATION ───── *@
			<nav class="lobby-tabs" role="tablist" aria-label="League sections">
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Lobby ? "active" : "")" role="tab" aria-selected="@(_activeTab == LeagueDetailTab.Lobby)" @onclick="() => _activeTab = LeagueDetailTab.Lobby">
					<span class="lobby-tab-icon"><i class="fa-solid fa-house"></i></span>
					<span class="lobby-tab-text">Lobby</span>
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Results ? "active" : "")" role="tab" aria-selected="@(_activeTab == LeagueDetailTab.Results)" @onclick="() => _activeTab = LeagueDetailTab.Results">
					<span class="lobby-tab-icon"><i class="fa-solid fa-trophy"></i></span>
					<span class="lobby-tab-text">Results</span>
					@if (_recentCompletedEvents.Count > 0)
					{
						<span class="lobby-tab-badge">@_recentCompletedEvents.Count</span>
					}
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Standings ? "active" : "")" role="tab" aria-selected="@(_activeTab == LeagueDetailTab.Standings)" @onclick="() => _activeTab = LeagueDetailTab.Standings">
					<span class="lobby-tab-icon"><i class="fa-solid fa-ranking-star"></i></span>
					<span class="lobby-tab-text">Standings</span>
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Schedule ? "active" : "")" role="tab" aria-selected="@(_activeTab == LeagueDetailTab.Schedule)" @onclick="() => _activeTab = LeagueDetailTab.Schedule">
					<span class="lobby-tab-icon"><i class="fa-solid fa-calendar-days"></i></span>
					<span class="lobby-tab-text">Schedule</span>
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Members ? "active" : "")" role="tab" aria-selected="@(_activeTab == LeagueDetailTab.Members)" @onclick="() => _activeTab = LeagueDetailTab.Members">
					<span class="lobby-tab-icon"><i class="fa-solid fa-users"></i></span>
					<span class="lobby-tab-text">Members</span>
					<span class="lobby-tab-badge">@_leagueDetail?.ActiveMemberCount</span>
				</button>
			</nav>

			@* ═══════════ TAB 1: LOBBY ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Lobby)
			{
				<div class="league-detail-tab-content">
					<div class="league-detail-lobby-grid">
						<div class="league-detail-lobby-main">
							@* Recent Completed Events *@
							<section class="league-detail-card">
								<div class="league-detail-card-header">
									<h3><i class="fa-solid fa-flag-checkered"></i> Recent Results</h3>
								</div>
								@if (_recentCompletedEvents.Count == 0)
								{
									<p class="league-detail-empty">No completed events yet.</p>
								}
								else
								{
									<div class="league-detail-event-list">
										@foreach (var seasonEvent in _recentCompletedEvents)
										{
											<div class="league-detail-event-row">
												<div class="league-detail-event-info">
													<span class="league-detail-event-name">@seasonEvent.Name</span>
													<span class="league-detail-event-date">@FormatDate(seasonEvent.ScheduledAtUtc)</span>
												</div>
												<span class="league-detail-event-status league-detail-event-status-completed">@seasonEvent.Status</span>
											</div>
										}
									</div>
								}
							</section>

							@* Upcoming Events *@
							<section class="league-detail-card">
								<div class="league-detail-card-header">
									<h3><i class="fa-solid fa-calendar-star"></i> Upcoming Events</h3>
								</div>
								@{
									var upcomingSeasonEvents = _seasonEvents.Where(e => e.Status != LeagueSeasonEventStatus.Completed).Take(5).ToList();
									var upcomingOneOffs = _oneOffEvents.Where(e => e.Status != LeagueOneOffEventStatus.Completed).Take(3).ToList();
								}
								@if (upcomingSeasonEvents.Count == 0 && upcomingOneOffs.Count == 0)
								{
									<p class="league-detail-empty">No upcoming events scheduled.</p>
								}
								else
								{
									<div class="league-detail-event-list">
										@foreach (var se in upcomingSeasonEvents)
										{
											<div class="league-detail-event-row">
												<div class="league-detail-event-info">
													<span class="league-detail-event-name">@se.Name</span>
													<span class="league-detail-event-date">@FormatDate(se.ScheduledAtUtc)</span>
												</div>
												<span class="league-detail-event-status">@se.Status</span>
											</div>
										}
										@foreach (var oo in upcomingOneOffs)
										{
											<div class="league-detail-event-row">
												<div class="league-detail-event-info">
													<span class="league-detail-event-name">@oo.Name</span>
													<span class="league-detail-event-date">@oo.ScheduledAtUtc.ToLocalTime().ToString("g")</span>
												</div>
												<span class="league-detail-event-status">@oo.EventType</span>
											</div>
										}
									</div>
								}
							</section>
						</div>

						@* Sidebar: Leaders of the Season *@
						<aside class="league-detail-lobby-sidebar">
							<section class="league-detail-card league-detail-leaders-card">
								<div class="league-detail-card-header">
									<h3><i class="fa-solid fa-crown"></i> Leaders of the Season</h3>
								</div>
								@if (_standings.Count == 0)
								{
									<p class="league-detail-empty">No standings yet.</p>
								}
								else
								{
									<div class="league-detail-leaders-list">
										@foreach (var leader in _standings.Take(3))
										{
											var leaderInitial = (leader.UserDisplayName ?? leader.UserId)?[..1].ToUpperInvariant() ?? "?";
											var rankColorClass = leader.Rank switch
											{
												1 => "league-detail-leader-gold",
												2 => "league-detail-leader-silver",
												3 => "league-detail-leader-bronze",
												_ => ""
											};
											<div class="league-detail-leader-row">
												<div class="league-detail-leader-rank @rankColorClass">@leader.Rank</div>
												<div class="league-detail-leader-avatar @rankColorClass">@leaderInitial</div>
												<div class="league-detail-leader-info">
													<span class="league-detail-leader-name">@(leader.UserDisplayName ?? leader.UserId)</span>
													<span class="league-detail-leader-points">@leader.TotalPoints pts</span>
												</div>
											</div>
										}
									</div>
								}
							</section>

							@* My Progress mini card *@
							@if (_myStanding is not null)
							{
								<section class="league-detail-card league-detail-my-progress-card">
									<div class="league-detail-card-header">
										<h3><i class="fa-solid fa-chart-line"></i> My Progress</h3>
										<span class="league-rank-chip @GetRankMovementCssClass(_myStanding.UserId)">@GetRankMovementLabel(_myStanding.UserId)</span>
									</div>
									<div class="league-detail-progress-stats">
										<div class="league-detail-progress-stat">
											<span class="league-detail-progress-stat-value">#@_myStanding.Rank</span>
											<span class="league-detail-progress-stat-label">Rank</span>
										</div>
										<div class="league-detail-progress-stat">
											<span class="league-detail-progress-stat-value">@_myStanding.TotalPoints</span>
											<span class="league-detail-progress-stat-label">Points</span>
										</div>
										<div class="league-detail-progress-stat">
											<span class="league-detail-progress-stat-value">@_myStanding.TotalEvents</span>
											<span class="league-detail-progress-stat-label">Events</span>
										</div>
										<div class="league-detail-progress-stat">
											<span class="league-detail-progress-stat-value">@FormatChipsDelta(_myStanding.TotalChipsDelta)</span>
											<span class="league-detail-progress-stat-label">Chips</span>
										</div>
									</div>
								</section>
							}
						</aside>
					</div>
				</div>
			}

			@* ═══════════ TAB 2: RESULTS ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Results)
			{
				<div class="league-detail-tab-content">
					<section class="league-detail-card">
						<div class="league-detail-card-header">
							<h3><i class="fa-solid fa-trophy"></i> Season Event Results</h3>
							<div class="league-detail-card-actions">
								@if (_seasons.Count > 0)
								{
									<select class="league-detail-season-select" @onchange="OnSeasonSelectorChanged">
										@foreach (var season in _seasons)
										{
											<option value="@season.SeasonId" selected="@(season.SeasonId == _selectedSeasonId)">@season.Name</option>
										}
									</select>
								}
								@if (CanManageLeague && _selectedSeasonId.HasValue)
								{
									<button class="league-detail-btn league-detail-btn-create" @onclick="OpenSeasonEventModal">
										<i class="fa-solid fa-plus"></i> Record Results
									</button>
								}
							</div>
						</div>

						@if (_seasonEvents.Count == 0)
						{
							<p class="league-detail-empty">No season events for the selected season.</p>
						}
						else
						{
							<div class="league-detail-results-table">
								<div class="league-detail-results-header-row">
									<span>Event</span>
									<span>Scheduled</span>
									<span>Status</span>
									<span>Actions</span>
								</div>
								@foreach (var seasonEvent in _seasonEvents)
								{
									<div class="league-detail-results-row">
										<span class="league-detail-results-name">@seasonEvent.Name</span>
										<span class="league-detail-results-date">@FormatDate(seasonEvent.ScheduledAtUtc)</span>
										<span class="league-detail-event-status @(seasonEvent.Status == LeagueSeasonEventStatus.Completed ? "league-detail-event-status-completed" : "")">@seasonEvent.Status</span>
										<div class="league-detail-results-actions">
											@if (CanManageLeague)
											{
												<button class="btn btn-sm btn-outline-success league-action-btn" @onclick="() => OpenRecordResultsModal(seasonEvent)">Record Results</button>
											}
											@if (seasonEvent.LaunchedGameId.HasValue)
											{
												<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => OpenTable(seasonEvent.LaunchedGameId.Value)">Open Table</button>
											}
											else if (CanManageLeague)
											{
												<button class="btn btn-sm btn-primary league-action-btn" @onclick="() => LaunchSeasonEventAsync(seasonEvent.EventId)" disabled="@(_launchingSeasonEventId == seasonEvent.EventId)">Launch Play</button>
											}
										</div>
									</div>
								}
							</div>
						}
					</section>
				</div>
			}

			@* ═══════════ TAB 3: STANDINGS ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Standings)
			{
				<div class="league-detail-tab-content">
					<section class="league-detail-card league-detail-rules-box">
						<div class="league-detail-rules-icon"><i class="fa-solid fa-scale-balanced"></i></div>
						<div>
							<div class="fw-semibold">Scoring &amp; Tie-break Rules</div>
							<ul class="league-detail-rules-list">
								<li>Ranked by total points (highest first).</li>
								<li>Tie-break #1: total chips delta (highest first).</li>
								<li>Tie-break #2: earliest standings update wins.</li>
								<li>Standings refresh after result ingestion.</li>
							</ul>
						</div>
					</section>

					@if (_selectedSeasonId.HasValue)
					{
						<div class="league-detail-season-scope">Season: @(SelectedSeasonName ?? "Selected season")</div>
					}

					@if (_myStanding is not null)
					{
						<section class="league-detail-card league-detail-my-progress-card">
							<div class="league-detail-card-header">
								<h3><i class="fa-solid fa-chart-line"></i> My Progress</h3>
								<span class="league-rank-chip @GetRankMovementCssClass(_myStanding.UserId)">@GetRankMovementLabel(_myStanding.UserId)</span>
							</div>
							<div class="league-detail-progress-stats">
								<div class="league-detail-progress-stat">
									<span class="league-detail-progress-stat-value">#@_myStanding.Rank</span>
									<span class="league-detail-progress-stat-label">Rank</span>
								</div>
								<div class="league-detail-progress-stat">
									<span class="league-detail-progress-stat-value">@_myStanding.TotalPoints</span>
									<span class="league-detail-progress-stat-label">Points</span>
								</div>
								<div class="league-detail-progress-stat">
									<span class="league-detail-progress-stat-value">@_myStanding.TotalEvents</span>
									<span class="league-detail-progress-stat-label">Events</span>
								</div>
								<div class="league-detail-progress-stat">
									<span class="league-detail-progress-stat-value">@FormatChipsDelta(_myStanding.TotalChipsDelta)</span>
									<span class="league-detail-progress-stat-label">Chips &Delta;</span>
								</div>
							</div>
						</section>
					}

					<section class="league-detail-card">
						<div class="league-detail-card-header">
							<h3><i class="fa-solid fa-ranking-star"></i> Leaderboard</h3>
							<button class="league-detail-btn league-detail-btn-refresh" @onclick="LoadStandingsAsync" disabled="@_isLoading" aria-label="Refresh standings">
								<i class="fa-solid fa-rotate-right"></i>
							</button>
						</div>
						@if (_standings.Count == 0)
						{
							<p class="league-detail-empty">No standings yet.</p>
						}
						else
						{
							<div class="league-detail-standings-table">
								<div class="league-detail-standings-header-row">
									<span>Rank</span>
									<span>Player</span>
									<span>Points</span>
									<span>Events</span>
									<span>Chips &Delta;</span>
									<span>Movement</span>
								</div>
								@foreach (var standing in _standings)
								{
									<div class="league-detail-standings-row @(standing.Rank <= 3 ? "league-detail-standings-top" : "") @(IsCurrentUserStanding(standing) ? "league-detail-standings-me" : "")">
										<span class="league-detail-standings-rank">@GetRankPrefix(standing.Rank) #@standing.Rank</span>
										<span class="league-detail-standings-player">
											@(standing.UserDisplayName ?? standing.UserId)
											@if (IsCurrentUserStanding(standing))
											{
												<span class="league-you-chip">You</span>
											}
										</span>
										<span class="league-detail-standings-pts fw-semibold">@standing.TotalPoints</span>
										<span>@standing.TotalEvents</span>
										<span>@FormatChipsDelta(standing.TotalChipsDelta)</span>
										<span class="league-rank-chip @GetRankMovementCssClass(standing.UserId)">@GetRankMovementLabel(standing.UserId)</span>
									</div>
								}
							</div>
						}
					</section>
				</div>
			}

			@* ═══════════ TAB 4: SCHEDULE ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Schedule)
			{
				<div class="league-detail-tab-content">
					<div class="league-schedule-tabs" role="tablist" aria-label="Schedule sections">
						<button type="button"
								class="league-schedule-tab @(_activeScheduleTab == ScheduleTab.Seasons ? "league-schedule-tab-active" : string.Empty)"
								role="tab"
								aria-selected="@(_activeScheduleTab == ScheduleTab.Seasons)"
								@onclick="() => _activeScheduleTab = ScheduleTab.Seasons">
							<i class="fa-solid fa-layer-group"></i> Seasons
						</button>
						<button type="button"
								class="league-schedule-tab @(_activeScheduleTab == ScheduleTab.OneOffEvents ? "league-schedule-tab-active" : string.Empty)"
								role="tab"
								aria-selected="@(_activeScheduleTab == ScheduleTab.OneOffEvents)"
								@onclick="() => _activeScheduleTab = ScheduleTab.OneOffEvents">
							<i class="fa-solid fa-sparkles"></i> One-Off Events
						</button>
					</div>

					@if (_activeScheduleTab == ScheduleTab.Seasons)
					{
						<section class="league-detail-card">
							<div class="league-detail-card-header">
								<h3><i class="fa-solid fa-layer-group"></i> Seasons</h3>
								@if (CanManageLeague)
								{
									<button class="league-detail-btn league-detail-btn-create" @onclick="OpenSeasonModal">
										<i class="fa-solid fa-plus"></i> Create Season
									</button>
								}
							</div>
							@if (_seasons.Count == 0)
							{
								<p class="league-detail-empty">No seasons yet.</p>
							}
							else
							{
								<div class="league-detail-event-list">
									@foreach (var season in _seasons)
									{
										<div class="league-detail-event-row league-detail-season-row @(season.SeasonId == _selectedSeasonId ? "league-detail-season-selected" : "")">
											<div class="league-detail-event-info">
												<span class="league-detail-event-name">@season.Name</span>
												<span class="league-detail-event-date">@season.Status &bull; @(season.PlannedEventCount?.ToString() ?? "-") planned &bull; @FormatDate(season.StartsAtUtc) - @FormatDate(season.EndsAtUtc)</span>
											</div>
											<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => SelectSeasonAsync(season.SeasonId)">View Events</button>
										</div>
									}
								</div>
							}
						</section>

						@if (_selectedSeasonId.HasValue)
						{
							<section class="league-detail-card">
								<div class="league-detail-card-header">
									<h3><i class="fa-solid fa-calendar-check"></i> Season Events</h3>
									@if (CanManageLeague)
									{
										<button class="league-detail-btn league-detail-btn-create" @onclick="OpenSeasonEventModal">
											<i class="fa-solid fa-plus"></i> Create Event
										</button>
									}
								</div>
								@if (_seasonEvents.Count == 0)
								{
									<p class="league-detail-empty">No season events yet.</p>
								}
								else
								{
									<div class="league-detail-event-list">
										@foreach (var seasonEvent in _seasonEvents)
										{
											<div class="league-detail-event-row">
												<div class="league-detail-event-info">
													<span class="league-detail-event-name">@seasonEvent.Name</span>
													<span class="league-detail-event-date">Seq: @(seasonEvent.SequenceNumber?.ToString() ?? "-") &bull; @FormatDate(seasonEvent.ScheduledAtUtc) &bull; @seasonEvent.Status</span>
												</div>
												<div class="league-detail-event-row-actions">
													@if (CanManageLeague)
													{
														<button class="btn btn-sm btn-outline-success league-action-btn" @onclick="() => OpenRecordResultsModal(seasonEvent)">Record Results</button>
													}
													@if (seasonEvent.LaunchedGameId.HasValue)
													{
														<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => OpenTable(seasonEvent.LaunchedGameId.Value)">Open Table</button>
													}
													else if (CanManageLeague)
													{
														<button class="btn btn-sm btn-primary league-action-btn" @onclick="() => LaunchSeasonEventAsync(seasonEvent.EventId)" disabled="@(_launchingSeasonEventId == seasonEvent.EventId)">Launch Play</button>
													}
												</div>
											</div>
										}
									</div>
								}
							</section>
						}
					}
					else
					{
						<section class="league-detail-card">
							<div class="league-detail-card-header">
								<h3><i class="fa-solid fa-sparkles"></i> One-Off Events</h3>
								@if (CanManageLeague)
								{
									<button class="league-detail-btn league-detail-btn-create" @onclick="OpenOneOffModal">
										<i class="fa-solid fa-plus"></i> Create Event
									</button>
								}
							</div>
							@if (_oneOffEvents.Count == 0)
							{
								<p class="league-detail-empty">No one-off events yet.</p>
							}
							else
							{
								<div class="league-detail-event-list">
									@foreach (var oneOff in _oneOffEvents)
									{
										<div class="league-detail-event-row">
											<div class="league-detail-event-info">
												<span class="league-detail-event-name">@oneOff.Name</span>
												<span class="league-detail-event-date">@oneOff.EventType &bull; @oneOff.ScheduledAtUtc.ToLocalTime().ToString("g") &bull; @oneOff.Status</span>
											</div>
											<div class="league-detail-event-row-actions">
