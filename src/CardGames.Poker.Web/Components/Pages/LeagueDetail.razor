@page "/leagues/{LeagueId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer

@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization

@inject ILeaguesApi LeaguesApi
@inject ILogger<LeagueDetail> Logger
@inject NavigationManager NavigationManager

<PageTitle>League Detail - Friday Night Poker</PageTitle>

<AuthenticatedNavBar />

<main class="lobby-main">
	<div class="lobby-container">
		<div class="lobby-header">
			<div class="lobby-header-content">
				<h1 class="lobby-title">
					<i class="fa-solid fa-users"></i>
					League Detail
				</h1>
				@if (_leagueDetail is not null)
				{
					<p class="lobby-subtitle">@_leagueDetail.Name</p>
				}
			</div>
		</div>

		@if (!string.IsNullOrWhiteSpace(_message))
		{
			<section class="cashier-panel">
				<div class="cashier-panel-body">
					<div class="alert @(_isError ? "alert-warning" : "alert-success") mb-0" role="alert">@_message</div>
				</div>
			</section>
		}

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-2">
				<div class="cashier-section-header">
					<h2 class="cashier-section-title">Overview</h2>
					<div class="d-flex gap-2">
						<button class="btn btn-sm btn-outline-secondary league-action-btn" @onclick="LoadAllAsync" disabled="@_isLoading">Refresh</button>
						<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="BackToLeagues">Back</button>
					</div>
				</div>

				@if (_isLoading)
				{
					<p class="mb-0 text-muted">Loading league...</p>
				}
				else if (_leagueDetail is null)
				{
					<p class="mb-0 text-muted">Unable to load this league.</p>
				}
				else
				{
					<div class="small text-muted">Role: @_leagueDetail.MyRole • Active members: @_leagueDetail.ActiveMemberCount</div>
					<div class="small text-muted">Created by @_leagueDetail.CreatedByUserId • @_leagueDetail.CreatedAtUtc.ToLocalTime().ToString("g")</div>
					@if (!string.IsNullOrWhiteSpace(_leagueDetail.Description))
					{
						<div class="text-muted">@_leagueDetail.Description</div>
					}
				}
			</div>
		</section>

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<h2 class="cashier-section-title">Members</h2>
				@if (_members.Count == 0)
				{
					<p class="mb-0 text-muted">No members found.</p>
				}
				else
				{
					<ul class="list-group">
						@foreach (var member in _members)
						{
							<li class="list-group-item d-flex justify-content-between align-items-center gap-2">
								<div>
									<div class="fw-semibold">@member.UserId</div>
									<div class="small text-muted">Role: @member.Role • Joined: @member.JoinedAtUtc.ToLocalTime().ToString("g")</div>
								</div>
								@if (CanPromote(member))
								{
									<button class="btn btn-sm btn-warning" @onclick="() => PromoteMemberAsync(member.UserId)" disabled="@_isSubmittingPromote">Promote</button>
								}
							</li>
						}
					</ul>
				}

				<div>
					<h3 class="h6">Membership History</h3>
					@if (_membershipHistory.Count == 0)
					{
						<p class="mb-0 text-muted">No membership events yet.</p>
					}
					else
					{
						<ul class="list-group">
							@foreach (var historyItem in _membershipHistory)
							{
								<li class="list-group-item small">
									@historyItem.EventType • User: @historyItem.UserId • Actor: @historyItem.ActorUserId • @historyItem.OccurredAtUtc.ToLocalTime().ToString("g")
								</li>
							}
						</ul>
					}
				</div>
			</div>
		</section>

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<h2 class="cashier-section-title">Invites</h2>

				@if (IsAdmin)
				{
					<div class="auth-form">
						<h3 class="h6">Create Invite Link</h3>
						<div class="form-floating mb-3" data-label="Expiry (UTC)">
							<InputDate id="invite-expiry" class="form-control" @bind-Value="_inviteExpiryDate" />
						</div>
						<button class="btn btn-sm btn-primary" @onclick="CreateInviteAsync" disabled="@_isSubmittingInvite">Create Invite</button>
						@if (!string.IsNullOrWhiteSpace(_createdInviteUrl))
						{
							<div class="alert alert-success mt-3 mb-0" role="alert">
								Invite link: <a href="@_createdInviteUrl">@_createdInviteUrl</a>
							</div>
						}
					</div>
				}

				@if (_invites.Count == 0)
				{
					<p class="mb-0 text-muted">No invites yet.</p>
				}
				else
				{
					<ul class="list-group">
						@foreach (var invite in _invites)
						{
							<li class="list-group-item small d-flex justify-content-between align-items-center gap-2">
								<div>Status: @invite.Status • Expires: @invite.ExpiresAtUtc.ToLocalTime().ToString("g")</div>
								@if (IsAdmin && invite.Status == LeagueInviteStatus.Active)
								{
									<button class="btn btn-sm btn-outline-danger league-action-btn" @onclick="() => RevokeInviteAsync(invite.InviteId)" disabled="@_isSubmittingRevokeInvite">Revoke</button>
								}
							</li>
						}
					</ul>
				}
			</div>
		</section>

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<h2 class="cashier-section-title">Schedule</h2>

				@if (IsAdmin)
				{
					<div class="auth-form">
						<h3 class="h6">Create Season</h3>
						<div class="form-floating mb-3" data-label="Season name">
							<InputText id="season-name" class="form-control" @bind-Value="_seasonName" maxlength="120" placeholder="Season name" />
						</div>
						<div class="form-floating mb-3" data-label="Planned event count">
							<InputNumber id="season-planned-count" class="form-control" @bind-Value="_seasonPlannedEventCount" placeholder="Planned event count" />
						</div>
						<div class="row g-2 mb-3">
							<div class="col-md-6">
								<label class="form-label small">Starts (optional)</label>
								<InputDate class="form-control" @bind-Value="_seasonStartsDate" />
							</div>
							<div class="col-md-6">
								<label class="form-label small">Ends (optional)</label>
								<InputDate class="form-control" @bind-Value="_seasonEndsDate" />
							</div>
						</div>
						<button class="btn btn-sm btn-primary" @onclick="CreateSeasonAsync" disabled="@_isSubmittingSeason">Create Season</button>
					</div>
				}

				<div>
					<h3 class="h6">Seasons</h3>
					@if (_seasons.Count == 0)
					{
						<p class="mb-0 text-muted">No seasons yet.</p>
					}
					else
					{
						<ul class="list-group">
							@foreach (var season in _seasons)
							{
								<li class="list-group-item @(season.SeasonId == _selectedSeasonId ? "border-primary" : string.Empty)">
									<div class="fw-semibold">@season.Name</div>
									<div class="small text-muted">Status: @season.Status • Planned events: @(season.PlannedEventCount?.ToString() ?? "-")</div>
									<div class="small text-muted">Range: @FormatDate(season.StartsAtUtc) - @FormatDate(season.EndsAtUtc)</div>
									<button class="btn btn-sm btn-outline-primary mt-2 league-action-btn" @onclick="() => SelectSeasonAsync(season.SeasonId)">View Events</button>
								</li>
							}
						</ul>
					}
				</div>

				@if (_selectedSeasonId.HasValue)
				{
					<div>
						<h3 class="h6">Season Events</h3>

						@if (IsAdmin)
						{
							<div class="auth-form mb-3">
								<div class="form-floating mb-3" data-label="Event name">
									<InputText id="season-event-name" class="form-control" @bind-Value="_seasonEventName" maxlength="120" placeholder="Event name" />
								</div>
								<div class="form-floating mb-3" data-label="Sequence (optional)">
									<InputNumber id="season-event-sequence" class="form-control" @bind-Value="_seasonEventSequence" placeholder="Sequence" />
								</div>
								<div class="row g-2 mb-3">
									<div class="col-md-6">
										<label class="form-label small">Scheduled (optional, UTC)</label>
										<InputDate class="form-control" @bind-Value="_seasonEventScheduledDate" />
									</div>
								</div>
								<div class="form-floating mb-3" data-label="Notes (optional)">
									<InputText id="season-event-notes" class="form-control" @bind-Value="_seasonEventNotes" maxlength="512" placeholder="Notes (optional)" />
								</div>
								<button class="btn btn-sm btn-primary" @onclick="CreateSeasonEventAsync" disabled="@_isSubmittingSeasonEvent">Create Season Event</button>
							</div>
						}

						@if (_seasonEvents.Count == 0)
						{
							<p class="mb-0 text-muted">No season events yet.</p>
						}
						else
						{
							<ul class="list-group">
								@foreach (var seasonEvent in _seasonEvents)
								{
									<li class="list-group-item small">
										@seasonEvent.Name • Seq: @(seasonEvent.SequenceNumber?.ToString() ?? "-") • Scheduled: @FormatDate(seasonEvent.ScheduledAtUtc) • Status: @seasonEvent.Status
									</li>
								}
							</ul>
						}
					</div>
				}

				<div>
					<h3 class="h6">One-Off Events</h3>

					@if (IsAdmin)
					{
						<div class="auth-form mb-3">
							<div class="form-floating mb-3" data-label="Event name">
								<InputText id="one-off-name" class="form-control" @bind-Value="_oneOffName" maxlength="120" placeholder="Event name" />
							</div>
							<div class="form-floating mb-3" data-label="Scheduled (UTC)">
								<InputDate id="one-off-scheduled" class="form-control" @bind-Value="_oneOffScheduledDate" />
							</div>
							<div class="form-floating mb-3" data-label="Type">
								<InputSelect id="one-off-type" class="form-control" @bind-Value="_oneOffType">
									<option value="@LeagueOneOffEventType.GameNight">Game Night</option>
									<option value="@LeagueOneOffEventType.Tournament">Tournament</option>
								</InputSelect>
							</div>
							<div class="form-floating mb-3" data-label="Notes (optional)">
								<InputText id="one-off-notes" class="form-control" @bind-Value="_oneOffNotes" maxlength="512" placeholder="Notes (optional)" />
							</div>
							<button class="btn btn-sm btn-primary" @onclick="CreateOneOffAsync" disabled="@_isSubmittingOneOff">Create One-Off Event</button>
						</div>
					}

					@if (_oneOffEvents.Count == 0)
					{
						<p class="mb-0 text-muted">No one-off events yet.</p>
					}
					else
					{
						<ul class="list-group">
							@foreach (var oneOff in _oneOffEvents)
							{
								<li class="list-group-item small">
									@oneOff.Name • @oneOff.EventType • Scheduled: @oneOff.ScheduledAtUtc.ToLocalTime().ToString("g") • Status: @oneOff.Status
								</li>
							}
						</ul>
					}
				</div>
			</div>
		</section>
	</div>
</main>

@code {
	[Parameter]
	public Guid LeagueId { get; set; }

	private bool _isLoading;
	private bool _isError;
	private string? _message;

	private LeagueDetailDto? _leagueDetail;
	private List<LeagueMemberDto> _members = [];
	private List<LeagueMembershipHistoryItemDto> _membershipHistory = [];
	private List<LeagueInviteSummaryDto> _invites = [];

	private DateTime _inviteExpiryDate = DateTime.UtcNow.Date.AddDays(7);
	private bool _isSubmittingInvite;
	private bool _isSubmittingRevokeInvite;
	private bool _isSubmittingPromote;
	private string? _createdInviteUrl;

	private List<LeagueSeasonDto> _seasons = [];
	private Guid? _selectedSeasonId;
	private List<LeagueSeasonEventDto> _seasonEvents = [];
	private List<LeagueOneOffEventDto> _oneOffEvents = [];

	private string _seasonName = string.Empty;
	private int? _seasonPlannedEventCount;
	private DateTime? _seasonStartsDate;
	private DateTime? _seasonEndsDate;
	private bool _isSubmittingSeason;

	private string _seasonEventName = string.Empty;
	private int? _seasonEventSequence;
	private DateTime? _seasonEventScheduledDate;
	private string? _seasonEventNotes;
	private bool _isSubmittingSeasonEvent;

	private string _oneOffName = string.Empty;
	private DateTime _oneOffScheduledDate = DateTime.UtcNow.Date.AddDays(1);
	private LeagueOneOffEventType _oneOffType = LeagueOneOffEventType.GameNight;
	private string? _oneOffNotes;
	private bool _isSubmittingOneOff;

	private bool IsAdmin => _leagueDetail?.MyRole == LeagueRole.Admin;

	protected override async Task OnParametersSetAsync()
	{
		await LoadAllAsync();
	}

	private async Task LoadAllAsync()
	{
		_isLoading = true;
		_message = null;
		_isError = false;

		try
		{
			await LoadDetailAsync();
			await LoadMembersAsync();
			await LoadMembershipHistoryAsync();
			await LoadInvitesAsync();
			await LoadSeasonsAsync();
			await LoadOneOffEventsAsync();

			if (_selectedSeasonId.HasValue)
			{
				await LoadSeasonEventsAsync(_selectedSeasonId.Value);
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed loading league detail page for {LeagueId}", LeagueId);
			_message = "Unable to load this league right now.";
			_isError = true;
		}
		finally
		{
			_isLoading = false;
		}
	}

	private async Task LoadDetailAsync()
	{
		var response = await LeaguesApi.GetLeagueDetailAsync(LeagueId);
		_leagueDetail = response.IsSuccessStatusCode ? response.Content : null;
	}

	private async Task LoadMembersAsync()
	{
		var response = await LeaguesApi.GetLeagueMembersAsync(LeagueId);
		_members = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadInvitesAsync()
	{
		var response = await LeaguesApi.GetInvitesAsync(LeagueId);
		_invites = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadMembershipHistoryAsync()
	{
		var response = await LeaguesApi.GetMembershipHistoryAsync(LeagueId);
		_membershipHistory = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadSeasonsAsync()
	{
		var response = await LeaguesApi.GetSeasonsAsync(LeagueId);
		_seasons = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];

		if (_selectedSeasonId.HasValue && _seasons.All(x => x.SeasonId != _selectedSeasonId.Value))
		{
			_selectedSeasonId = null;
			_seasonEvents = [];
		}
	}

	private async Task LoadSeasonEventsAsync(Guid seasonId)
	{
		var response = await LeaguesApi.GetSeasonEventsAsync(LeagueId, seasonId);
		_seasonEvents = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task LoadOneOffEventsAsync()
	{
		var response = await LeaguesApi.GetOneOffEventsAsync(LeagueId);
		_oneOffEvents = response.IsSuccessStatusCode && response.Content is not null ? response.Content.ToList() : [];
	}

	private async Task SelectSeasonAsync(Guid seasonId)
	{
		_selectedSeasonId = seasonId;
		await LoadSeasonEventsAsync(seasonId);
	}

	private async Task CreateInviteAsync()
	{
		_isSubmittingInvite = true;
		try
		{
			var expiryUtc = new DateTimeOffset(DateTime.SpecifyKind(_inviteExpiryDate, DateTimeKind.Utc));
			var response = await LeaguesApi.CreateInviteAsync(LeagueId, new CreateLeagueInviteRequest
			{
				ExpiresAtUtc = expiryUtc
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_createdInviteUrl = NavigationManager.ToAbsoluteUri(response.Content.InviteUrl).ToString();
				_message = "Invite created.";
				_isError = false;
				await LoadInvitesAsync();
			}
			else
			{
				_message = "Failed to create invite.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create invite for league {LeagueId}", LeagueId);
			_message = "Failed to create invite.";
			_isError = true;
		}
		finally
		{
			_isSubmittingInvite = false;
		}
	}

	private async Task RevokeInviteAsync(Guid inviteId)
	{
		_isSubmittingRevokeInvite = true;
		try
		{
			var response = await LeaguesApi.RevokeInviteAsync(LeagueId, inviteId);
			if (response.IsSuccessStatusCode)
			{
				_message = "Invite revoked.";
				_isError = false;
				await LoadInvitesAsync();
			}
			else
			{
				_message = "Failed to revoke invite.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to revoke invite {InviteId} for league {LeagueId}", inviteId, LeagueId);
			_message = "Failed to revoke invite.";
			_isError = true;
		}
		finally
		{
			_isSubmittingRevokeInvite = false;
		}
	}

	private bool CanPromote(LeagueMemberDto member)
	{
		return IsAdmin && member.IsActive && member.Role != LeagueRole.Admin;
	}

	private async Task PromoteMemberAsync(string memberUserId)
	{
		_isSubmittingPromote = true;
		try
		{
			var response = await LeaguesApi.PromoteMemberToAdminAsync(LeagueId, memberUserId);
			if (response.IsSuccessStatusCode)
			{
				_message = "Member promoted to admin.";
				_isError = false;
				await LoadMembersAsync();
				await LoadDetailAsync();
			}
			else
			{
				_message = "Failed to promote member.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to promote member for league {LeagueId}", LeagueId);
			_message = "Failed to promote member.";
			_isError = true;
		}
		finally
		{
			_isSubmittingPromote = false;
		}
	}

	private async Task CreateSeasonAsync()
	{
		if (string.IsNullOrWhiteSpace(_seasonName))
		{
			_message = "Season name is required.";
			_isError = true;
			return;
		}

		_isSubmittingSeason = true;
		try
		{
			var response = await LeaguesApi.CreateSeasonAsync(LeagueId, new CreateLeagueSeasonRequest
			{
				Name = _seasonName.Trim(),
				PlannedEventCount = _seasonPlannedEventCount,
				StartsAtUtc = _seasonStartsDate.HasValue ? new DateTimeOffset(DateTime.SpecifyKind(_seasonStartsDate.Value, DateTimeKind.Utc)) : null,
				EndsAtUtc = _seasonEndsDate.HasValue ? new DateTimeOffset(DateTime.SpecifyKind(_seasonEndsDate.Value, DateTimeKind.Utc)) : null
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_seasonName = string.Empty;
				_seasonPlannedEventCount = null;
				_seasonStartsDate = null;
				_seasonEndsDate = null;
				_message = "Season created.";
				_isError = false;
				await LoadSeasonsAsync();
			}
			else
			{
				_message = "Failed to create season.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create season for league {LeagueId}", LeagueId);
			_message = "Failed to create season.";
			_isError = true;
		}
		finally
		{
			_isSubmittingSeason = false;
		}
	}

	private async Task CreateSeasonEventAsync()
	{
		if (!_selectedSeasonId.HasValue)
		{
			_message = "Select a season first.";
			_isError = true;
			return;
		}

		if (string.IsNullOrWhiteSpace(_seasonEventName))
		{
			_message = "Season event name is required.";
			_isError = true;
			return;
		}

		_isSubmittingSeasonEvent = true;
		try
		{
			var response = await LeaguesApi.CreateSeasonEventAsync(LeagueId, _selectedSeasonId.Value, new CreateLeagueSeasonEventRequest
			{
				Name = _seasonEventName.Trim(),
				SequenceNumber = _seasonEventSequence,
				ScheduledAtUtc = _seasonEventScheduledDate.HasValue ? new DateTimeOffset(DateTime.SpecifyKind(_seasonEventScheduledDate.Value, DateTimeKind.Utc)) : null,
				Notes = string.IsNullOrWhiteSpace(_seasonEventNotes) ? null : _seasonEventNotes.Trim()
			});

			if (response.IsSuccessStatusCode)
			{
				_seasonEventName = string.Empty;
				_seasonEventSequence = null;
				_seasonEventScheduledDate = null;
				_seasonEventNotes = null;
				_message = "Season event created.";
				_isError = false;
				await LoadSeasonEventsAsync(_selectedSeasonId.Value);
			}
			else
			{
				_message = "Failed to create season event.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create season event for league {LeagueId}", LeagueId);
			_message = "Failed to create season event.";
			_isError = true;
		}
		finally
		{
			_isSubmittingSeasonEvent = false;
		}
	}

	private async Task CreateOneOffAsync()
	{
		if (string.IsNullOrWhiteSpace(_oneOffName))
		{
			_message = "One-off event name is required.";
			_isError = true;
			return;
		}

		_isSubmittingOneOff = true;
		try
		{
			var response = await LeaguesApi.CreateOneOffEventAsync(LeagueId, new CreateLeagueOneOffEventRequest
			{
				Name = _oneOffName.Trim(),
				ScheduledAtUtc = new DateTimeOffset(DateTime.SpecifyKind(_oneOffScheduledDate, DateTimeKind.Utc)),
				EventType = _oneOffType,
				Notes = string.IsNullOrWhiteSpace(_oneOffNotes) ? null : _oneOffNotes.Trim()
			});

			if (response.IsSuccessStatusCode)
			{
				_oneOffName = string.Empty;
				_oneOffScheduledDate = DateTime.UtcNow.Date.AddDays(1);
				_oneOffType = LeagueOneOffEventType.GameNight;
				_oneOffNotes = null;
				_message = "One-off event created.";
				_isError = false;
				await LoadOneOffEventsAsync();
			}
			else
			{
				_message = "Failed to create one-off event.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create one-off event for league {LeagueId}", LeagueId);
			_message = "Failed to create one-off event.";
			_isError = true;
		}
		finally
		{
			_isSubmittingOneOff = false;
		}
	}

	private static string FormatDate(DateTimeOffset? value)
	{
		return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "-";
	}

	private void BackToLeagues()
	{
		NavigationManager.NavigateTo("/leagues");
	}
}
