	private async Task ConfirmDeleteEventAsync()
	{
		if (_pendingEventDeletion is null || _isDeletingEvent)
		{
			return;
		}

		_isDeletingEvent = true;
		try
		{
			Refit.IApiResponse response = _pendingEventDeletion.Kind switch
			{
				LeagueEventDeletionKind.SeasonEvent when _pendingEventDeletion.SeasonId.HasValue
					=> await LeaguesApi.DeleteSeasonEventAsync(LeagueId, _pendingEventDeletion.SeasonId.Value, _pendingEventDeletion.EventId),
				LeagueEventDeletionKind.OneOffEvent
					=> await LeaguesApi.DeleteOneOffEventAsync(LeagueId, _pendingEventDeletion.EventId),
				_ => throw new InvalidOperationException("Delete dialog is missing event context.")
			};

			if (response.IsSuccessStatusCode)
			{
				if (_pendingEventDeletion.Kind == LeagueEventDeletionKind.SeasonEvent && _pendingEventDeletion.SeasonId.HasValue)
				{
					_selectedSeasonId = _pendingEventDeletion.SeasonId.Value;
					await LoadRecentCompletedSeasonEventsAsync(_pendingEventDeletion.SeasonId.Value);

					if (_activeTab == LeagueDetailTab.Results || (_hasLoadedSeasonEvents && _loadedSeasonEventsSeasonId == _pendingEventDeletion.SeasonId.Value))
					{
						await LoadSeasonEventsAsync(_pendingEventDeletion.SeasonId.Value);
					}
					else
					{
						_seasonEvents = [];
						_hasLoadedSeasonEvents = false;
						_loadedSeasonEventsSeasonId = null;
					}

					if (_activeTab == LeagueDetailTab.Schedule || (_hasLoadedScheduleSeasonEventsPage && _loadedScheduleSeasonEventsSeasonId == _pendingEventDeletion.SeasonId.Value))
					{
						await LoadSeasonEventsPageAsync(_scheduleSeasonEventsPageNumber);
					}
					else if (_loadedScheduleSeasonEventsSeasonId == _pendingEventDeletion.SeasonId.Value)
					{
						_scheduleSeasonEventsPageNumber = 1;
						_scheduleSeasonEventsPage = CreateEmptySeasonEventsPage();
						_hasLoadedScheduleSeasonEventsPage = false;
						_loadedScheduleSeasonEventsSeasonId = null;
					}

					await LoadStandingsAsync();
					_message = "Season event deleted.";
				}
				else
				{
					if (_hasLoadedOneOffEvents)
					{
						await LoadOneOffEventsAsync();
					}

					if (_activeTab == LeagueDetailTab.Schedule || _hasLoadedScheduleOneOffEventsPage)
					{
						await LoadOneOffEventsPageAsync(_scheduleOneOffEventsPageNumber);
					}

					_message = "One-off event deleted.";
				}

				await LoadActiveGamesPageAsync(_activeGamesPageNumber);
				await LoadUpcomingEventsPageAsync(_upcomingEventsPageNumber);

				_isError = false;
				CancelDeleteEvent();
				return;
			}

			_message = TryExtractApiErrorMessage(response) ?? "Failed to delete event.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to delete league event {EventId} in league {LeagueId}", _pendingEventDeletion.EventId, LeagueId);
			_message = "Failed to delete event.";
			_isError = true;
		}
		finally
		{
			_isDeletingEvent = false;
			_showDeleteEventConfirmation = false;
			_pendingEventDeletion = null;
		}
	}

	private void CancelDeleteEvent()
	{
		if (_isDeletingEvent)
		{
			return;
		}

		_showDeleteEventConfirmation = false;
		_pendingEventDeletion = null;
	}

	
