	private IReadOnlyList<BrowserTimeZoneOption> TimeZoneOptions => _availableTimeZones.Count > 0
		? _availableTimeZones
		: [new BrowserTimeZoneOption(BrowserTimeZoneId, BrowserTimeZoneId)];

	private GetAvailablePokerGamesResponse? SelectedSeasonEventGame => _availableLeagueGames.FirstOrDefault(game => string.Equals(game.Code, _seasonEventGameTypeCode, StringComparison.OrdinalIgnoreCase));

	private bool SeasonEventSelectedGameHasBlinds => UsesBlinds(_seasonEventGameTypeCode);

	private static bool UsesBlinds(string? gameTypeCode)
	{
		return gameTypeCode?.Trim().ToUpperInvariant() is "BOBBARKER"
			or "CRAZYPINEAPPLE"
			or "HOLDEM"
			or "HOLDTHEBASEBALL"
			or "IRISHHOLDEM"
			or "KLONDIKE"
			or "NEBRASKA"
			or "OMAHA"
			or "PHILSMOM"
			or "REDRIVER"
			or "SOUTHDAKOTA";
	}

	protected override async Task OnParametersSetAsync()
	{
		await LoadAllAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!_hasResolvedBrowserTimeZone)
		{
			_hasResolvedBrowserTimeZone = true;

			try
			{
				_leagueDetailModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", LeagueDetailModulePath);
				var timeZoneSetup = await _leagueDetailModule.InvokeAsync<BrowserTimeZoneSetup>("getTimeZoneSetup");
				_browserTimeZoneId = string.IsNullOrWhiteSpace(timeZoneSetup.BrowserTimeZoneId) ? "UTC" : timeZoneSetup.BrowserTimeZoneId;
				_availableTimeZones = timeZoneSetup.TimeZones
					.Where(option => !string.IsNullOrWhiteSpace(option.Id))
					.DistinctBy(option => option.Id)
					.ToList();

				StateHasChanged();
			}
			catch (InvalidOperationException)
			{
				// Ignore JS interop errors during SSR.
			}
			catch (JSDisconnectedException)
			{
				// Ignore circuit disconnects during teardown.
			}
			catch (JSException ex)
			{
				Logger.LogDebug(ex, "Failed resolving browser time zone for league detail page {LeagueId}", LeagueId);
			}
		}
	}

	private async Task LoadAllAsync()
	{
		_isLoading = true;
		_message = null;
		_isError = false;
		_isAwaitingApproval = false;

		try
		{
			await LoadCurrentUserAsync();
			await LoadDetailAsync();

			if (!HasLeagueAccess)
			{
				ResetLeagueRestrictedData();
				return;
			}

			await LoadMembersAsync();
			await LoadMembershipHistoryAsync();
			await LoadInvitesAsync();
			await LoadStandingsAsync();
			await LoadSeasonsAsync();
			await LoadAvailableLeagueGamesAsync();
			await LoadLobbySectionsAsync(resetPages: true);

			if (_activeTab == LeagueDetailTab.Results)
			{
				await EnsureSeasonEventsLoadedAsync(forceReload: true);
			}

			if (_activeTab == LeagueDetailTab.Schedule)
			{
				await EnsureScheduleSeasonEventsPageLoadedAsync(forceReload: true);
				await EnsureScheduleOneOffEventsPageLoadedAsync(forceReload: true);
			}

			await LoadPendingJoinRequestsAsync();
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed loading league detail page for {LeagueId}", LeagueId);
			_message = "Unable to load this league right now.";
			_isError = true;
		}
		finally
		{
			await SyncLeagueHubSubscriptionAsync();
			_isLoading = false;
		}
	}

	private async Task SetActiveTabAsync(LeagueDetailTab tab)
	{
		_activeTab = tab;

		if (tab == LeagueDetailTab.Results)
		{
			await EnsureSeasonEventsLoadedAsync();
			await EnsureOneOffEventsLoadedAsync();
		}

		if (tab == LeagueDetailTab.Schedule)
		{
			await EnsureScheduleSeasonEventsPageLoadedAsync();
			await EnsureScheduleOneOffEventsPageLoadedAsync();
		}
	}

	private async Task SyncLeagueHubSubscriptionAsync()
	{
		try
		{
			if (!_isLeagueHubSubscriptionInitialized)
			{
				LeagueHubClient.OnLeagueEventChanged += HandleLeagueEventChangedAsync;
				LeagueHubClient.OnLeagueEventSessionLaunched += HandleLeagueEventSessionLaunchedAsync;
				LeagueHubClient.OnLeagueJoinRequestSubmitted += HandleLeagueJoinRequestSubmittedAsync;
				LeagueHubClient.OnLeagueJoinRequestUpdated += HandleLeagueJoinRequestUpdatedAsync;
				_isLeagueHubSubscriptionInitialized = true;
			}

			if (HasLeagueAccess)
			{
				await LeagueHubClient.ConnectAsync();
				await LeagueHubClient.SetViewedLeaguesAsync([LeagueId]);
				await LeagueHubClient.SetManagedLeaguesAsync(CanManageLeague ? [LeagueId] : []);
			}
			else if (_isLeagueHubSubscriptionInitialized && LeagueHubClient.IsConnected)
			{
				await LeagueHubClient.SetViewedLeaguesAsync([]);
				await LeagueHubClient.SetManagedLeaguesAsync([]);
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed syncing league SignalR subscription for league {LeagueId}", LeagueId);
		}
	}

	private async Task HandleLeagueJoinRequestSubmittedAsync(LeagueJoinRequestSubmittedDto payload)
	{
		await InvokeAsync(async () =>
		{
			if (payload.LeagueId != LeagueId || !HasLeagueAccess || !CanManageLeague)
			{
				return;
			}

			await LoadPendingJoinRequestsAsync();
			StateHasChanged();
		});
	}

	private async Task HandleLeagueEventSessionLaunchedAsync(LeagueEventSessionLaunchedDto payload)
	{
		await InvokeAsync(async () =>
		{
			if (payload.LeagueId != LeagueId || !HasLeagueAccess)
			{
				return;
			}

			try
			{
				await ReloadLeagueEventStateAsync();
			}
			catch (Exception ex)
			{
				Logger.LogWarning(ex, "Error reloading league event state for league {LeagueId} after session launched notification", LeagueId);
			}

			StateHasChanged();
		});
	}

	private async Task HandleLeagueEventChangedAsync(LeagueEventChangedDto payload)
	{
		await InvokeAsync(async () =>
		{
			if (payload.LeagueId != LeagueId || !HasLeagueAccess)
			{
				return;
			}

			try
			{
				await ReloadLeagueEventStateAsync();
			}
			catch (Exception ex)
			{
				Logger.LogWarning(ex, "Error reloading league event state for league {LeagueId} after {ChangeKind} notification", LeagueId, payload.ChangeKind);
			}

			StateHasChanged();
		});
	}

	private async Task ReloadLeagueEventStateAsync()
	{
		await LoadLobbySectionsAsync();

		if (_hasLoadedSeasonEvents)
		{
			await EnsureSeasonEventsLoadedAsync(forceReload: true);
		}

		if (_hasLoadedOneOffEvents)
		{
			await EnsureOneOffEventsLoadedAsync(forceReload: true);
		}

		if (_hasLoadedScheduleSeasonEventsPage)
		{
			await EnsureScheduleSeasonEventsPageLoadedAsync(forceReload: true);
		}

		if (_hasLoadedScheduleOneOffEventsPage)
		{
			await EnsureScheduleOneOffEventsPageLoadedAsync(forceReload: true);
		}
	}

	private async Task HandleLeagueJoinRequestUpdatedAsync(LeagueJoinRequestUpdatedDto payload)
	{
		await InvokeAsync(async () =>
		{
			if (payload.LeagueId != LeagueId)
			{
				return;
			}

			if (HasLeagueAccess && CanManageLeague)
			{
				await LoadPendingJoinRequestsAsync();
				StateHasChanged();
				return;
			}

			if (!_isAwaitingApproval)
			{
				return;
			}

			await LoadAllAsync();
			StateHasChanged();
		});
	}

	private async Task LoadDetailAsync()
	{
		var response = await LeaguesApi.GetLeagueDetailAsync(LeagueId);
		if (response.IsSuccessStatusCode && response.Content is not null)
		{
			_leagueDetail = response.Content;
			_isAwaitingApproval = false;
			return;
		}

		_leagueDetail = null;

		if (response.StatusCode == HttpStatusCode.Forbidden)
		{
			_isAwaitingApproval = true;
		}
	}

