@page "/leagues/{LeagueId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer

@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel
@using System.Text.Json
@using System.Security.Claims

@inject ILeaguesApi LeaguesApi
@inject ILogger<LeagueDetail> Logger
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>League Detail - Friday Night Poker</PageTitle>

<AuthenticatedNavBar />

<main class="lobby-main">
	<div class="lobby-container">
		<div class="lobby-header">
			<div class="lobby-header-content">
				<h1 class="lobby-title">
					<i class="fa-solid fa-users"></i>
					@(_leagueDetail?.Name ?? "League")
				</h1>
			</div>
		</div>

		@if (!string.IsNullOrWhiteSpace(_message))
		{
			<section class="cashier-panel">
				<div class="cashier-panel-body">
					<div class="alert @(_isError ? "alert-warning" : "alert-success") mb-0" role="alert">@_message</div>
				</div>
			</section>
		}

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<div class="cashier-section-header">
					<h2 class="cashier-section-title">Overview</h2>
					<div class="d-flex gap-2">
						<button class="league-refresh-btn" aria-label="Refresh" @onclick="LoadAllAsync" disabled="@_isLoading">
							<i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
						</button>
					</div>
				</div>

				@if (_isLoading)
				{
					<p class="mb-0 text-muted">Loading league...</p>
				}
				else if (_leagueDetail is null)
				{
					<p class="mb-0 text-muted">Unable to load this league.</p>
				}
				else
				{
					<div class="small text-muted">Role: @_leagueDetail.MyRole • Active members: @_leagueDetail.ActiveMemberCount</div>
					<div class="small text-muted">Created by @(_leagueDetail.CreatedByDisplayName ?? _leagueDetail.CreatedByUserId) • @_leagueDetail.CreatedAtUtc.ToLocalTime().ToString("g")</div>
					@if (!string.IsNullOrWhiteSpace(_leagueDetail.Description))
					{
						<div class="text-muted">@_leagueDetail.Description</div>
					}

					<h3 id="league-members" class="h6 mb-0 league-members-title">Members</h3>
					@if (_members.Count == 0)
					{
						<p class="mb-0 text-muted">No members found.</p>
					}
					else
					{
						<ul class="list-group">
							@foreach (var member in _members)
							{
								<li class="list-group-item d-flex justify-content-between align-items-center gap-2">
									<div>
										<div class="fw-semibold">@(member.UserDisplayName ?? member.UserId)</div>
										<div class="small text-muted">Role: @member.Role • Joined: @member.JoinedAtUtc.ToLocalTime().ToString("g")</div>
									</div>
									<div class="d-flex gap-2 flex-wrap justify-content-end">
										@if (CanPromote(member))
										{
											<button class="btn btn-sm btn-warning league-action-btn" @onclick="() => PromoteMemberAsync(member.UserId)" disabled="@(_isSubmittingPromote || IsActingOnMember(member.UserId))">Promote</button>
										}
										@if (CanDemote(member))
										{
											<button class="btn btn-sm btn-outline-warning league-action-btn" @onclick="() => DemoteMemberAsync(member.UserId)" disabled="@(_isSubmittingDemote || IsActingOnMember(member.UserId))">Demote</button>
										}
										@if (CanTransferOwnership(member))
										{
											<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => TransferOwnershipAsync(member.UserId)" disabled="@(_isSubmittingTransferOwnership || IsActingOnMember(member.UserId))">Transfer Owner</button>
										}
										@if (CanRemove(member))
										{
											<button class="btn btn-sm btn-outline-danger league-action-btn" @onclick="() => RemoveMemberAsync(member.UserId)" disabled="@(_isSubmittingRemove || IsActingOnMember(member.UserId))">Remove</button>
										}
									</div>
								</li>
							}
						</ul>
					}

					<h3 class="h6 mb-0 mt-2">Membership History</h3>
					@if (_membershipHistory.Count == 0)
					{
						<p class="mb-0 text-muted">No membership events yet.</p>
					}
					else
					{
						<ul class="list-group">
							@foreach (var historyItem in _membershipHistory)
							{
								<li class="list-group-item small">
									@GetMembershipHistoryEventTypeDescription(historyItem.EventType) • User: @(historyItem.UserDisplayName ?? historyItem.UserId) • Actor: @(historyItem.ActorDisplayName ?? historyItem.ActorUserId) • @historyItem.OccurredAtUtc.ToLocalTime().ToString("g")
								</li>
							}
						</ul>
					}
				}
			</div>
		</section>

		@if (CanManageLeague)
		{
			<section class="cashier-panel">
				<div class="cashier-panel-body d-flex flex-column gap-3">
					<h2 class="cashier-section-title">Admin Operations Console</h2>

					<div class="d-flex flex-column gap-2">
						<h3 class="h6 mb-0">Join Request Queue</h3>
						@if (_isLoadingJoinRequests)
						{
							<p class="mb-0 text-muted">Loading pending requests...</p>
						}
						else if (_pendingJoinRequests.Count == 0)
						{
							<p class="mb-0 text-muted">No pending join requests.</p>
						}
						else
						{
							<ul class="list-group">
								@foreach (var joinRequest in _pendingJoinRequests)
								{
									<li class="list-group-item d-flex flex-column gap-2">
										<div class="d-flex flex-wrap justify-content-between gap-2">
											<div>
												<div class="fw-semibold">@joinRequest.RequesterDisplayName</div>
												<div class="small text-muted">User: @joinRequest.RequesterUserId • Requested: @joinRequest.CreatedAtUtc.ToLocalTime().ToString("g") • Expires: @joinRequest.ExpiresAtUtc.ToLocalTime().ToString("g")</div>
											</div>
											<div class="d-flex gap-2">
												<button class="btn btn-sm btn-outline-success league-action-btn" @onclick="() => ApproveJoinRequestAsync(joinRequest.JoinRequestId)" disabled="@(_isSubmittingJoinRequest && _actingJoinRequestId == joinRequest.JoinRequestId)">Approve</button>
												<button class="btn btn-sm btn-outline-danger league-action-btn" @onclick="() => DenyJoinRequestAsync(joinRequest.JoinRequestId)" disabled="@(_isSubmittingJoinRequest && _actingJoinRequestId == joinRequest.JoinRequestId)">Deny</button>
											</div>
										</div>
										<input
											class="form-control form-control-sm"
											placeholder="Reason (optional)"
											value="@GetModerationReason(joinRequest.JoinRequestId)"
											@oninput="e => SetModerationReason(joinRequest.JoinRequestId, e.Value?.ToString())" />
									</li>
								}
							</ul>
						}
					</div>

					<div class="d-flex flex-column gap-2">
						<h3 class="h6 mb-0">Role Management</h3>
						<div class="small text-muted">Promote, demote, transfer ownership, and remove members from the overview member list.</div>
						<div class="small text-muted">Active members: @_members.Count(x => x.IsActive) • Managers: @_members.Count(x => x.IsActive && x.Role == LeagueRole.Manager) • Admins: @_members.Count(x => x.IsActive && x.Role == LeagueRole.Admin) • Members: @_members.Count(x => x.IsActive && x.Role == LeagueRole.Member)</div>
						<div>
							<a href="#league-members" class="btn btn-sm btn-outline-secondary league-action-btn">Go to Member Controls</a>
						</div>
					</div>

					<div class="d-flex flex-column gap-2">
						<h3 class="h6 mb-0">Governance Audit</h3>
						@if (GovernanceAuditEntries.Count == 0)
						{
							<p class="mb-0 text-muted">No governance actions recorded yet.</p>
						}
						else
						{
							<ul class="list-group">
								@foreach (var auditItem in GovernanceAuditEntries)
								{
									<li class="list-group-item small">
										@GetMembershipHistoryEventTypeDescription(auditItem.EventType) • User: @(auditItem.UserDisplayName ?? auditItem.UserId) • Actor: @(auditItem.ActorDisplayName ?? auditItem.ActorUserId) • @auditItem.OccurredAtUtc.ToLocalTime().ToString("g")
									</li>
								}
							</ul>
						}
					</div>
				</div>
			</section>
		}

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<div class="cashier-section-header">
					<h2 class="cashier-section-title">Invites</h2>
					@if (CanManageLeague)
					{
						<button class="btn btn-sm btn-primary league-action-btn" @onclick="OpenInviteModal">Create Invite</button>
					}
				</div>

				@if (_invites.Count == 0)
				{
					<p class="mb-0 text-muted">No invites yet.</p>
				}
				else
				{
					<ul class="list-group">
						@foreach (var invite in _invites)
						{
							<li class="list-group-item small d-flex justify-content-between align-items-center gap-2">
								<div>Status: @invite.Status • Expires: @invite.ExpiresAtUtc.ToLocalTime().ToString("g")</div>
								@if (CanManageLeague && invite.Status == LeagueInviteStatus.Active)
								{
									<button class="btn btn-sm btn-outline-danger league-action-btn" @onclick="() => RevokeInviteAsync(invite.InviteId)" disabled="@_isSubmittingRevokeInvite">Revoke</button>
								}
							</li>
						}
					</ul>
				}
			</div>
		</section>

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<div class="cashier-section-header">
					<h2 class="cashier-section-title">Standings</h2>
					<button class="btn btn-sm btn-outline-secondary league-action-btn" @onclick="LoadStandingsAsync" disabled="@_isLoading">
						<i class="fa-solid fa-rotate-right me-1" aria-hidden="true"></i>
						Refresh Standings
					</button>
				</div>

				<div class="league-standings-rules">
					<div class="fw-semibold">Scoring + tie-break rules</div>
					<ul class="mb-0 small text-muted">
						<li>Ranked by total points (highest first).</li>
						<li>Tie-break #1: total chips delta (highest first).</li>
						<li>Tie-break #2: earliest standings update wins the tie.</li>
						<li>Standings refresh after season event result ingestion.</li>
					</ul>
				</div>

				@if (_myStanding is not null)
				{
					<div class="league-my-progress">
						<div class="league-my-progress-header">
							<h3 class="h6 mb-0">My Progress</h3>
							<span class="league-rank-chip @GetRankMovementCssClass(_myStanding.UserId)">@GetRankMovementLabel(_myStanding.UserId)</span>
						</div>
						<div class="league-my-progress-grid">
							<div class="league-progress-item">
								<div class="league-progress-label">Rank</div>
								<div class="league-progress-value">#@_myStanding.Rank</div>
							</div>
							<div class="league-progress-item">
								<div class="league-progress-label">Points</div>
								<div class="league-progress-value">@_myStanding.TotalPoints</div>
							</div>
							<div class="league-progress-item">
								<div class="league-progress-label">Events</div>
								<div class="league-progress-value">@_myStanding.TotalEvents</div>
							</div>
							<div class="league-progress-item">
								<div class="league-progress-label">Chips Δ</div>
								<div class="league-progress-value">@FormatChipsDelta(_myStanding.TotalChipsDelta)</div>
							</div>
						</div>
					</div>
				}

				@if (_standings.Count == 0)
				{
					<p class="mb-0 text-muted">No standings yet.</p>
				}
				else
				{
					<ul class="list-group league-standings-list">
						@foreach (var standing in _standings)
						{
							<li class="list-group-item d-flex justify-content-between align-items-center gap-2 @GetLeaderboardRowCssClass(standing)">
								<div>
									<div class="fw-semibold d-flex align-items-center flex-wrap gap-2">
										<span>@GetRankPrefix(standing.Rank) #@standing.Rank</span>
										<span>•</span>
										<span>@(standing.UserDisplayName ?? standing.UserId)</span>
										@if (IsCurrentUserStanding(standing))
										{
											<span class="league-you-chip">You</span>
										}
									</div>
									<div class="small text-muted">Events: @standing.TotalEvents • Last place: @(standing.LastPlacement?.ToString() ?? "-") • Updated @standing.UpdatedAtUtc.ToLocalTime().ToString("g")</div>
								</div>
								<div class="text-end">
									<div class="fw-semibold">Pts: @standing.TotalPoints</div>
									<div class="small text-muted">Chips Δ: @FormatChipsDelta(standing.TotalChipsDelta)</div>
									<div class="small"><span class="league-rank-chip @GetRankMovementCssClass(standing.UserId)">@GetRankMovementLabel(standing.UserId)</span></div>
								</div>
							</li>
						}
					</ul>

					<div>
						<h3 class="h6 mb-2">Recent Results</h3>
						@if (_recentCompletedEvents.Count == 0)
						{
							<p class="mb-0 text-muted small">No completed season events yet for the selected season.</p>
						}
						else
						{
							<ul class="list-group">
								@foreach (var seasonEvent in _recentCompletedEvents)
								{
									<li class="list-group-item small d-flex justify-content-between align-items-center gap-2">
										<div>@seasonEvent.Name</div>
										<div class="text-muted">@FormatDate(seasonEvent.ScheduledAtUtc) • @seasonEvent.Status</div>
									</li>
								}
							</ul>
						}
					</div>
				}
			</div>
		</section>

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<h2 class="cashier-section-title league-schedule-title">Schedule</h2>
				<div class="league-schedule-tabs" role="tablist" aria-label="Schedule sections">
					<button
						type="button"
						class="league-schedule-tab @(_activeScheduleTab == ScheduleTab.Seasons ? "league-schedule-tab-active" : string.Empty)"
						role="tab"
						aria-selected="@(_activeScheduleTab == ScheduleTab.Seasons)"
						@onclick="() => _activeScheduleTab = ScheduleTab.Seasons">
						Seasons
					</button>
					<button
						type="button"
						class="league-schedule-tab @(_activeScheduleTab == ScheduleTab.OneOffEvents ? "league-schedule-tab-active" : string.Empty)"
						role="tab"
						aria-selected="@(_activeScheduleTab == ScheduleTab.OneOffEvents)"
						@onclick="() => _activeScheduleTab = ScheduleTab.OneOffEvents">
						One-Off Events
					</button>
				</div>

				@if (_activeScheduleTab == ScheduleTab.Seasons)
				{
					<div>
						<div class="cashier-section-header mb-2 league-seasons-header">
							<h3 class="h6 mb-0">Seasons</h3>
							@if (CanManageLeague)
							{
								<button class="btn btn-sm btn-primary league-action-btn" @onclick="OpenSeasonModal">Create Season</button>
							}
						</div>
						@if (_seasons.Count == 0)
						{
							<p class="mb-0 text-muted">No seasons yet.</p>
						}
						else
						{
							<ul class="list-group">
								@foreach (var season in _seasons)
								{
									<li class="list-group-item @(season.SeasonId == _selectedSeasonId ? "border-primary" : string.Empty)">
										<div class="fw-semibold">@season.Name</div>
										<div class="small text-muted">Status: @season.Status • Planned events: @(season.PlannedEventCount?.ToString() ?? "-")</div>
										<div class="small text-muted">Range: @FormatDate(season.StartsAtUtc) - @FormatDate(season.EndsAtUtc)</div>
										<button class="btn btn-sm btn-outline-primary mt-2 league-action-btn" @onclick="() => SelectSeasonAsync(season.SeasonId)">View Events</button>
									</li>
								}
							</ul>
						}
					</div>

					@if (_selectedSeasonId.HasValue)
					{
						<div>
							<div class="cashier-section-header mb-2">
								<h3 class="h6 mb-0">Season Events</h3>
								@if (CanManageLeague)
								{
									<button class="btn btn-sm btn-primary league-action-btn" @onclick="OpenSeasonEventModal">Create Season Event</button>
								}
							</div>

							@if (_seasonEvents.Count == 0)
							{
								<p class="mb-0 text-muted">No season events yet.</p>
							}
							else
							{
								<ul class="list-group">
									@foreach (var seasonEvent in _seasonEvents)
									{
										<li class="list-group-item small d-flex justify-content-between align-items-center gap-2">
											<div>
												@seasonEvent.Name • Seq: @(seasonEvent.SequenceNumber?.ToString() ?? "-") • Scheduled: @FormatDate(seasonEvent.ScheduledAtUtc) • Status: @seasonEvent.Status
											</div>
											<div class="d-flex gap-2">
												@if (CanManageLeague)
												{
													<button class="btn btn-sm btn-outline-success league-action-btn" @onclick="() => OpenRecordResultsModal(seasonEvent)">Record Results</button>
												}
												@if (seasonEvent.LaunchedGameId.HasValue)
												{
													<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => OpenTable(seasonEvent.LaunchedGameId.Value)">Open Table</button>
												}
												else if (CanManageLeague)
												{
													<button class="btn btn-sm btn-primary league-action-btn" @onclick="() => LaunchSeasonEventAsync(seasonEvent.EventId)" disabled="@(_launchingSeasonEventId == seasonEvent.EventId)">Launch Play</button>
												}
											</div>
										</li>
									}
								</ul>
							}
						</div>
					}
				}
				else
				{
					<div>
						<div class="cashier-section-header mb-2 league-seasons-header">
							<h3 class="h6 mb-0">One-off Events</h3>
							@if (CanManageLeague)
							{
								<button class="btn btn-sm btn-primary league-action-btn" @onclick="OpenOneOffModal">Create One-Off Event</button>
							}
						</div>

						@if (_oneOffEvents.Count == 0)
						{
							<p class="mb-0 text-muted">No one-off events yet.</p>
						}
						else
						{
							<ul class="list-group">
								@foreach (var oneOff in _oneOffEvents)
								{
									<li class="list-group-item small d-flex justify-content-between align-items-center gap-2">
										<div>
											@oneOff.Name • @oneOff.EventType • Scheduled: @oneOff.ScheduledAtUtc.ToLocalTime().ToString("g") • Status: @oneOff.Status
										</div>
										<div class="d-flex gap-2">
											@if (oneOff.LaunchedGameId.HasValue)
											{
												<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => OpenTable(oneOff.LaunchedGameId.Value)">Open Table</button>
											}
											else if (CanManageLeague)
											{
												<button class="btn btn-sm btn-primary league-action-btn" @onclick="() => LaunchOneOffEventAsync(oneOff.EventId)" disabled="@(_launchingOneOffEventId == oneOff.EventId)">Launch Play</button>
											}
										</div>
									</li>
								}
							</ul>
						}
					</div>
				}
			</div>
		</section>
	</div>
</main>

@if (_showInviteModal)
{
	<div class="confirm-dialog-overlay" @onclick="CloseInviteModal">
		<div class="confirm-dialog league-form-modal invite-modal" @onclick:stopPropagation>
			<div class="confirm-dialog-header league-form-modal-header">
				<h3 class="confirm-dialog-title mb-0">Create Invite Link</h3>
				<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="CloseInviteModal">
					<i class="fa-solid fa-xmark" aria-hidden="true"></i>
				</button>
			</div>
			<div class="confirm-dialog-body league-form-modal-body text-start">
				<div class="league-form-field">
					<label for="invite-expiry" class="form-label small mb-1">Expiry (UTC)</label>
					<InputDate id="invite-expiry" class="form-control league-modal-date-input" @bind-Value="_inviteExpiryDate" />
				</div>
				<div class="league-form-modal-actions">
					<button class="btn btn-sm btn-primary league-action-btn" @onclick="CreateInviteAsync" disabled="@_isSubmittingInvite">Create Invite</button>
				</div>
				@if (!string.IsNullOrWhiteSpace(_createdInviteUrl))
				{
					<div class="alert alert-success mt-3 mb-0" role="alert">
						<div class="d-flex align-items-center gap-2 flex-wrap">
							<span class="invite-link-text">Invite link: <a href="@_createdInviteUrl">@_createdInviteUrl</a></span>
							<button type="button" class="btn btn-sm btn-outline-success league-action-btn" @onclick="CopyCreatedInviteUrlAsync" title="@(_isInviteUrlCopied ? "Copied" : "Copy invite link")" aria-label="@(_isInviteUrlCopied ? "Copied" : "Copy invite link")">
								@if (_isInviteUrlCopied)
								{
									<i class="fa-solid fa-check" aria-hidden="true"></i>
									<span class="ms-1">Copied</span>
								}
								else
								{
									<i class="fa-regular fa-copy" aria-hidden="true"></i>
								}
							</button>
						</div>
					</div>
				}
			</div>
		</div>
	</div>
}

@if (_showSeasonModal)
{
	<div class="confirm-dialog-overlay" @onclick="CloseSeasonModal">
		<div class="confirm-dialog league-form-modal season-modal" @onclick:stopPropagation>
			<div class="confirm-dialog-header league-form-modal-header">
				<h3 class="confirm-dialog-title mb-0">Create Season</h3>
				<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="CloseSeasonModal">
					<i class="fa-solid fa-xmark" aria-hidden="true"></i>
				</button>
			</div>
			<div class="confirm-dialog-body league-form-modal-body text-start">
				<div class="form-floating" data-label="Season name">
					<InputText id="season-name" class="form-control league-modal-input" @bind-Value="_seasonName" maxlength="120" placeholder="Season name" />
				</div>
				<div class="form-floating" data-label="Planned event count">
					<InputNumber id="season-planned-count" class="form-control league-modal-input" @bind-Value="_seasonPlannedEventCount" placeholder="Planned event count" />
				</div>
				<div class="row g-2">
					<div class="col-md-6">
						<label class="form-label small">Starts (optional)</label>
						<InputDate class="form-control league-modal-date-input" @bind-Value="_seasonStartsDate" />
					</div>
					<div class="col-md-6">
						<label class="form-label small">Ends (optional)</label>
						<InputDate class="form-control league-modal-date-input" @bind-Value="_seasonEndsDate" />
					</div>
				</div>
				<div class="league-form-modal-actions">
					<button class="btn btn-sm btn-primary league-action-btn" @onclick="CreateSeasonAsync" disabled="@_isSubmittingSeason">Create Season</button>
				</div>
			</div>
