@page "/leagues/{LeagueId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using CardGames.Contracts.SignalR
@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Pages.LeagueDetailTabs
@using CardGames.Poker.Web.Components.Shared
@using CardGames.Poker.Web.Services
@using CardGames.Poker.Web.Utilities
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel
@using System.Net
@using System.Security.Claims
@using System.Text.Json

@inject ILeaguesApi LeaguesApi
@inject LeagueHubClient LeagueHubClient
@inject ILogger<LeagueDetail> Logger
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IProfileApi ProfileApi
@inject IAvailablePokerGamesApi AvailableGamesApi

<PageTitle>League Detail - Dealer's Choice Poker</PageTitle>

<AuthenticatedNavBar />

<NoChipsModal @bind-IsVisible="_showNoChipsModal" OnClose="HandleNoChipsModalClose" />

<ConfirmDialog @bind-IsVisible="_showDeleteEventConfirmation"
			   Title="Delete Event"
			   Message="@_deleteEventConfirmationMessage"
			   ConfirmText="Delete"
			   CancelText="Cancel"
			   ProcessingText="Deleting..."
			   IconClass="fa-trash"
			   ConfirmButtonClass="btn-danger"
			   IsProcessing="_isDeletingEvent"
			   AllowOverlayDismiss="false"
			   ShowCloseButton="true"
			   OnConfirm="ConfirmDeleteEventAsync"
			   OnCancel="CancelDeleteEvent" />

<main class="lobby-main">
	<div class="lobby-container">

		@* ───── LEAGUE DETAIL HEADER ───── *@
		<div class="league-detail-header">
			<div class="league-detail-header-left">
				<div class="league-detail-icon">
					<i class="fa-solid fa-shield-halved"></i>
				</div>
				<div class="league-detail-header-info">
					<h1 class="league-detail-name">@(_leagueDetail?.Name ?? "League")</h1>
					@if (!string.IsNullOrWhiteSpace(_leagueDetail?.Description))
					{
						<p class="league-detail-description">@_leagueDetail.Description</p>
					}
					<div class="league-detail-meta">
						Created by @(_leagueDetail?.CreatedByDisplayName ?? _leagueDetail?.CreatedByUserId) &bull;
						@(_leagueDetail?.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy"))
					</div>
				</div>
			</div>
			<div class="league-detail-header-right">
				<div class="league-detail-members-avatars">
					@if (_members.Count > 0)
					{
						@foreach (var member in _members.Take(5))
						{
							var initial = (member.UserDisplayName ?? member.UserId)?[..1].ToUpperInvariant() ?? "?";
							<div class="league-detail-avatar" title="@(member.UserDisplayName ?? member.UserId)">@initial</div>
						}
						@if (_leagueDetail?.ActiveMemberCount > 5)
						{
							<div class="league-detail-avatar league-detail-avatar-more">+@(_leagueDetail.ActiveMemberCount - 5)</div>
						}
					}
				</div>
				<span class="league-detail-role-badge">@_leagueDetail?.MyRole</span>
				<div class="league-detail-header-actions">
					@if (CanManageLeague)
					{
						<button class="league-detail-btn league-detail-btn-share" @onclick="OpenInviteModal">
							<i class="fa-solid fa-share-nodes"></i>
							<span>Share</span>
						</button>
						<div class="league-detail-create-dropdown-wrapper">
							<button class="league-detail-btn league-detail-btn-create" @onclick="ToggleCreateDropdown"
									@onclick:stopPropagation>
								<i class="fa-solid fa-plus"></i>
								<span>Create</span>
								<i class="fa-solid fa-chevron-down league-detail-create-chevron"></i>
							</button>
							@if (_showCreateDropdown)
							{
								<div class="league-detail-create-dropdown-backdrop" @onclick="CloseCreateDropdown"></div>
								<div class="league-detail-create-dropdown" @onclick:stopPropagation>
									<button class="league-detail-create-dropdown-item" @onclick="OpenCreateCashGame">
										<i class="fa-solid fa-coins"></i>
										<span>Create Cash Game</span>
									</button>
									<button class="league-detail-create-dropdown-item" @onclick="OpenCreateTournament">
										<i class="fa-solid fa-trophy"></i>
										<span>Create Tournament</span>
									</button>
								</div>
							}
						</div>
					}
					<button class="league-detail-btn league-detail-btn-refresh" aria-label="Refresh"
							@onclick="LoadAllAsync" disabled="@_isLoading">
						<i class="fa-solid fa-rotate-right"></i>
					</button>
				</div>
			</div>
		</div>

		@* ───── MESSAGE BANNER ───── *@
		@if (!string.IsNullOrWhiteSpace(_message))
		{
			<div class="league-detail-message @(_isError ? "league-detail-message-error" : "league-detail-message-success")"
				 role="alert">
				<i class="fa-solid @(_isError ? "fa-triangle-exclamation" : "fa-circle-check")"></i>
				<span>@_message</span>
			</div>
		}

		@* ───── LOADING / AWAITING / ERROR STATES ───── *@
		@if (_isLoading)
		{
			<div class="league-detail-loading">
				<i class="fa-solid fa-spinner fa-spin"></i>
				<span>Loading league...</span>
			</div>
		}
		else if (_isAwaitingApproval)
		{
			<div class="league-detail-awaiting">
				<i class="fa-solid fa-clock"></i>
				<div>
					<div class="fw-semibold mb-1">Join request submitted</div>
					<div class="small">Your request to join this league is waiting for manager approval. You'll be able to view league details after approval.</div>
				</div>
			</div>
		}
		else if (_leagueDetail is null)
		{
			<div class="league-detail-loading">
				<i class="fa-solid fa-circle-exclamation"></i>
				<span>Unable to load this league.</span>
			</div>
		}
		else if (HasLeagueAccess)
		{
			@* ───── TAB NAVIGATION ───── *@
			<nav class="lobby-tabs" role="tablist" aria-label="League sections">
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Lobby ? "active" : "")" role="tab"
						aria-selected="@(_activeTab == LeagueDetailTab.Lobby)"
						@onclick="() => SetActiveTabAsync(LeagueDetailTab.Lobby)">
					<span class="lobby-tab-icon"><i class="fa-thin fa-house"></i></span>
					<span class="lobby-tab-text">Lobby</span>
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Results ? "active" : "")" role="tab"
						aria-selected="@(_activeTab == LeagueDetailTab.Results)"
						@onclick="() => SetActiveTabAsync(LeagueDetailTab.Results)">
					<span class="lobby-tab-icon"><i class="fa-thin fa-trophy"></i></span>
					<span class="lobby-tab-text">Results</span>
					@if (_recentCompletedEvents.Count > 0)
					{
						<span class="lobby-tab-badge">@_recentCompletedEvents.Count</span>
					}
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Standings ? "active" : "")"
						role="tab" aria-selected="@(_activeTab == LeagueDetailTab.Standings)"
						@onclick="() => SetActiveTabAsync(LeagueDetailTab.Standings)">
					<span class="lobby-tab-icon"><i class="fa-thin fa-ranking-star"></i></span>
					<span class="lobby-tab-text">Standings</span>
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Schedule ? "active" : "")" role="tab"
						aria-selected="@(_activeTab == LeagueDetailTab.Schedule)"
						@onclick="() => SetActiveTabAsync(LeagueDetailTab.Schedule)">
					<span class="lobby-tab-icon"><i class="fa-thin fa-calendar-days"></i></span>
					<span class="lobby-tab-text">Schedule</span>
				</button>
				<button type="button" class="lobby-tab @(_activeTab == LeagueDetailTab.Members ? "active" : "")" role="tab"
						aria-selected="@(_activeTab == LeagueDetailTab.Members)"
						@onclick="() => SetActiveTabAsync(LeagueDetailTab.Members)">
					<span class="lobby-tab-icon"><i class="fa-thin fa-users"></i></span>
					<span class="lobby-tab-text">Members</span>
					<span class="lobby-tab-badge">@_leagueDetail?.ActiveMemberCount</span>
				</button>
			</nav>

			@* ═══════════ TAB 1: LOBBY ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Lobby)
			{
				<LeagueDetailLobbyTab RecentCompletedEvents="_recentCompletedEvents" ActiveGamesPage="_activeGamesPage"
									  UpcomingEventsPage="_upcomingEventsPage" Standings="_standings" MyStanding="_myStanding"
									  RankMovementByUserId="_rankMovementByUserId"
									  BrowserTimeZoneId="@BrowserTimeZoneId"
									  IsLoadingActiveGamesPage="_isLoadingActiveGamesPage" IsLoadingUpcomingEventsPage="_isLoadingUpcomingEventsPage"
									  LoadActiveGamesPage="LoadActiveGamesPageAsync" LoadUpcomingEventsPage="LoadUpcomingEventsPageAsync"
									  LaunchingSeasonEventId="_launchingSeasonEventId" LaunchingOneOffEventId="_launchingOneOffEventId"
									  OpenTable="OpenTable" CanManageLeague="CanManageLeague" EditSeasonEvent="OpenSeasonEventEditor"
									  LaunchSeasonEvent="LaunchSeasonEventFromLobbyAsync" LaunchOneOffEvent="LaunchOneOffEventFromLobbyAsync"
									  DeleteSeasonEvent="OpenDeleteSeasonEventDialog" EditOneOffEvent="OpenOneOffEventEditor"
									  DeleteOneOffEvent="OpenDeleteOneOffEventDialog" />
			}

			@* ═══════════ TAB 2: RESULTS ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Results)
			{
				<LeagueDetailResultsTab Seasons="_seasons" SelectedSeasonId="_selectedSeasonId"
									CanManageLeague="CanManageLeague" SeasonEvents="_seasonEvents"
									CompletedOneOffEvents="CompletedOneOffEvents"
									BrowserTimeZoneId="@BrowserTimeZoneId"
									LaunchingSeasonEventId="_launchingSeasonEventId" OnSeasonSelectorChanged="OnSeasonSelectorChanged"
									OpenSeasonEventModal="OpenSeasonEventModal" EditSeasonEvent="OpenSeasonEventEditor"
									DeleteSeasonEvent="OpenDeleteSeasonEventDialog"
									OpenTable="OpenTable" LaunchSeasonEvent="LaunchSeasonEventAsync" />
			}

			@* ═══════════ TAB 3: STANDINGS ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Standings)
			{
				<LeagueDetailStandingsTab SelectedSeasonId="_selectedSeasonId" SelectedSeasonName="SelectedSeasonName"
									  MyStanding="_myStanding" RankMovementByUserId="_rankMovementByUserId" Standings="_standings"
									  IsLoading="_isLoading" CurrentUserId="_currentUserId" LoadStandings="LoadStandingsAsync" />
			}

			@* ═══════════ TAB 4: SCHEDULE ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Schedule)
			{
				<LeagueDetailScheduleTab LeagueId="LeagueId" CanManageLeague="CanManageLeague" Seasons="_seasons" SelectedSeasonId="_selectedSeasonId"
									 OneOffEventsPage="_scheduleOneOffEventsPage"
									 IsLoadingOneOffEventsPage="_isLoadingScheduleOneOffEventsPage"
									 LoadOneOffEventsPage="LoadOneOffEventsPageAsync" BrowserTimeZoneId="@BrowserTimeZoneId"
									 LaunchingOneOffEventId="_launchingOneOffEventId" OpenSeasonModal="OpenSeasonModal"
									 OpenTable="OpenTable" OpenOneOffModal="OpenOneOffModal"
									 EditOneOffEvent="OpenOneOffEventEditor" DeleteOneOffEvent="OpenDeleteOneOffEventDialog"
									 LaunchOneOffEvent="LaunchOneOffEventAsync" />
			}

			@* ═══════════ TAB 5: MEMBERS ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Members)
			{
				<LeagueDetailMembersTab Members="_members" MembershipHistory="_membershipHistory"
									CanManageLeague="CanManageLeague" IsManager="IsManager" IsSubmittingPromote="_isSubmittingPromote"
									IsSubmittingDemote="_isSubmittingDemote" IsSubmittingTransferOwnership="_isSubmittingTransferOwnership"
									IsSubmittingRemove="_isSubmittingRemove" ActingMemberUserId="_actingMemberUserId"
									PromoteMember="PromoteMemberAsync" DemoteMember="DemoteMemberAsync"
									TransferOwnership="TransferOwnershipAsync" RemoveMember="RemoveMemberAsync"
									IsLoadingJoinRequests="_isLoadingJoinRequests" PendingJoinRequests="_pendingJoinRequests"
									IsSubmittingJoinRequest="_isSubmittingJoinRequest" ActingJoinRequestId="_actingJoinRequestId"
									ApproveJoinRequest="ApproveJoinRequestAsync" DenyJoinRequestAsync="DenyJoinRequestAsync"
									OpenInviteModal="OpenInviteModal" Invites="_invites" CopyInviteCodeAsync="CopyInviteCodeAsync"
									IsInviteCodeCopied="IsInviteCodeCopied" IsSubmittingRevokeInvite="_isSubmittingRevokeInvite"
									RevokeInvite="RevokeInviteAsync" />
			}
		}
	</div>
</main>

@if (_showInviteModal)
{
	<div class="confirm-dialog-overlay">
		<div class="confirm-dialog league-form-modal invite-modal" @onclick:stopPropagation>
			<div class="confirm-dialog-header league-form-modal-header">
				<h3 class="confirm-dialog-title mb-0">Create Invite Link</h3>
				<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="CloseInviteModal">
					<i class="fa-solid fa-xmark" aria-hidden="true"></i>
				</button>
			</div>
			<div class="confirm-dialog-body league-form-modal-body text-start">
				<div class="league-form-field">
					<label for="invite-expiry" class="form-label small mb-1">Expiry (UTC)</label>
					<InputDate id="invite-expiry" class="form-control league-modal-date-input" @bind-Value="_inviteExpiryDate" />
				</div>
				<div class="league-form-modal-actions">
					<button type="button" class="btn btn-sm btn-secondary league-action-btn" @onclick="CloseInviteModal"
							disabled="@_isSubmittingInvite">Cancel</button>
					<button type="button" class="btn btn-sm btn-primary league-action-btn" @onclick="CreateInviteAsync"
							disabled="@_isSubmittingInvite">Create Invite</button>
				</div>
				@if (!string.IsNullOrWhiteSpace(_createdInviteUrl))
				{
					<div class="alert alert-success mt-3 mb-0" role="alert">
						<div class="d-flex align-items-center gap-2 flex-wrap">
							<span class="invite-link-text">Invite link: <a href="@_createdInviteUrl">@_createdInviteUrl</a></span>
							<button type="button" class="btn btn-sm btn-outline-success league-action-btn"
									@onclick="CopyCreatedInviteUrlAsync"
									title="@(_isInviteUrlCopied ? "Copied" : "Copy invite link")"
									aria-label="@(_isInviteUrlCopied ? "Copied" : "Copy invite link")">
								@if (_isInviteUrlCopied)
								{
									<i class="fa-solid fa-check" aria-hidden="true"></i>
									<span class="ms-1">Copied</span>
								}
								else
								{
									<i class="fa-regular fa-copy" aria-hidden="true"></i>
								}
							</button>
						</div>
					</div>
				}
			</div>
		</div>
	</div>
}

@if (_showSeasonModal)
{
	<div class="confirm-dialog-overlay">
		<div class="confirm-dialog league-form-modal season-modal" @onclick:stopPropagation>
			<div class="confirm-dialog-header league-form-modal-header">
				<h3 class="confirm-dialog-title mb-0">Create Season</h3>
				<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="CloseSeasonModal">
					<i class="fa-solid fa-xmark" aria-hidden="true"></i>
				</button>
			</div>
			<div class="confirm-dialog-body league-form-modal-body text-start">
				<div class="form-floating" data-label="Season name">
					<InputText id="season-name" class="form-control league-modal-input" @bind-Value="_seasonName"
							   maxlength="120" placeholder="Season name" />
				</div>
				<div class="form-floating" data-label="Planned event count">
					<InputNumber id="season-planned-count" class="form-control league-modal-input"
							 @bind-Value="_seasonPlannedEventCount" placeholder="Planned event count" />
				</div>
				<div class="row g-2">
					<div class="col-md-6">
						<label class="form-label small">Starts (optional)</label>
						<InputDate class="form-control league-modal-date-input" @bind-Value="_seasonStartsDate" />
					</div>
					<div class="col-md-6">
						<label class="form-label small">Ends (optional)</label>
						<InputDate class="form-control league-modal-date-input" @bind-Value="_seasonEndsDate" />
					</div>
				</div>
				<div class="league-form-modal-actions">
					<button type="button" class="btn btn-sm btn-secondary league-action-btn" @onclick="CloseSeasonModal"
							disabled="@_isSubmittingSeason">Cancel</button>
					<button type="button" class="btn btn-sm btn-primary league-action-btn" @onclick="CreateSeasonAsync"
							disabled="@_isSubmittingSeason">Create Season</button>
				</div>
			</div>
		</div>
	</div>
}

@if (_showSeasonEventModal)
{
	<div class="confirm-dialog-overlay">
		<div class="confirm-dialog league-form-modal season-event-modal" @onclick:stopPropagation>
			<div class="confirm-dialog-header league-form-modal-header">
				<h3 class="confirm-dialog-title mb-0">@SeasonEventModalTitle</h3>
				<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="CloseSeasonEventModal">
					<i class="fa-solid fa-xmark" aria-hidden="true"></i>
				</button>
			</div>
			<div class="confirm-dialog-body league-form-modal-body text-start">
				<div class="row league-form-inline-fields">
					<div class="col-md-4 league-form-inline-field">
						<label class="form-label small" for="season-event-date">Scheduled date</label>
						<InputDate id="season-event-date" class="form-control league-modal-date-input" @bind-Value="_seasonEventScheduledDate" />
					</div>
					<div class="col-md-3 league-form-inline-field">
						<label class="form-label small" for="season-event-time">Start time</label>
						<input id="season-event-time" type="time" class="form-control league-modal-input league-modal-date-input" value="@_seasonEventScheduledTime" @onchange="OnSeasonEventScheduledTimeChanged" />
					</div>
					<div class="col-md-5 league-form-inline-field">
						<label class="form-label small" for="season-event-time-zone">Time zone</label>
						<InputSelect id="season-event-time-zone" class="form-select league-modal-input league-modal-date-input" @bind-Value="_seasonEventTimeZoneId">
							@foreach (var timeZone in TimeZoneOptions)
							{
								<option value="@timeZone.Id">@timeZone.DisplayName</option>
							}
						</InputSelect>
					</div>
				</div>
				<div class="form-floating" data-label="Notes (optional)">
					<InputText id="season-event-notes" class="form-control league-modal-input"
							   @bind-Value="_seasonEventNotes" maxlength="512" placeholder="Notes (optional)" />
				</div>
				<div class="form-floating" data-label="Game Variant">
					@if (_isLoadingAvailableLeagueGames)
					{
						<p class="text-muted small">Loading game variants...</p>
					}
					else
					{
						<InputSelect id="season-event-game-type" class="form-control league-modal-input" @bind-Value="_seasonEventGameTypeCode" @bind-Value:after="OnSeasonEventGameTypeChanged">
							<option value="">-- Select a game --</option>
							@foreach (var game in _availableLeagueGames)
							{
								<option value="@game.Code">@game.Name</option>
							}
						</InputSelect>
					}
				</div>
				@if (SeasonEventSelectedGameHasBlinds)
				{
					<div class="league-form-inline-fields league-form-inline-fields-bets">
						<div class="league-form-inline-field">
							<div class="form-floating" data-label="Small Blind">
								<InputNumber id="season-event-small-blind" class="form-control league-modal-input" @bind-Value="_seasonEventSmallBlind" min="1" max="1000" />
							</div>
						</div>
						<div class="league-form-inline-field">
							<div class="form-floating" data-label="Big Blind">
								<InputNumber id="season-event-big-blind" class="form-control league-modal-input" @bind-Value="_seasonEventBigBlind" min="1" max="2000" />
							</div>
						</div>
					</div>
				}
				else
				{
					<div class="league-form-inline-fields league-form-inline-fields-bets">
						<div class="league-form-inline-field">
							<div class="form-floating" data-label="Ante">
								<InputNumber id="season-event-ante" class="form-control league-modal-input" @bind-Value="_seasonEventAnte" min="1" max="100" />
							</div>
						</div>
						<div class="league-form-inline-field">
							<div class="form-floating" data-label="Minimum Bet">
								<InputNumber id="season-event-min-bet" class="form-control league-modal-input" @bind-Value="_seasonEventMinBet" min="1" max="1000" />
							</div>
						</div>
					</div>
				}
				<div class="join-buy-in-modal-controls">
					<label class="form-label mb-1" for="season-event-tournament-buy-in-slider">Tournament buy-in</label>
					<input id="season-event-tournament-buy-in-slider"
						   type="range"
						   class="bet-slider"
						   style="@GetSeasonEventTournamentBuyInSliderStyle()"
						   min="@GetSeasonEventTournamentBuyInMin()"
						   max="@GetSeasonEventTournamentBuyInMax()"
						   step="@GetSeasonEventTournamentBuyInStep()"
						   @bind="_seasonEventTournamentBuyIn"
						   @bind:event="oninput"
						   @bind:after="NormalizeSeasonEventTournamentBuyIn" />
					<div class="bet-slider-labels">
						<span>Min @GetSeasonEventTournamentBuyInMin().ToString("N0")</span>
						<span>Max @GetSeasonEventTournamentBuyInMax().ToString("N0")</span>
					</div>

					<input id="season-event-tournament-buy-in-input"
						   class="form-input join-buy-in-input"
						   type="number"
						   min="@GetSeasonEventTournamentBuyInMin()"
						   max="@GetSeasonEventTournamentBuyInMax()"
						   step="1"
						   @bind="_seasonEventTournamentBuyIn"
						   @bind:after="ClampSeasonEventTournamentBuyIn" />
				</div>
				<div class="league-form-modal-actions">
					<button type="button" class="btn btn-sm btn-secondary league-action-btn" @onclick="CloseSeasonEventModal"
							disabled="@_isSubmittingSeasonEvent">Cancel</button>
					<button type="button" class="btn btn-sm btn-primary league-action-btn" @onclick="SaveSeasonEventAsync"
							disabled="@_isSubmittingSeasonEvent">@SeasonEventSubmitLabel</button>
				</div>
			</div>
		</div>
	</div>
}

<CreateLeagueEventModal Show="_showOneOffModal" EventType="_oneOffType" LeagueId="LeagueId" EditingEvent="_editingOneOffEvent"
						BrowserTimeZoneId="@BrowserTimeZoneId" AvailableTimeZones="TimeZoneOptions" OnClose="CloseOneOffModal" OnSaved="HandleOneOffSaved" />

@code {
	[Parameter]
	public Guid LeagueId { get; set; }

	private bool _isLoading;
	private bool _isError;
	private string? _message;
	private bool _isAwaitingApproval;

	private LeagueDetailDto? _leagueDetail;
	private List<LeagueMemberDto> _members = [];
	private List<LeagueMembershipHistoryItemDto> _membershipHistory = [];
	private List<LeagueInviteSummaryDto> _invites = [];
	private List<LeagueJoinRequestQueueItemDto> _pendingJoinRequests = [];

	private DateTime _inviteExpiryDate = DateTime.UtcNow.Date.AddDays(7);
	private bool _isSubmittingInvite;
	private bool _isSubmittingRevokeInvite;
	private bool _isSubmittingPromote;
	private bool _isSubmittingDemote;
	private bool _isSubmittingTransferOwnership;
	private bool _isSubmittingRemove;
	private string? _actingMemberUserId;
	private bool _isLoadingJoinRequests;
	private bool _isSubmittingJoinRequest;
	private Guid? _actingJoinRequestId;
	private string? _createdInviteUrl;
	private bool _isInviteUrlCopied;
	private int _inviteCopyFeedbackVersion;
	private Guid? _copiedInviteCodeId;
	private int _inviteCodeCopyFeedbackVersion;
	private bool _showInviteModal;

	private List<LeagueSeasonDto> _seasons = [];
	private Guid? _selectedSeasonId;
	private List<LeagueSeasonEventDto> _seasonEvents = [];
	private List<LeagueOneOffEventDto> _oneOffEvents = [];
	private LeagueSeasonEventsPageDto _scheduleSeasonEventsPage = CreateEmptySeasonEventsPage();
	private LeagueOneOffEventsPageDto _scheduleOneOffEventsPage = CreateEmptyOneOffEventsPage();
	private List<LeagueStandingEntryDto> _standings = [];
	private List<LeagueSeasonEventDto> _recentCompletedEvents = [];
	private LeagueActiveGamesPageDto _activeGamesPage = CreateEmptyActiveGamesPage();
