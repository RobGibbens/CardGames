	private void OpenRecordResultsModal(LeagueSeasonEventDto seasonEvent)
	{
		if (!_selectedSeasonId.HasValue)
		{
			return;
		}

		_recordingSeasonEventId = seasonEvent.EventId;
		_recordingSeasonEventName = seasonEvent.Name;
		var activeMembers = _members
			.Where(x => x.IsActive)
			.OrderBy(x => x.Role)
			.ThenBy(x => x.UserDisplayName ?? x.UserId)
			.ToList();

		_resultDrafts = [];
		for (var index = 0; index < activeMembers.Count; index++)
		{
			var member = activeMembers[index];
			_resultDrafts.Add(new SeasonEventResultDraft
			{
				MemberUserId = member.UserId,
				MemberDisplayName = member.UserDisplayName ?? member.UserId,
				Placement = index + 1,
				Points = 0,
				ChipsDelta = 0
			});
		}

		_showRecordResultsModal = true;
	}

	private void CloseRecordResultsModal()
	{
		if (_isSubmittingResults)
		{
			return;
		}

		_showRecordResultsModal = false;
		_recordingSeasonEventId = null;
		_recordingSeasonEventName = string.Empty;
		_resultDrafts = [];
	}

	private async Task SubmitSeasonEventResultsAsync()
	{
		if (!_selectedSeasonId.HasValue || !_recordingSeasonEventId.HasValue)
		{
			_message = "Select a season event first.";
			_isError = true;
			return;
		}

		var includedResults = _resultDrafts
			.Where(x => x.Include)
			.Select(x => new LeagueSeasonEventResultEntryRequest
			{
				MemberUserId = x.MemberUserId,
				Placement = x.Placement,
				Points = x.Points,
				ChipsDelta = x.ChipsDelta
			})
			.ToList();

		if (includedResults.Count == 0)
		{
			_message = "Include at least one member result.";
			_isError = true;
			return;
		}

		_isSubmittingResults = true;
		try
		{
			var response = await LeaguesApi.IngestSeasonEventResultsAsync(LeagueId, _selectedSeasonId.Value, _recordingSeasonEventId.Value, new IngestLeagueSeasonEventResultsRequest
			{
				Results = includedResults
			});

			if (response.IsSuccessStatusCode)
			{
				_message = "Season event results recorded.";
				_isError = false;
				CloseRecordResultsModal();
				await LoadSeasonEventsAsync(_selectedSeasonId.Value);
				await LoadStandingsAsync();
				return;
			}

			_message = "Failed to record season event results.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to record season event results for league {LeagueId}", LeagueId);
			_message = "Failed to record season event results.";
			_isError = true;
		}
		finally
		{
			_isSubmittingResults = false;
		}
	}

	private static string FormatDate(DateTimeOffset? value)
	{
		return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "-";
	}

	private bool IsCurrentUserStanding(LeagueStandingEntryDto standing)
	{
		return !string.IsNullOrWhiteSpace(_currentUserId)
			&& string.Equals(standing.UserId, _currentUserId, StringComparison.Ordinal);
	}

	private string GetRankMovementLabel(string userId)
	{
		if (!_rankMovementByUserId.TryGetValue(userId, out var movement))
		{
			return "No change";
		}

		if (movement > 0)
		{
			return $"▲ {movement}";
		}

		if (movement < 0)
		{
			return $"▼ {Math.Abs(movement)}";
		}

		return "No change";
	}

	private string GetRankMovementCssClass(string userId)
	{
		if (!_rankMovementByUserId.TryGetValue(userId, out var movement))
		{
			return "league-rank-movement-neutral";
		}

		if (movement > 0)
		{
			return "league-rank-movement-up";
		}

		if (movement < 0)
		{
			return "league-rank-movement-down";
		}

		return "league-rank-movement-neutral";
	}

	private static string FormatChipsDelta(int chipsDelta)
	{
		return chipsDelta >= 0 ? $"+{chipsDelta}" : chipsDelta.ToString();
	}

	private static string GetLeaderboardRowCssClass(LeagueStandingEntryDto standing)
	{
		return standing.Rank <= 3 ? "league-standings-top-row" : string.Empty;
	}

	private static string GetRankPrefix(int rank)
	{
		return rank switch
		{
			1 => "🥇",
			2 => "🥈",
			3 => "🥉",
			_ => ""
		};
	}

	private static string GetMembershipHistoryEventTypeDescription(LeagueMembershipHistoryEventType eventType)
	{
		var field = typeof(LeagueMembershipHistoryEventType).GetField(eventType.ToString());
		var descriptionAttribute = field?.GetCustomAttributes(typeof(DescriptionAttribute), false)
			.OfType<DescriptionAttribute>()
			.FirstOrDefault();

		return descriptionAttribute?.Description ?? eventType.ToString();
	}

	private async Task LaunchSeasonEventAsync(Guid eventId)
	{
		if (!_selectedSeasonId.HasValue)
		{
			_message = "Select a season first.";
			_isError = true;
			return;
		}

		_launchingSeasonEventId = eventId;
		try
		{
			var response = await LeaguesApi.LaunchSeasonEventSessionAsync(LeagueId, _selectedSeasonId.Value, eventId, new LaunchLeagueEventSessionRequest
			{
				GameCode = "FIVECARDDRAW",
				Ante = 10,
				MinBet = 20,
				HostStartingChips = 100
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				NavigationManager.NavigateTo(response.Content.TablePath);
				return;
			}

			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to launch table from season event {EventId} in league {LeagueId}", eventId, LeagueId);
			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		finally
		{
			_launchingSeasonEventId = null;
		}
	}

