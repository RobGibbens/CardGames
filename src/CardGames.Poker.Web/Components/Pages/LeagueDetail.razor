	private static string BuildLeagueTablePath(string tablePath)
	{
		if (string.IsNullOrWhiteSpace(tablePath))
		{
			return tablePath;
		}

		if (tablePath.Contains("autojoin=", StringComparison.OrdinalIgnoreCase))
		{
			return tablePath;
		}

		return tablePath.Contains('?', StringComparison.Ordinal)
			? $"{tablePath}&autojoin=1"
			: $"{tablePath}?autojoin=1";
	}

	private async Task OpenTable(Guid gameId)
	{
		try
		{
			var cashierSummary = await ProfileApi.GetCashierSummaryAsync();
			if (cashierSummary.IsSuccessStatusCode && (cashierSummary.Content?.CurrentBalance ?? 0) <= 0)
			{
				// Allow navigation — the player may have unreturned chips from a previous session.
				// The table page handles the rejoin flow or shows the no-chips modal if ineligible.
				NavigationManager.NavigateTo(BuildLeagueTablePath($"/table/{gameId}"));
				return;
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed to check chip balance before opening table");
		}
		NavigationManager.NavigateTo(BuildLeagueTablePath($"/table/{gameId}"));
	}

