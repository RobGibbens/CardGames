	private async Task LoadActiveGameDetailsAsync()
	{
		_activeGameDetails.Clear();

		var activeGameIds = _seasonEvents
			.Where(e => e.LaunchedGameId.HasValue && e.Status != LeagueSeasonEventStatus.Completed && e.Status != LeagueSeasonEventStatus.Canceled)
			.Select(e => e.LaunchedGameId!.Value)
			.Concat(_oneOffEvents
				.Where(e => e.LaunchedGameId.HasValue && e.Status != LeagueOneOffEventStatus.Completed && e.Status != LeagueOneOffEventStatus.Canceled)
				.Select(e => e.LaunchedGameId!.Value))
			.Distinct()
			.ToList();

		var tasks = activeGameIds.Select(async gameId =>
		{
			try
			{
				var response = await GamesApi.GetTableSettingsAsync(gameId);
				if (response.IsSuccessStatusCode && response.Content is not null)
				{
					return (gameId, settings: (GetTableSettingsResponse?)response.Content);
				}
			}
			catch
			{
			}

			return (gameId, settings: (GetTableSettingsResponse?)null);
		});

		var results = await Task.WhenAll(tasks);
		foreach (var (gameId, settings) in results)
		{
			if (settings is not null)
			{
				_activeGameDetails[gameId] = settings;
			}
		}
	}

	private async Task LoadStandingsAsync()
	{
		var previousRankByUserId = _standings.ToDictionary(x => x.UserId, x => x.Rank, StringComparer.Ordinal);

		var response = await LeaguesApi.GetLeagueStandingsAsync(LeagueId, _selectedSeasonId);
		if (response.IsSuccessStatusCode && response.Content is not null)
		{
			_standings = response.Content.ToList();
			_rankMovementByUserId = new Dictionary<string, int>(StringComparer.Ordinal);

			foreach (var standing in _standings)
			{
				if (previousRankByUserId.TryGetValue(standing.UserId, out var previousRank))
				{
					_rankMovementByUserId[standing.UserId] = previousRank - standing.Rank;
				}
			}

			_myStanding = _standings.FirstOrDefault(IsCurrentUserStanding);
			return;
		}

		_standings = [];
		_rankMovementByUserId.Clear();
		_myStanding = null;
	}

	private async Task LoadCurrentUserAsync()
	{
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var user = authState.User;

		if (user.Identity?.IsAuthenticated != true)
