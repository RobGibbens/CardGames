	private async Task ModerateJoinRequestAsync(
		Guid joinRequestId,
		Func<Guid, ModerateLeagueJoinRequestRequest, Task<Refit.IApiResponse>> moderationAction,
		string? moderationReason,
		string successMessage,
		string fallbackErrorMessage)
	{
		_actingJoinRequestId = joinRequestId;
		_isSubmittingJoinRequest = true;

		try
		{
			var response = await moderationAction(joinRequestId, new ModerateLeagueJoinRequestRequest
			{
				Reason = string.IsNullOrWhiteSpace(moderationReason) ? null : moderationReason.Trim()
			});

			if (response.IsSuccessStatusCode)
			{
				_message = successMessage;
				_isError = false;
				await LoadPendingJoinRequestsAsync();
				await LoadMembersAsync();
				await LoadMembershipHistoryAsync();
				await LoadDetailAsync();
				return;
			}

			_message = TryExtractApiErrorMessage(response) ?? fallbackErrorMessage;
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to moderate join request {JoinRequestId} for league {LeagueId}", joinRequestId, LeagueId);
			_message = fallbackErrorMessage;
			_isError = true;
		}
		finally
		{
			_isSubmittingJoinRequest = false;
			_actingJoinRequestId = null;
		}
	}

	private static string? TryExtractApiErrorMessage(Refit.IApiResponse response)
	{
		var content = response.Error?.Content;
		if (string.IsNullOrWhiteSpace(content))
		{
			return response.Error?.Message;
		}

		try
		{
			using var document = JsonDocument.Parse(content);
			if (document.RootElement.ValueKind == JsonValueKind.Object)
			{
				if (document.RootElement.TryGetProperty("message", out var messageProperty))
				{
					return messageProperty.GetString();
				}

				if (document.RootElement.TryGetProperty("Message", out var messagePascalCaseProperty))
				{
					return messagePascalCaseProperty.GetString();
				}
			}
		}
		catch (JsonException)
		{
		}

		return content;
	}

