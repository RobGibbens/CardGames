	private void PopulateSeasonEventDraft(LeagueSeasonEventDto seasonEvent)
	{
		_editingSeasonEventId = seasonEvent.EventId;
		_seasonEventScheduledDate = LeagueTimeZoneHelper.ConvertUtcToLocalDate(seasonEvent.ScheduledAtUtc, BrowserTimeZoneId);
		_seasonEventScheduledTime = LeagueTimeZoneHelper.ConvertUtcToTimeText(seasonEvent.ScheduledAtUtc, BrowserTimeZoneId);
		_seasonEventTimeZoneId = BrowserTimeZoneId;
		_seasonEventNotes = seasonEvent.Notes;
		_seasonEventGameTypeCode = seasonEvent.GameTypeCode ?? string.Empty;
		_seasonEventAnte = seasonEvent.Ante ?? 10;
		_seasonEventMinBet = seasonEvent.MinBet ?? 20;
		_seasonEventSmallBlind = seasonEvent.SmallBlind ?? 5;
		_seasonEventBigBlind = seasonEvent.BigBlind ?? 10;
		_seasonEventTournamentBuyIn = seasonEvent.TournamentBuyIn ?? DefaultTournamentBuyIn;
		OnSeasonEventGameTypeChanged();
	}

	private void OnSeasonEventGameTypeChanged()
	{
		if (SeasonEventSelectedGameHasBlinds)
		{
			if (_seasonEventSmallBlind <= 0)
			{
				_seasonEventSmallBlind = 5;
			}

			if (_seasonEventBigBlind <= _seasonEventSmallBlind)
			{
				_seasonEventBigBlind = Math.Max(_seasonEventSmallBlind * 2, 10);
			}

			_seasonEventMinBet = _seasonEventBigBlind;
			_seasonEventAnte = 0;
			return;
		}

		if (_seasonEventAnte <= 0)
		{
			_seasonEventAnte = 10;
		}

		if (_seasonEventMinBet <= 0)
		{
			_seasonEventMinBet = 20;
		}
	}

	private bool TryValidateSeasonEventTournamentBuyIn(out string? errorMessage)
	{
		NormalizeSeasonEventTournamentBuyIn();
		if (_seasonEventTournamentBuyIn < GetSeasonEventTournamentBuyInMin() || _seasonEventTournamentBuyIn > GetSeasonEventTournamentBuyInMax())
		{
			errorMessage = $"Tournament buy-in must be between {GetSeasonEventTournamentBuyInMin():N0} and {GetSeasonEventTournamentBuyInMax():N0}.";
			return false;
		}

		errorMessage = null;
		return true;
	}

	private void NormalizeSeasonEventTournamentBuyIn()
	{
		var min = GetSeasonEventTournamentBuyInMin();
		var max = GetSeasonEventTournamentBuyInMax();
		var step = GetSeasonEventTournamentBuyInStep();
		var clamped = Math.Clamp(_seasonEventTournamentBuyIn, min, max);

		if (step > 1)
		{
			var snapped = ((clamped - min) / step) * step + min;
			clamped = Math.Clamp(snapped, min, max);
		}

		_seasonEventTournamentBuyIn = clamped;
	}

	private void ClampSeasonEventTournamentBuyIn()
	{
		_seasonEventTournamentBuyIn = Math.Clamp(_seasonEventTournamentBuyIn, GetSeasonEventTournamentBuyInMin(), GetSeasonEventTournamentBuyInMax());
	}

	private static int GetSeasonEventTournamentBuyInMin() => 1;

	private static int GetSeasonEventTournamentBuyInStep() => 100;

	private static int GetSeasonEventTournamentBuyInMax() => LeagueEventBuyInRules.MaxTournamentBuyIn;

	private string GetSeasonEventTournamentBuyInSliderStyle()
	{
		var min = GetSeasonEventTournamentBuyInMin();
		var max = GetSeasonEventTournamentBuyInMax();
		if (max <= min)
		{
			return "--slider-progress: 0%;";
		}

		var progress = (_seasonEventTournamentBuyIn - min) * 100.0 / (max - min);
		return $"--slider-progress: {progress:F1}%;";
	}

