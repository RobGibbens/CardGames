	private async Task LaunchSeasonEventAsync(Guid eventId)
	{
		if (!_selectedSeasonId.HasValue)
		{
			_message = "Select a season first.";
			_isError = true;
			return;
		}

		_launchingSeasonEventId = eventId;
		var seasonEvent = _scheduleSeasonEventsPage.Entries.FirstOrDefault(e => e.EventId == eventId);
		if (seasonEvent is null)
		{
			await EnsureSeasonEventsLoadedAsync();
			seasonEvent = _seasonEvents.FirstOrDefault(e => e.EventId == eventId);
		}

		await LaunchSeasonEventCoreAsync(
			_selectedSeasonId.Value,
			eventId,
			seasonEvent?.TournamentBuyIn ?? DefaultTournamentBuyIn,
			$"Failed to launch table from season event {eventId} in league {LeagueId}");
	}

	private async Task LaunchSeasonEventCoreAsync(Guid seasonId, Guid eventId, int hostStartingChips, string logMessage)
	{
		try
		{
			var seasonEvent = _scheduleSeasonEventsPage.Entries.FirstOrDefault(e => e.EventId == eventId);
			if (seasonEvent is null)
			{
				await EnsureSeasonEventsLoadedAsync();
				seasonEvent = _seasonEvents.FirstOrDefault(e => e.EventId == eventId);
			}

			var response = await LeaguesApi.LaunchSeasonEventSessionAsync(LeagueId, seasonId, eventId, new LaunchLeagueEventSessionRequest
			{
				GameCode = seasonEvent?.GameTypeCode ?? "FIVECARDDRAW",
				Ante = seasonEvent?.Ante ?? 10,
				MinBet = seasonEvent?.MinBet ?? 20,
				SmallBlind = seasonEvent?.SmallBlind,
				BigBlind = seasonEvent?.BigBlind,
				HostStartingChips = hostStartingChips
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				NavigationManager.NavigateTo(BuildLeagueTablePath(response.Content.TablePath));
				return;
			}

			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, logMessage);
			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		finally
		{
			_launchingSeasonEventId = null;
		}
	}

	private Task LaunchSeasonEventFromLobbyAsync(LeagueSeasonEventDto seasonEvent)
	{
		_selectedSeasonId = seasonEvent.SeasonId;
		_launchingSeasonEventId = seasonEvent.EventId;
		return LaunchSeasonEventCoreAsync(seasonEvent.SeasonId, seasonEvent.EventId, seasonEvent.TournamentBuyIn ?? DefaultTournamentBuyIn,
			$"Failed to launch table from season event {seasonEvent.EventId} in league {LeagueId}");
	}

