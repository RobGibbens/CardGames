	private JoinRequestModerationInput GetModerationReasonInput(Guid joinRequestId)
	{
		if (_joinRequestReasons.TryGetValue(joinRequestId, out var moderationInput))
		{
			return moderationInput;
		}

		moderationInput = new JoinRequestModerationInput();
		_joinRequestReasons[joinRequestId] = moderationInput;
		return moderationInput;
	}

