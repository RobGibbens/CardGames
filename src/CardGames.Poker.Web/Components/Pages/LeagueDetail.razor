	private async Task CopyCreatedInviteUrlAsync()
	{
		if (string.IsNullOrWhiteSpace(_createdInviteUrl))
		{
			return;
		}

		try
		{
			await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _createdInviteUrl);
			var feedbackVersion = ++_inviteCopyFeedbackVersion;
			_isInviteUrlCopied = true;
			_message = "Invite link copied.";
			_isError = false;

			await Task.Delay(1500);
			if (feedbackVersion == _inviteCopyFeedbackVersion)
			{
				_isInviteUrlCopied = false;
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed to copy invite link for league {LeagueId}", LeagueId);
			_isInviteUrlCopied = false;
			_message = "Unable to copy invite link.";
			_isError = true;
		}
	}

	private async Task CopyInviteCodeAsync(Guid inviteId, string? inviteCode)
	{
		if (string.IsNullOrWhiteSpace(inviteCode))
		{
			return;
		}

		try
		{
			await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", inviteCode);
			var feedbackVersion = ++_inviteCodeCopyFeedbackVersion;
			_copiedInviteCodeId = inviteId;
			_message = "Invite code copied.";
			_isError = false;

			await Task.Delay(1500);
			if (feedbackVersion == _inviteCodeCopyFeedbackVersion && _copiedInviteCodeId == inviteId)
			{
				_copiedInviteCodeId = null;
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed to copy invite code for invite {InviteId} in league {LeagueId}", inviteId, LeagueId);
			_copiedInviteCodeId = null;
			_message = "Unable to copy invite code.";
			_isError = true;
		}
	}

