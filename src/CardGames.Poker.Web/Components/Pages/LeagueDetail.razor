	private bool _hasResolvedBrowserTimeZone;

	private string BrowserTimeZoneId => string.IsNullOrWhiteSpace(_browserTimeZoneId) ? "UTC" : _browserTimeZoneId;

	private IReadOnlyList<BrowserTimeZoneOption> TimeZoneOptions => _availableTimeZones.Count > 0
		? _availableTimeZones
		: [new BrowserTimeZoneOption(BrowserTimeZoneId, BrowserTimeZoneId)];

	protected override async Task OnParametersSetAsync()
	{
		await LoadAllAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!_hasResolvedBrowserTimeZone)
		{
			_hasResolvedBrowserTimeZone = true;

			try
			{
				_leagueDetailModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", LeagueDetailModulePath);
				var timeZoneSetup = await _leagueDetailModule.InvokeAsync<BrowserTimeZoneSetup>("getTimeZoneSetup");
				_browserTimeZoneId = string.IsNullOrWhiteSpace(timeZoneSetup.BrowserTimeZoneId) ? "UTC" : timeZoneSetup.BrowserTimeZoneId;
				_availableTimeZones = timeZoneSetup.TimeZones
					.Where(option => !string.IsNullOrWhiteSpace(option.Id))
					.DistinctBy(option => option.Id)
					.ToList();

				StateHasChanged();
			}
			catch (InvalidOperationException)
			{
				// Ignore JS interop errors during SSR.
			}
			catch (JSDisconnectedException)
			{
				// Ignore circuit disconnects during teardown.
			}
			catch (JSException ex)
			{
				Logger.LogDebug(ex, "Failed resolving browser time zone for league detail page {LeagueId}", LeagueId);
			}
		}
	}

	private async Task LoadAllAsync()
	{
		_isLoading = true;
		_message = null;
		_isError = false;
		_isAwaitingApproval = false;

		try
		{
			await LoadCurrentUserAsync();
			await LoadDetailAsync();

			if (!HasLeagueAccess)
			{
				ResetLeagueRestrictedData();
				return;
			}

			await LoadMembersAsync();
			await LoadMembershipHistoryAsync();
			await LoadInvitesAsync();
			await LoadStandingsAsync();
			await LoadSeasonsAsync();
			await LoadOneOffEventsAsync();
			await LoadPendingJoinRequestsAsync();

			if (_selectedSeasonId.HasValue)
			{
				await LoadSeasonEventsAsync(_selectedSeasonId.Value);
			}

			await LoadActiveGameDetailsAsync();
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed loading league detail page for {LeagueId}", LeagueId);
			_message = "Unable to load this league right now.";
			_isError = true;
		}
		finally
		{
			await SyncLeagueHubSubscriptionAsync();
			_isLoading = false;
		}
	}

	private async Task SyncLeagueHubSubscriptionAsync()
	{
		try
		{
			if (!_isLeagueHubSubscriptionInitialized)
			{
				LeagueHubClient.OnLeagueJoinRequestSubmitted += HandleLeagueJoinRequestSubmittedAsync;
				LeagueHubClient.OnLeagueJoinRequestUpdated += HandleLeagueJoinRequestUpdatedAsync;
				_isLeagueHubSubscriptionInitialized = true;
			}

			if (HasLeagueAccess && CanManageLeague)
			{
				await LeagueHubClient.ConnectAsync();
				await LeagueHubClient.SetManagedLeaguesAsync([LeagueId]);
			}
			else if (_isLeagueHubSubscriptionInitialized)
			{
				await LeagueHubClient.ConnectAsync();
				await LeagueHubClient.SetManagedLeaguesAsync([]);
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed syncing league SignalR subscription for league {LeagueId}", LeagueId);
		}
	}

	private async Task HandleLeagueJoinRequestSubmittedAsync(LeagueJoinRequestSubmittedDto payload)
	{
		await InvokeAsync(async () =>
		{
			if (payload.LeagueId != LeagueId || !HasLeagueAccess || !CanManageLeague)
			{
				return;
			}

			await LoadPendingJoinRequestsAsync();
			StateHasChanged();
		});
	}

	private async Task HandleLeagueJoinRequestUpdatedAsync(LeagueJoinRequestUpdatedDto payload)
	{
		await InvokeAsync(async () =>
		{
			if (payload.LeagueId != LeagueId)
			{
				return;
			}

			if (HasLeagueAccess && CanManageLeague)
			{
				await LoadPendingJoinRequestsAsync();
				StateHasChanged();
				return;
			}

			if (!_isAwaitingApproval)
			{
				return;
			}

			await LoadAllAsync();
			StateHasChanged();
		});
	}

	private async Task LoadDetailAsync()
	{
		var response = await LeaguesApi.GetLeagueDetailAsync(LeagueId);
		if (response.IsSuccessStatusCode && response.Content is not null)
		{
			_leagueDetail = response.Content;
			_isAwaitingApproval = false;
			return;
		}

		_leagueDetail = null;

		if (response.StatusCode == HttpStatusCode.Forbidden)
		{
			_isAwaitingApproval = true;
		}
	}

