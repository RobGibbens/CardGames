										<label class="form-label small">Placement</label>
										<InputNumber class="form-control league-modal-input" @bind-Value="draft.Placement" disabled="@(!draft.Include)" />
									</div>
									<div class="col-md-4">
										<label class="form-label small">Points</label>
										<InputNumber class="form-control league-modal-input" @bind-Value="draft.Points" disabled="@(!draft.Include)" />
									</div>
									<div class="col-md-4">
										<label class="form-label small">Chips Δ</label>
