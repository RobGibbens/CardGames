	private async Task LaunchSeasonEventAsync(Guid eventId)
	{
		if (!_selectedSeasonId.HasValue)
		{
			_message = "Select a season first.";
			_isError = true;
			return;
		}

		_launchingSeasonEventId = eventId;
		try
		{
			var response = await LeaguesApi.LaunchSeasonEventSessionAsync(LeagueId, _selectedSeasonId.Value, eventId, new
LaunchLeagueEventSessionRequest
			{
				GameCode = "FIVECARDDRAW",
				Ante = 10,
				MinBet = 20,
				HostStartingChips = 100
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				NavigationManager.NavigateTo(response.Content.TablePath);
				return;
			}

			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to launch table from season event {EventId} in league {LeagueId}", eventId, LeagueId);
			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		finally
		{
			_launchingSeasonEventId = null;
		}
	}

	private async Task LaunchOneOffEventAsync(Guid eventId)
	{
		_launchingOneOffEventId = eventId;
		try
		{
			var oneOff = _oneOffEvents.FirstOrDefault(e => e.EventId == eventId);
			var response = await LeaguesApi.LaunchOneOffEventSessionAsync(LeagueId, eventId, new LaunchLeagueEventSessionRequest
			{
				GameCode = oneOff?.GameTypeCode ?? "FIVECARDDRAW",
				GameName = oneOff?.Name,
				Ante = oneOff?.Ante ?? 10,
				MinBet = oneOff?.MinBet ?? 20,
				HostStartingChips = 100
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				NavigationManager.NavigateTo(response.Content.TablePath);
				return;
			}

			_message = "Failed to launch table from one-off event.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to launch table from one-off event {EventId} in league {LeagueId}", eventId, LeagueId);
			_message = "Failed to launch table from one-off event.";
			_isError = true;
		}
		finally
		{
			_launchingOneOffEventId = null;
		}
	}

	private async Task OpenTable(Guid gameId)
	{
		try
		{
			var cashierSummary = await ProfileApi.GetCashierSummaryAsync();
			if (cashierSummary.IsSuccessStatusCode && (cashierSummary.Content?.CurrentBalance ?? 0) <= 0)
			{
				// Allow navigation — the player may have unreturned chips from a previous session.
				// The table page handles the rejoin flow or shows the no-chips modal if ineligible.
				NavigationManager.NavigateTo($"/table/{gameId}");
				return;
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed to check chip balance before opening table");
		}
		NavigationManager.NavigateTo($"/table/{gameId}");
	}

