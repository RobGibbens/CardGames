			var response = await LeaguesApi.GetOneOffEventsPageAsync(LeagueId, SchedulePageSize, pageNumber, includeCompleted: false);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_scheduleOneOffEventsPage = response.Content;
				_scheduleOneOffEventsPageNumber = response.Content.PageNumber;
				_hasLoadedScheduleOneOffEventsPage = true;
				return;
			}

			_scheduleOneOffEventsPage = CreateEmptyOneOffEventsPage(pageNumber);
			_scheduleOneOffEventsPageNumber = _scheduleOneOffEventsPage.PageNumber;
			_hasLoadedScheduleOneOffEventsPage = true;
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed loading one-off events page for league {LeagueId}", LeagueId);
			_scheduleOneOffEventsPage = CreateEmptyOneOffEventsPage(pageNumber);
			_scheduleOneOffEventsPageNumber = _scheduleOneOffEventsPage.PageNumber;
			_hasLoadedScheduleOneOffEventsPage = true;
		}
		finally
		{
			_isLoadingScheduleOneOffEventsPage = false;
		}
	}

	private async Task LoadLobbySectionsAsync(bool resetPages = false)
	{
		if (resetPages)
		{
			_activeGamesPageNumber = 1;
			_upcomingEventsPageNumber = 1;
		}

		try
		{
			if (_selectedSeasonId.HasValue)
			{
				await LoadRecentCompletedSeasonEventsAsync(_selectedSeasonId.Value);
			}
			else
			{
				_recentCompletedEvents = [];
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed loading recent completed events for league {LeagueId}", LeagueId);
		}

		try
		{
			await LoadActiveGamesPageAsync(_activeGamesPageNumber);
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed loading active games page for league {LeagueId}", LeagueId);
		}

		await LoadUpcomingEventsPageAsync(_upcomingEventsPageNumber);
	}

