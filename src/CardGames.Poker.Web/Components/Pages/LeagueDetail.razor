													<button class="btn btn-sm btn-primary league-action-btn" @onclick="() => LaunchOneOffEventAsync(oneOff.EventId)" disabled="@(_launchingOneOffEventId == oneOff.EventId)">Launch Play</button>
												}
											</div>
										</div>
									}
								</div>
							}
						</section>
					}
				</div>
			}

			@* ═══════════ TAB 5: MEMBERS ═══════════ *@
			@if (_activeTab == LeagueDetailTab.Members)
			{
				<div class="league-detail-tab-content">
					<section class="league-detail-card">
						<div class="league-detail-card-header">
							<h3><i class="fa-solid fa-users"></i> Members (@_members.Count)</h3>
						</div>
						@if (_members.Count == 0)
						{
							<p class="league-detail-empty">No members found.</p>
						}
