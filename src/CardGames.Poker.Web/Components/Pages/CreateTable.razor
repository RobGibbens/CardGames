	private async Task DebounceCanCreateUpdateAsync()
	{
		_canCreateDebounceCancellationTokenSource?.Cancel();
		_canCreateDebounceCancellationTokenSource?.Dispose();

		var cancellationTokenSource = new CancellationTokenSource();
		_canCreateDebounceCancellationTokenSource = cancellationTokenSource;

		try
		{
			await Task.Delay(CanCreateDebounceDelayMilliseconds, cancellationTokenSource.Token);
			ApplyBufferedCanCreateInputs();
			await InvokeAsync(StateHasChanged);
		}
		catch (OperationCanceledException)
		{
			// A newer keystroke restarted the debounce window.
		}
	}

	private void ApplyBufferedCanCreateInputs()
	{
		_tableName = _tableNameInput;
		_smallBlind = ParseBufferedInteger(_smallBlindInput);
		_bigBlind = ParseBufferedInteger(_bigBlindInput);
		_ante = ParseBufferedInteger(_anteInput);
		_minBet = ParseBufferedInteger(_minBetInput);
		_maxBuyIn = ParseBufferedNullableInteger(_maxBuyInInput);
	}

	private void SyncBufferedCanCreateInputs()
	{
		_tableNameInput = _tableName;
		_smallBlindInput = _smallBlind.ToString();
		_bigBlindInput = _bigBlind.ToString();
		_anteInput = _ante.ToString();
		_minBetInput = _minBet.ToString();
		_maxBuyInInput = _maxBuyIn?.ToString() ?? string.Empty;
	}

	private static int ParseBufferedInteger(string value)
	{
		return int.TryParse(value, out var parsedValue) ? parsedValue : 0;
	}

	private static int? ParseBufferedNullableInteger(string value)
	{
		if (string.IsNullOrWhiteSpace(value))
		{
			return null;
		}

		return int.TryParse(value, out var parsedValue) ? parsedValue : null;
	}

	private int GetConfiguredMinimumBuyIn()
	{
		if (_selectedVariant is null || _isDealersChoice)
		{
			return 1;
		}

		if (IsScrewYourNeighbor)
		{
			return Math.Max(1, _ante * 3);
		}

		if (IsInBetween)
		{
			return Math.Max(1, _ante);
		}

		if (_hasBlinds)
		{
			return Math.Max(1, _bigBlind);
		}

		return Math.Max(1, Math.Max(_ante, _minBet));
	}

	private static string NormalizeVariantCode(string? value)
	{
		return string.IsNullOrWhiteSpace(value)
			? string.Empty
			: value.Trim().ToUpperInvariant();
	}

	private bool MatchesVariantSearch(string gameName)
	{
		return string.IsNullOrWhiteSpace(_variantSearch)
			|| gameName.Contains(_variantSearch, StringComparison.OrdinalIgnoreCase);
	}

	private static bool IsScrewYourNeighborCode(string? gameCode)
	{
		return string.Equals(gameCode, ScrewYourNeighborCode, StringComparison.OrdinalIgnoreCase);
	}

	private static bool IsInBetweenCode(string? gameCode)
	{
		return string.Equals(gameCode, InBetweenCode, StringComparison.OrdinalIgnoreCase);
	}

