	{
		_tableNameInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnSmallBlindInput(ChangeEventArgs args)
	{
		_smallBlindInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnBigBlindInput(ChangeEventArgs args)
	{
		_bigBlindInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnAnteInput(ChangeEventArgs args)
	{
		_anteInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnMinimumBetInput(ChangeEventArgs args)
	{
		_minBetInput = args.Value?.ToString() ?? string.Empty;
