@page "/table/create"
@attribute [Authorize]
@rendermode InteractiveServer

@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable

@inject IGamesApi GamesApi
@inject IAvailablePokerGamesApi AvailableGamesApi
@inject IProfileApi ProfileApi
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Create Table - Friday Night Poker</PageTitle>

<AuthenticatedNavBar />

<main class="create-table-main">
	<div class="create-table-container">
		<!-- Page Header -->
		<div class="create-table-header">
			<a href="/lobby" class="back-link">
				<i class="fa-regular fa-arrow-left"></i>
				Back to Lobby
			</a>
			<div class="create-table-header-content">
				<h1 class="create-table-title">
					<i class="fa-regular fa-plus"></i>
					Create New Table
				</h1>
				<p class="create-table-subtitle">Set up your private poker game and invite friends to play</p>
			</div>
		</div>

		@if (_isLoading)
		{
			<div class="create-table-loading">
				<div class="loading-spinner"></div>
				<p>Loading game variants...</p>
			</div>
		}
		else if (_loadError is not null)
		{
			<div class="create-table-error">
				<div class="error-icon"><i class="fa-thin fa-triangle-exclamation"></i></div>
				<h3>Failed to Load</h3>
				<p>@_loadError</p>
				<button class="btn btn-primary" @onclick="LoadAvailableGamesAsync">Try Again</button>
			</div>
		}
		else
		{
			<div class="create-table-content">
				<!-- Step 1: Choose Variant -->
				<section class="create-step">
					<div class="step-header">
						<span class="step-number">1</span>
						<div class="step-info">
								<h2 class="step-title">Choose Game Variant</h2>
								<p class="step-description">Select the poker variant you want to play</p>
							</div>
						</div>
						@if (_selectedVariant is null)
						{
						<div class="form-row variant-search-row">
							<div class="form-group">
								<label class="form-label" for="variantSearch">Search Variants</label>
							<input type="text"
								   id="variantSearch"
								   class="form-input"
								   placeholder="Search by game name"
								   @bind="_variantSearch"
								   @bind:event="oninput" />
						</div>
					</div>
						}
					<div class="variants-selection-region" @ref="_variantsSelectionRegion">
					@if (ShowDealersChoiceCard)
					{
						<div class="variants-grid @(_selectedVariant is not null ? "has-selection" : "")">
							@{
								var game = DealersChoiceCard;
								var isAvailable = true;
							}
							<div class="variant-card @GetVariantCardClasses(game) @(!isAvailable ? "disabled" : "")"
								 data-variant-code="@game.Code"
								 @onclick="() => SelectVariantAsync(game, isAvailable)">
								<div class="variant-icon">
									@if (!string.IsNullOrEmpty(game.ImageName))
									{
										<img src="/images/games/@(game.ImageName)" alt="@game.Name" class="variant-icon-image" />
									}
									else if (game.Code == DealersChoiceCode)
									{
										<img src="/images/games/dealerschoice.png" alt="@game.Name" class="variant-icon-image" />
									}
									else
									{
										<span class="variant-icon-fallback"><i class="fa-thin fa-card-club"></i></span>
									}
								</div>
								<div class="variant-content">
									<h3 class="variant-name">@game.Name</h3>
									<p class="variant-description">@game.Description</p>
									<div class="variant-meta">
										<span class="variant-players">
											<i class="fa-regular fa-users"></i>
											@game.MinimumNumberOfPlayers-@game.MaximumNumberOfPlayers players
										</span>
									</div>
								</div>
								@if (!isAvailable)
								{
									<span class="variant-badge coming-soon">Coming Soon</span>
								}
								@if (_selectedVariant?.Code == game.Code)
								{
									<span class="variant-selected-indicator"><i class="fa-thin fa-check"></i></span>
								}
							</div>
						</div>
					}
					@foreach (var group in VariantCardGroups)
					{
						if (group.Cards.Count == 0)
						{
							continue;
						}

						<section class="variant-group @GetVariantGroupClasses(group)">
							@if (_selectedVariant is null)
							{
								<h2>@group.Title</h2>
							}
							<div class="variants-grid @(_selectedVariant is not null ? "has-selection" : "")">
								@foreach (var game in group.Cards)
								{
									var isAvailable = game.Code == DealersChoiceCode
										|| _availableGames.Any(g => string.Equals(g.Code, game.Code, StringComparison.OrdinalIgnoreCase));
										<div class="variant-card @GetVariantCardClasses(game) @(!isAvailable ? "disabled" : "")"
										 data-variant-code="@game.Code"
										 @onclick="() => SelectVariantAsync(game, isAvailable)">
										<div class="variant-icon">
											@if (!string.IsNullOrEmpty(game.ImageName))
											{
												<img src="/images/games/@(game.ImageName)" alt="@game.Name" class="variant-icon-image" />
											}
											else if (game.Code == DealersChoiceCode)
											{
												<img src="/images/games/dealerschoice.png" alt="@game.Name" class="variant-icon-image" />
											}
											else
											{
												<span class="variant-icon-fallback"><i class="fa-thin fa-card-club"></i></span>
											}
										</div>
										<div class="variant-content">
											<h3 class="variant-name">@game.Name</h3>
											<p class="variant-description">@game.Description</p>
											<div class="variant-meta">
												<span class="variant-players">
													<i class="fa-regular fa-users"></i>
													@game.MinimumNumberOfPlayers-@game.MaximumNumberOfPlayers players
												</span>
											</div>
										</div>
										@if (!isAvailable)
										{
											<span class="variant-badge coming-soon">Coming Soon</span>
										}
										@if (_selectedVariant?.Code == game.Code)
										{
											<span class="variant-selected-indicator"><i class="fa-thin fa-check"></i></span>
										}
									</div>
								}
							</div>
						</section>
					}
					</div>
				</section>

				@if (_selectedVariant is not null)
				{
					<!-- Step 2: Table Settings -->
					<section class="create-step animate-fade-in-up">
						<div class="step-header">
							<span class="step-number">2</span>
							<div class="step-info">
								<h2 class="step-title">Table Settings</h2>
								<p class="step-description">Configure your table name and game rules</p>
							</div>
						</div>
						<div class="settings-form">
							<div class="form-row">
								<div class="form-group">
									<label class="form-label" for="tableName">Table Name</label>
									<input type="text"
										   id="tableName"
										   class="form-input"
										   placeholder="e.g., Friday Night Poker"
										   value="@_tableNameInput"
										   @oninput="OnTableNameInput"
										   maxlength="50" />
									<span class="form-hint">Give your table a memorable name</span>
								</div>
							</div>
							@if (!_isDealersChoice)
							{
								@if (_hasBlinds)
								{
									<div class="form-row two-columns">
										<div class="form-group">
											<label class="form-label" for="smallBlind">Small Blind</label>
											<input type="number"
												   id="smallBlind"
												   class="form-input"
												   min="1"
												   max="50000"
											   value="@_smallBlindInput"
											   @oninput="OnSmallBlindInput" />
											<span class="form-hint">Small blind amount</span>
										</div>
										<div class="form-group">
											<label class="form-label" for="bigBlind">Big Blind</label>
											<input type="number"
												   id="bigBlind"
												   class="form-input"
												   min="1"
												   max="100000"
											   value="@_bigBlindInput"
											   @oninput="OnBigBlindInput" />
											<span class="form-hint">Minimum bet is automatically set to the big blind.</span>
										</div>
									</div>
								}
								else
								{
                                  <div class="form-row @(ShowMinimumBetInput ? "two-columns" : string.Empty)">
										<div class="form-group">
                                           <label class="form-label" for="ante">@(IsScrewYourNeighbor ? "Chip stack amount" : "Ante")</label>
											<input type="number"
												   id="ante"
												   class="form-input"
												   min="1"
												   max="100"
											   value="@_anteInput"
											   @oninput="OnAnteInput" />
                                           <span class="form-hint">@(IsScrewYourNeighbor ? "Chips per stack (3 stacks)" : "Mandatory bet before each hand")</span>
										</div>
                                        @if (ShowMinimumBetInput)
										{
											<div class="form-group">
												<label class="form-label" for="minBet">Minimum Bet</label>
												<input type="number"
													   id="minBet"
													   class="form-input"
													   min="1"
													   max="1000"
												   value="@_minBetInput"
												   @oninput="OnMinimumBetInput" />
												<span class="form-hint">Minimum bet during play</span>
											</div>
										}
									</div>
								}
							}
							else
							{
							<div class="form-row">
								<div class="form-group">
									<span class="form-hint"><i class="fa-regular fa-info-circle"></i> The dealer will set the ante and minimum bet each hand.</span>
								</div>
							</div>
							<div class="form-row">
								<div class="form-group">
									<label class="form-label">Allowed Dealer's Choice Variants</label>
									<span class="form-hint">Choose which game variants the dealer may select at this table. At least one variant must remain enabled.</span>
									<div class="create-table-dealers-choice-selection-groups">
										@foreach (var group in DealerChoiceAllowedVariantGroups)
										{
											if (group.Cards.Count == 0)
											{
												continue;
											}

											<section class="create-table-dealers-choice-selection-group">
												<h3 class="create-table-dealers-choice-selection-group-title">@group.Title</h3>
												<div class="create-table-dealers-choice-selection-list">
													@foreach (var game in group.Cards)
													{
														var isAllowed = IsDealerChoiceGameAllowed(game.Code);
														<div class="create-table-dealers-choice-selection-item">
															<div class="create-table-dealers-choice-selection-copy">
																<span class="create-table-dealers-choice-selection-name">@game.Name</span>
																<span class="create-table-dealers-choice-selection-description">@game.Description</span>
															</div>
															<button class="game-info-odds-toggle-switch @(isAllowed ? "is-on" : "is-off")"
																	type="button"
																	role="switch"
																	aria-checked="@isAllowed"
																	aria-label="@($"Toggle {game.Name}")"
																	@onclick="() => ToggleAllowedDealerChoiceGame(game.Code)">
																<span class="game-info-odds-toggle-text">@(isAllowed ? "ON" : "OFF")</span>
																<span class="game-info-odds-toggle-thumb" aria-hidden="true"></span>
															</button>
														</div>
													}
												</div>
											</section>
										}
									</div>
								</div>
							</div>
							}

							<div class="form-row">
								<div class="form-group">
									<label class="form-label" for="areOddsVisibleToAllPlayers">Odds Visibility</label>
									<div class="create-table-odds-visibility-control">
										<button class="game-info-odds-toggle-switch @(_areOddsVisibleToAllPlayers ? "is-on" : "is-off")"
												type="button"
												id="areOddsVisibleToAllPlayers"
												role="switch"
												aria-checked="@_areOddsVisibleToAllPlayers"
												aria-label="Toggle odds visibility for everyone"
												@onclick="ToggleOddsVisibility">
											<span class="game-info-odds-toggle-text">@(_areOddsVisibleToAllPlayers ? "ON" : "OFF")</span>
											<span class="game-info-odds-toggle-thumb" aria-hidden="true"></span>
										</button>
										<span class="form-hint odds-visibility-hint">Allow all players to see hand-odds in the dashboard</span>
									</div>
								</div>
							</div>
						</div>
					</section>

					<!-- Create Button -->
					<div class="create-actions animate-fade-in-up animate-delay-2">
						@if (_createError is not null)
						{
							<div class="create-error-message">
								<i class="fa-regular fa-circle-exclamation"></i>
								@_createError
							</div>
						}
						<button class="btn btn-primary btn-lg create-table-btn"
								@onclick="CreateTableAsync"
								disabled="@(!CanCreate || _isCreating)">
							@if (_isCreating)
							{
								<span class="loading-spinner-small"></span>
								<span>Creating...</span>
							}
							else
							{
								<i class="fa-regular fa-check"></i>
								<span>Create Table</span>
							}
						</button>
						<p class="create-hint">After creating the table, go to Lobby and click Join to enter the game.</p>
					</div>
				}
			</div>
		}
	</div>
</main>

<style>
	.create-step .variant-card.selected-layout {
		display: grid;
		grid-column: 1 / -1;
		width: 100%;
		grid-template-columns: minmax(260px, 380px) minmax(0, 1fr);
		align-items: stretch;
		gap: 1rem;
		transition: grid-template-columns 460ms ease, transform 460ms ease, opacity 460ms ease;
	}

	.create-step .variants-grid.has-selection .variant-card {
		transition: transform 460ms ease, opacity 460ms ease, max-height 460ms ease, margin 460ms ease, padding 460ms ease;
		transform-origin: top center;
		opacity: 1;
		transform: translateY(0) scale(1);
		max-height: 42rem;
		will-change: transform, opacity, max-height;
	}

	.create-step .variants-grid.has-selection .variant-card.collapsing-out {
		opacity: 0;
		transform: scale(0.96) translateY(-6px);
		pointer-events: none;
		max-height: 0;
		padding-top: 0;
		padding-bottom: 0;
		margin: 0;
		overflow: hidden;
	}

	.create-step .variant-group.selection-hidden {
		display: none;
	}

	.create-step .variants-grid.has-selection .variant-card.collapsing-out {
		display: none;
	}

	.create-step .variant-group.selected-group {
		margin-top: 0.75rem;
	}

	.create-step .variant-card.selected-layout .variant-icon {
		width: 100%;
		margin: 0;
		height: 100%;
		min-height: 220px;
	}

	.create-step .variant-card.selected-layout .variant-icon-image,
	.create-step .variant-card.selected-layout .variant-icon-fallback {
		width: 100%;
		height: 100%;
		border-radius: 0.75rem;
	}

	.create-step .variant-card.selected-layout .variant-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-width: 0;
	}

	.create-step .variant-card.selected-layout .variant-content .variant-name {
		margin-top: 0;
		font-size: clamp(1.8rem, 2.6vw, 2.5rem);
		line-height: 1.15;
		margin-bottom: 0.75rem;
	}

	.create-table-dealers-choice-selection-groups {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 1rem;
	}

	.create-table-dealers-choice-selection-group {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1rem 1.25rem;
		border: 1px solid rgba(148, 163, 184, 0.18);
		border-radius: 0.9rem;
		background: rgba(15, 23, 42, 0.24);
	}

	.create-table-dealers-choice-selection-group-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 700;
	}

	.create-table-dealers-choice-selection-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.create-table-dealers-choice-selection-item {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 1rem;
		padding: 0.9rem 1rem;
		border-radius: 0.85rem;
		background: rgba(15, 23, 42, 0.38);
	}

	.create-table-dealers-choice-selection-item .game-info-odds-toggle-switch {
		flex-shrink: 0;
		min-width: 84px;
		justify-self: end;
	}

	.create-table-dealers-choice-selection-copy {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		min-width: 0;
	}

	.create-table-dealers-choice-selection-name {
		font-weight: 700;
		line-height: 1.2;
	}

	.create-table-dealers-choice-selection-description {
		color: rgba(226, 232, 240, 0.78);
		font-size: 0.92rem;
		line-height: 1.35;
	}

	@@media (max-width: 768px) {
		.create-step .variant-card.selected-layout {
			grid-template-columns: 1fr;
		}

		.create-step .variant-card.selected-layout .variant-icon {
			min-height: 190px;
		}

		.create-table-dealers-choice-selection-item {
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: start;
		}

		.create-table-dealers-choice-selection-item .game-info-odds-toggle-switch {
			margin-top: 0.1rem;
		}
	}
</style>

@code {
	private bool _isLoading = true;
	private bool _isCreating;
	private string? _loadError;
	private string? _createError;
	private string _tableName = "";
	private string _tableNameInput = "";
	private int _ante = 5;
	private string _anteInput = "5";
	private int _minBet = 10;
	private string _minBetInput = "10";
	private int _smallBlind = 1;
	private string _smallBlindInput = "1";
	private int _bigBlind = 2;
	private string _bigBlindInput = "2";
	private bool _areOddsVisibleToAllPlayers = true;
	private readonly HashSet<string> _allowedDealerChoiceGameCodes = new(StringComparer.OrdinalIgnoreCase);
	private string _variantSearch = string.Empty;
	private bool _isDealersChoice;
	private bool _hasBlinds;
	private bool _hasInitializedAllowedDealerChoiceGameCodes;
	private List<GetAvailablePokerGamesResponse> _availableGames = [];
	private GetAvailablePokerGamesResponse? _selectedVariant;
	private ElementReference _variantsSelectionRegion;
	private IJSObjectReference? _variantAnimationModule;
	private CancellationTokenSource? _canCreateDebounceCancellationTokenSource;
	private bool _playVariantFlipAfterRender;
	private const int FallbackSmallBlind = 1;
	private const int FallbackBigBlind = 2;
	private const int FallbackAnte = 5;
	private const int FallbackMinimumBet = 10;
	private const int CanCreateDebounceDelayMilliseconds = 400;

	private const string DealersChoiceCode = "DEALERSCHOICE";
 private const string ScrewYourNeighborCode = "SCREWYOURNEIGHBOR";
	private const string HoldEmVariantsTitle = "Hold 'Em variants";
	private const string DrawVariantsTitle = "Draw variants";
	private const string StudVariantsTitle = "Stud variants";
	private const string OtherVariantsTitle = "Other variants";

	private static readonly VariantCard DealersChoiceCard = new(
		Code: DealersChoiceCode,
		Name: "Dealer's Choice",
		Description: "The dealer picks the game variant each hand — a different game every deal!",
		MinimumNumberOfPlayers: 2,
		MaximumNumberOfPlayers: 8,
		ImageName: "",
		GroupTitle: OtherVariantsTitle,
		Source: null
	);

	private IEnumerable<VariantGroup> VariantCardGroups
	{
		get
		{
			var cards = _availableGames
					.Where(g => MatchesVariantSearch(g.Name)
						|| string.Equals(g.Code, _selectedVariant?.Code, StringComparison.OrdinalIgnoreCase))
					.OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase)
					.Select(ToVariantCard);

			return CreateVariantGroups(cards);
		}
	}

	private IEnumerable<VariantGroup> DealerChoiceAllowedVariantGroups =>
		CreateVariantGroups(
			_availableGames
				.OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase)
				.Select(ToVariantCard));

	private bool ShowDealersChoiceCard =>
		(_selectedVariant is null && MatchesVariantSearch(DealersChoiceCard.Name)) ||
		string.Equals(_selectedVariant?.Code, DealersChoiceCode, StringComparison.OrdinalIgnoreCase);

	private string GetVariantCardClasses(VariantCard game)
	{
		var classes = new List<string>();
		var isSelected = string.Equals(_selectedVariant?.Code, game.Code, StringComparison.OrdinalIgnoreCase);

		if (isSelected)
		{
			classes.Add("selected");
			classes.Add("selected-layout");
		}

		if (_selectedVariant is not null && !isSelected)
		{
			classes.Add("collapsing-out");
		}

		return string.Join(" ", classes);
	}

	private string GetVariantGroupClasses(VariantGroup group)
	{
		if (_selectedVariant is null)
		{
			return string.Empty;
		}

		var containsSelectedVariant = group.Cards.Any(card =>
			string.Equals(card.Code, _selectedVariant.Code, StringComparison.OrdinalIgnoreCase));

		return containsSelectedVariant ? "selected-group" : "selection-hidden";
	}

	private bool CanCreate =>
		_selectedVariant is not null &&
		!string.IsNullOrWhiteSpace(_tableName) &&
		(_isDealersChoice
			? _allowedDealerChoiceGameCodes.Count > 0
			: (_hasBlinds
				? (_smallBlind > 0 && _bigBlind >= _smallBlind)
				: (_ante > 0 && _minBet > 0)));

	private bool IsScrewYourNeighbor =>
       IsScrewYourNeighborCode(_selectedVariant?.Code);

	private bool ShowMinimumBetInput => !IsScrewYourNeighbor;

	private sealed record VariantCard(
		string Code,
		string Name,
		string Description,
		int MinimumNumberOfPlayers,
		int MaximumNumberOfPlayers,
		string? ImageName,
		string GroupTitle,
		GetAvailablePokerGamesResponse? Source
	);

	private sealed record VariantGroup(string Title, IReadOnlyList<VariantCard> Cards);

	protected override async Task OnInitializedAsync()
	{
		await Task.WhenAll(
			LoadAvailableGamesAsync(),
			LoadGamePreferenceDefaultsAsync());
	}

	private async Task LoadGamePreferenceDefaultsAsync()
	{
		try
		{
			var response = await ProfileApi.GetGamePreferencesAsync();
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				ApplyGamePreferenceDefaults(response.Content);
				return;
			}
		}
		catch
		{
			// Ignore errors and fall back to local defaults.
		}

		ApplyIntelligentFallbackDefaults();
	}

	private void ApplyGamePreferenceDefaults(GamePreferencesDto preferences)
	{
		_smallBlind = preferences.DefaultSmallBlind > 0 ? preferences.DefaultSmallBlind : FallbackSmallBlind;
		_bigBlind = preferences.DefaultBigBlind >= _smallBlind ? preferences.DefaultBigBlind : _smallBlind * 2;
		_ante = preferences.DefaultAnte > 0 ? preferences.DefaultAnte : FallbackAnte;
		_minBet = preferences.DefaultMinimumBet > 0 ? preferences.DefaultMinimumBet : Math.Max(FallbackMinimumBet, _bigBlind);
		SyncBufferedCanCreateInputs();
	}

	private void ApplyIntelligentFallbackDefaults()
	{
		_smallBlind = FallbackSmallBlind;
		_bigBlind = FallbackBigBlind;
		_ante = FallbackAnte;
		_minBet = FallbackMinimumBet;
		SyncBufferedCanCreateInputs();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_variantAnimationModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
				"import",
				"./Components/Pages/CreateTable.razor.js");
		}

		if (_playVariantFlipAfterRender && _variantAnimationModule is not null)
		{
			_playVariantFlipAfterRender = false;
			await _variantAnimationModule.InvokeVoidAsync("playVariantSelectionFlip", _variantsSelectionRegion);
		}
	}

	private async Task LoadAvailableGamesAsync()
	{
		_isLoading = true;
		_loadError = null;
		StateHasChanged();

		try
		{
			var response = await AvailableGamesApi.GetAvailablePokerGamesAsync(string.Empty);

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_availableGames = response.Content.ToList();
				EnsureAllowedDealerChoiceGameDefaults();
			}
			else
			{
				_loadError = "Unable to load available game variants. Please try again.";
			}
		}
		catch (Exception ex)
		{
			_loadError = $"An error occurred: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}

	private static VariantGroup CreateGroup(string title, IEnumerable<VariantCard> cards)
	{
		return new VariantGroup(title, cards.Where(c => c.GroupTitle == title).ToList());
	}

	private static IEnumerable<VariantGroup> CreateVariantGroups(IEnumerable<VariantCard> cards)
	{
		var materializedCards = cards.ToList();

		return new[]
		{
			CreateGroup(HoldEmVariantsTitle, materializedCards),
			CreateGroup(DrawVariantsTitle, materializedCards),
			CreateGroup(StudVariantsTitle, materializedCards),
			CreateGroup(OtherVariantsTitle, materializedCards)
		};
	}

	private static VariantCard ToVariantCard(GetAvailablePokerGamesResponse game)
	{
		var groupTitle = GetGroupTitle(game.VariantType);
		return new VariantCard(
			Code: game.Code,
			Name: game.Name,
			Description: game.Description,
			MinimumNumberOfPlayers: game.MinimumNumberOfPlayers,
			MaximumNumberOfPlayers: game.MaximumNumberOfPlayers,
			ImageName: game.ImageName,
			GroupTitle: groupTitle,
			Source: game
		);
	}

	private static string GetGroupTitle(VariantType variantType)
	{
		return variantType switch
		{
			VariantType.HoldEm => HoldEmVariantsTitle,
			VariantType.Draw => DrawVariantsTitle,
			VariantType.Stud => StudVariantsTitle,
			_ => OtherVariantsTitle
		};
	}

	private void EnsureAllowedDealerChoiceGameDefaults()
	{
		if (_hasInitializedAllowedDealerChoiceGameCodes)
		{
			return;
		}

		foreach (var gameCode in _availableGames.Select(game => game.Code))
		{
			_allowedDealerChoiceGameCodes.Add(gameCode);
		}

		_hasInitializedAllowedDealerChoiceGameCodes = _allowedDealerChoiceGameCodes.Count > 0;
	}

	private bool IsDealerChoiceGameAllowed(string gameCode)
	{
		return _allowedDealerChoiceGameCodes.Contains(gameCode);
	}

	private void ToggleAllowedDealerChoiceGame(string gameCode)
	{
		if (!_allowedDealerChoiceGameCodes.Add(gameCode))
		{
			_allowedDealerChoiceGameCodes.Remove(gameCode);
		}
	}

	private async Task SelectVariantAsync(VariantCard variant, bool isAvailable)
	{
		if (!isAvailable)
		{
			return;
		}

		if (_variantAnimationModule is not null)
		{
			await _variantAnimationModule.InvokeVoidAsync("captureVariantSelectionFlip", _variantsSelectionRegion);
		}

		if (_selectedVariant?.Code == variant.Code)
		{
			_selectedVariant = null;
			_isDealersChoice = false;
			_hasBlinds = false;
			_playVariantFlipAfterRender = true;
			return;
		}

		_selectedVariant = variant.Source ?? new GetAvailablePokerGamesResponse(
			code: DealersChoiceCode,
			description: variant.Description,
			imageName: variant.ImageName ?? string.Empty,
			maximumNumberOfPlayers: variant.MaximumNumberOfPlayers,
			minimumNumberOfPlayers: variant.MinimumNumberOfPlayers,
			name: variant.Name,
			variantType: VariantType.Other
		);
		_isDealersChoice = variant.Code == DealersChoiceCode;
       _hasBlinds = !_isDealersChoice
			&& !IsScrewYourNeighborCode(_selectedVariant.Code)
			&& _selectedVariant.VariantType == VariantType.HoldEm;

		if (_hasBlinds)
		{
			_minBet = _bigBlind;
		}

		SyncBufferedCanCreateInputs();

		_playVariantFlipAfterRender = true;
	}

	private async Task CreateTableAsync()
	{
		ApplyBufferedCanCreateInputs();

		if (!CanCreate || _selectedVariant is null)
		{
			return;
		}

		_isCreating = true;
		_createError = null;
		StateHasChanged();

		try
		{
			var gameId = Guid.CreateVersion7();
			var playerInfos = new List<PlayerInfo>();

			var ante = (_isDealersChoice || _hasBlinds) ? 0 : _ante;
			var minimumBet = _isDealersChoice ? 0 : (_hasBlinds ? _bigBlind : _minBet);

			var command = new CreateGameCommand(ante, _selectedVariant.Code, gameId, _tableName, minimumBet, playerInfos)
			{
				IsDealersChoice = _isDealersChoice,
				SmallBlind = _hasBlinds ? _smallBlind : null,
				BigBlind = _hasBlinds ? _bigBlind : null,
				AreOddsVisibleToAllPlayers = _areOddsVisibleToAllPlayers,
				AllowedDealerChoiceGameCodes = _isDealersChoice
					? _allowedDealerChoiceGameCodes.OrderBy(code => code, StringComparer.OrdinalIgnoreCase).ToArray()
					: null
			};

			// Call the appropriate API based on the selected variant
			Guid? createdGameId = null;
			var response = await GamesApi.CreateGameAsync(command);
			if (response.IsSuccessStatusCode && response.Content != Guid.Empty)
			{
				createdGameId = response.Content;
			}

			if (createdGameId.HasValue)
			{
				NavigationManager.NavigateTo("/lobby");
			}
			else
			{
				_createError = "Failed to create the table. Please check your settings and try again.";
			}
		}
		catch (Exception ex)
		{
			_createError = $"An error occurred: {ex.Message}";
		}
		finally
		{
			_isCreating = false;
			StateHasChanged();
		}
	}

	private async Task OnTableNameInput(ChangeEventArgs args)
	{
		_tableNameInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnSmallBlindInput(ChangeEventArgs args)
	{
		_smallBlindInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnBigBlindInput(ChangeEventArgs args)
	{
		_bigBlindInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnAnteInput(ChangeEventArgs args)
	{
		_anteInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task OnMinimumBetInput(ChangeEventArgs args)
	{
		_minBetInput = args.Value?.ToString() ?? string.Empty;
		await DebounceCanCreateUpdateAsync();
	}

	private async Task DebounceCanCreateUpdateAsync()
	{
		_canCreateDebounceCancellationTokenSource?.Cancel();
		_canCreateDebounceCancellationTokenSource?.Dispose();

		var cancellationTokenSource = new CancellationTokenSource();
		_canCreateDebounceCancellationTokenSource = cancellationTokenSource;

		try
		{
			await Task.Delay(CanCreateDebounceDelayMilliseconds, cancellationTokenSource.Token);
			ApplyBufferedCanCreateInputs();
			await InvokeAsync(StateHasChanged);
		}
		catch (OperationCanceledException)
		{
			// A newer keystroke restarted the debounce window.
		}
	}

	private void ApplyBufferedCanCreateInputs()
	{
		_tableName = _tableNameInput;
		_smallBlind = ParseBufferedInteger(_smallBlindInput);
		_bigBlind = ParseBufferedInteger(_bigBlindInput);
		_ante = ParseBufferedInteger(_anteInput);
		_minBet = ParseBufferedInteger(_minBetInput);
	}

	private void SyncBufferedCanCreateInputs()
	{
		_tableNameInput = _tableName;
		_smallBlindInput = _smallBlind.ToString();
		_bigBlindInput = _bigBlind.ToString();
		_anteInput = _ante.ToString();
		_minBetInput = _minBet.ToString();
	}

	private static int ParseBufferedInteger(string value)
	{
		return int.TryParse(value, out var parsedValue) ? parsedValue : 0;
	}

	private bool MatchesVariantSearch(string gameName)
	{
		return string.IsNullOrWhiteSpace(_variantSearch)
			|| gameName.Contains(_variantSearch, StringComparison.OrdinalIgnoreCase);
	}

	private static bool IsScrewYourNeighborCode(string? gameCode)
	{
		return string.Equals(gameCode, ScrewYourNeighborCode, StringComparison.OrdinalIgnoreCase);
	}

	private void ToggleOddsVisibility()
	{
		_areOddsVisibleToAllPlayers = !_areOddsVisibleToAllPlayers;
	}

	public async ValueTask DisposeAsync()
	{
		if (_variantAnimationModule is not null)
		{
			try
			{
				await _variantAnimationModule.DisposeAsync();
			}
			catch (JSDisconnectedException)
			{
				// Circuit disconnected, ignore.
			}
		}

		_canCreateDebounceCancellationTokenSource?.Cancel();
		_canCreateDebounceCancellationTokenSource?.Dispose();
	}
}
