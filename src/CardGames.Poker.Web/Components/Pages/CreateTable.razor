@code {
	private string _variantViewMode = "grid";
	private bool _isLoading = true;
	private bool _isCreating;
	private bool _isGeneratingTableName;
	private bool _isUpdatingFavoriteVariants;
	private string? _loadError;
	private string? _createError;
	private string? _favoriteVariantsError;
	private string _tableName = "";
	private string _tableNameInput = "";
	private int _ante = 5;
	private string _anteInput = "5";
	private int _minBet = 10;
	private string _minBetInput = "10";
	private int _smallBlind = 1;
	private string _smallBlindInput = "1";
	private int _bigBlind = 2;
	private string _bigBlindInput = "2";
	private int? _maxBuyIn;
	private string _maxBuyInInput = string.Empty;
	private bool _requiresJoinApproval;
	private bool _areOddsVisibleToAllPlayers = true;
	private bool _canManageFavoriteVariants = true;
	private readonly HashSet<string> _allowedDealerChoiceGameCodes = new(StringComparer.OrdinalIgnoreCase);
	private readonly HashSet<string> _favoriteVariantCodes = new(StringComparer.OrdinalIgnoreCase);
	private string _variantSearch = string.Empty;
	private bool _isDealersChoice;
	private bool _hasBlinds;
	private bool _hasInitializedAllowedDealerChoiceGameCodes;
	private List<GetAvailablePokerGamesResponse> _availableGames = [];
	private GetAvailablePokerGamesResponse? _selectedVariant;
	private ElementReference _variantsSelectionRegion;
	private IJSObjectReference? _variantAnimationModule;
	private CancellationTokenSource? _canCreateDebounceCancellationTokenSource;
	private bool _playVariantFlipAfterRender;
	private const int FallbackSmallBlind = 1;
	private const int FallbackBigBlind = 2;
	private const int FallbackAnte = 5;
	private const int FallbackMinimumBet = 10;
	private const int CanCreateDebounceDelayMilliseconds = 400;

	private const string VariantViewModeKey = "createTable.variantViewMode";
	private const string DealersChoiceCode = "DEALERSCHOICE";
	private const string ScrewYourNeighborCode = "SCREWYOURNEIGHBOR";
	private const string InBetweenCode = "INBETWEEN";
	private const string FavoriteVariantsTitle = "Favorites";
	private const string DealersChoiceGroupTitle = "Dealer's Choice";
	private const string HoldEmVariantsTitle = "Hold 'Em variants";
	private const string DrawVariantsTitle = "Draw variants";
	private const string StudVariantsTitle = "Stud variants";
	private const string OtherVariantsTitle = "Other variants";

	private static readonly VariantCard DealersChoiceCard = new(
		Code: DealersChoiceCode,
		Name: "Dealer's Choice",
		Description: "The dealer picks the game variant each hand — a different game every deal!",
		MinimumNumberOfPlayers: 2,
		MaximumNumberOfPlayers: 8,
		ImageName: "",
		GroupTitle: DealersChoiceGroupTitle,
		Source: null
	);

	private IEnumerable<VariantCard> FilteredVariantCards
	{
		get
		{
			return _availableGames
				.Select(ToVariantCard)
				.Append(DealersChoiceCard)
				.Where(card => MatchesVariantSearch(card.Name)
					|| string.Equals(card.Code, _selectedVariant?.Code, StringComparison.OrdinalIgnoreCase))
				.GroupBy(card => card.Code, StringComparer.OrdinalIgnoreCase)
				.Select(group => group.First())
				.OrderBy(card => card.Name, StringComparer.OrdinalIgnoreCase);
		}
	}

	private IEnumerable<VariantGroup> VariantCardGroups => CreateVariantGroups(FilteredVariantCards);

	private VariantGroup FavoriteVariantGroup => new(
		FavoriteVariantsTitle,
		FilteredVariantCards.Where(card => IsFavoriteVariant(card.Code)).ToList(),
		true);

	private IEnumerable<VariantGroup> DealerChoiceAllowedVariantGroups =>
		CreateVariantGroups(
			_availableGames
				.OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase)
				.Select(ToVariantCard));

	private string GetVariantCardClasses(VariantCard game)
	{
		var classes = new List<string>();
		var isSelected = string.Equals(_selectedVariant?.Code, game.Code, StringComparison.OrdinalIgnoreCase);

		if (isSelected)
		{
			classes.Add("selected");
			classes.Add("selected-layout");
		}

		if (_selectedVariant is not null && !isSelected)
		{
			classes.Add("collapsing-out");
		}

		return string.Join(" ", classes);
	}

	private string GetVariantGroupClasses(VariantGroup group)
	{
		if (_selectedVariant is null)
		{
			return string.Empty;
		}

		var containsSelectedVariant = group.Cards.Any(card =>
			string.Equals(card.Code, _selectedVariant.Code, StringComparison.OrdinalIgnoreCase));

		if (!containsSelectedVariant)
		{
			return "selection-hidden";
		}

		if (IsFavoriteVariant(_selectedVariant.Code) && !group.IsFavorites)
		{
			return "selection-hidden";
		}

		return "selected-group";
	}

	private bool CanCreate =>
		_selectedVariant is not null &&
		!string.IsNullOrWhiteSpace(_tableName) &&
		HasValidMaxBuyIn &&
		(_isDealersChoice
			? _allowedDealerChoiceGameCodes.Count > 0
			: (_hasBlinds
				? (_smallBlind > 0 && _bigBlind >= _smallBlind)
				: (_ante > 0 && (IsInBetween || IsScrewYourNeighbor || _minBet > 0))));

	private bool IsScrewYourNeighbor =>
	   IsScrewYourNeighborCode(_selectedVariant?.Code);

	private bool IsInBetween =>
		IsInBetweenCode(_selectedVariant?.Code);

	private bool ShowMinimumBetInput => !IsScrewYourNeighbor && !IsInBetween;

	private bool HasValidMaxBuyIn =>
		string.IsNullOrWhiteSpace(_maxBuyInInput)
		|| (_maxBuyIn.HasValue && _maxBuyIn.Value >= GetConfiguredMinimumBuyIn());

	private bool CanManageFavoriteVariants => _canManageFavoriteVariants && !_isUpdatingFavoriteVariants;

	private sealed record VariantCard(
		string Code,
		string Name,
		string Description,
		int MinimumNumberOfPlayers,
		int MaximumNumberOfPlayers,
		string? ImageName,
		string GroupTitle,
		GetAvailablePokerGamesResponse? Source
	);

	private sealed record VariantGroup(string Title, IReadOnlyList<VariantCard> Cards, bool IsFavorites = false);

	protected override async Task OnInitializedAsync()
	{
		await Task.WhenAll(
			LoadAvailableGamesAsync(),
			LoadGamePreferenceDefaultsAsync(),
			LoadFavoriteVariantsAsync());
	}

	private async Task LoadGamePreferenceDefaultsAsync()
	{
		try
		{
			var response = await ProfileApi.GetGamePreferencesAsync();
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				ApplyGamePreferenceDefaults(response.Content);
				return;
			}
		}
		catch
		{
			// Ignore errors and fall back to local defaults.
		}

		ApplyIntelligentFallbackDefaults();
	}

	private void ApplyGamePreferenceDefaults(GamePreferencesDto preferences)
	{
		_smallBlind = preferences.DefaultSmallBlind > 0 ? preferences.DefaultSmallBlind : FallbackSmallBlind;
		_bigBlind = preferences.DefaultBigBlind >= _smallBlind ? preferences.DefaultBigBlind : _smallBlind * 2;
		_ante = preferences.DefaultAnte > 0 ? preferences.DefaultAnte : FallbackAnte;
		_minBet = preferences.DefaultMinimumBet > 0 ? preferences.DefaultMinimumBet : Math.Max(FallbackMinimumBet, _bigBlind);
		SyncBufferedCanCreateInputs();
	}

	private void ApplyIntelligentFallbackDefaults()
	{
		_smallBlind = FallbackSmallBlind;
		_bigBlind = FallbackBigBlind;
		_ante = FallbackAnte;
		_minBet = FallbackMinimumBet;
		SyncBufferedCanCreateInputs();
	}

	private async Task LoadFavoriteVariantsAsync()
	{
		try
		{
			var response = await ProfileApi.GetFavoriteVariantsAsync();
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				ApplyFavoriteVariants(response.Content);
				_favoriteVariantsError = null;
				_canManageFavoriteVariants = true;
				return;
			}
		}
		catch
		{
			// Allow table creation to continue even if favorites are unavailable.
		}

		_favoriteVariantCodes.Clear();
		_canManageFavoriteVariants = false;
		_favoriteVariantsError = "Favorites are unavailable right now.";
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_variantAnimationModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
				"import",
				"./Components/Pages/CreateTable.razor.js");

			var stored = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", VariantViewModeKey);
			if (stored is "grid" or "list")
			{
				_variantViewMode = stored;
				StateHasChanged();
			}
		}

		if (_playVariantFlipAfterRender && _variantAnimationModule is not null)
		{
			_playVariantFlipAfterRender = false;
			await _variantAnimationModule.InvokeVoidAsync("playVariantSelectionFlip", _variantsSelectionRegion);
		}
	}

	private async Task LoadAvailableGamesAsync()
	{
		_isLoading = true;
		_loadError = null;
		StateHasChanged();

		try
		{
			var response = await AvailableGamesApi.GetAvailablePokerGamesAsync(string.Empty);

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_availableGames = response.Content.ToList();
				EnsureAllowedDealerChoiceGameDefaults();
			}
			else
			{
				_loadError = "Unable to load available game variants. Please try again.";
			}
		}
		catch (Exception ex)
		{
			_loadError = $"An error occurred: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}

	private static VariantGroup CreateGroup(string title, IEnumerable<VariantCard> cards)
	{
		return new VariantGroup(title, cards.Where(c => c.GroupTitle == title).ToList());
	}

	private static IEnumerable<VariantGroup> CreateVariantGroups(IEnumerable<VariantCard> cards)
	{
		var materializedCards = cards.ToList();

		return new[]
		{
			CreateGroup(DealersChoiceGroupTitle, materializedCards),
			CreateGroup(HoldEmVariantsTitle, materializedCards),
			CreateGroup(DrawVariantsTitle, materializedCards),
			CreateGroup(StudVariantsTitle, materializedCards),
			CreateGroup(OtherVariantsTitle, materializedCards)
		};
	}

	private static VariantCard ToVariantCard(GetAvailablePokerGamesResponse game)
	{
		var groupTitle = GetGroupTitle(game.VariantType);
		return new VariantCard(
			Code: game.Code,
			Name: game.Name,
			Description: game.Description,
			MinimumNumberOfPlayers: game.MinimumNumberOfPlayers,
			MaximumNumberOfPlayers: game.MaximumNumberOfPlayers,
			ImageName: game.ImageName,
			GroupTitle: groupTitle,
			Source: game
		);
	}

	private static string GetGroupTitle(VariantType variantType)
	{
		return variantType switch
		{
			VariantType.HoldEm => HoldEmVariantsTitle,
			VariantType.Draw => DrawVariantsTitle,
			VariantType.Stud => StudVariantsTitle,
			_ => OtherVariantsTitle
		};
	}

	private void EnsureAllowedDealerChoiceGameDefaults()
	{
		if (_hasInitializedAllowedDealerChoiceGameCodes)
		{
			return;
		}

		foreach (var gameCode in _availableGames.Select(game => game.Code))
		{
			_allowedDealerChoiceGameCodes.Add(gameCode);
		}

		_hasInitializedAllowedDealerChoiceGameCodes = _allowedDealerChoiceGameCodes.Count > 0;
	}

	private bool IsDealerChoiceGameAllowed(string gameCode)
	{
		return _allowedDealerChoiceGameCodes.Contains(gameCode);
	}

	private bool IsVariantAvailable(string gameCode)
	{
		return string.Equals(gameCode, DealersChoiceCode, StringComparison.OrdinalIgnoreCase)
			|| _availableGames.Any(game => string.Equals(game.Code, gameCode, StringComparison.OrdinalIgnoreCase));
	}

	private bool IsFavoriteVariant(string? gameCode)
	{
		return !string.IsNullOrWhiteSpace(gameCode)
			&& _favoriteVariantCodes.Contains(gameCode);
	}

	private string GetFavoriteButtonClasses(string gameCode, bool isListButton = false)
	{
		var classes = new List<string> { "variant-favorite-button" };

		if (IsFavoriteVariant(gameCode))
		{
			classes.Add("active");
		}

		if (isListButton)
		{
			classes.Add("variant-list-button");
		}

		return string.Join(" ", classes);
	}

	private string GetFavoriteButtonIconClasses(string gameCode)
	{
		return IsFavoriteVariant(gameCode) ? "fa-solid fa-star" : "fa-regular fa-star";
	}

	private string GetFavoriteButtonLabel(VariantCard game)
	{
		return IsFavoriteVariant(game.Code)
			? $"Remove {game.Name} from favorites"
			: $"Add {game.Name} to favorites";
	}

	private void ApplyFavoriteVariants(FavoriteVariantsDto favoriteVariants)
	{
		_favoriteVariantCodes.Clear();

		foreach (var gameCode in favoriteVariants.FavoriteVariantCodes.Select(NormalizeVariantCode).Where(code => !string.IsNullOrWhiteSpace(code)))
		{
			_favoriteVariantCodes.Add(gameCode);
		}
	}

	private async Task ToggleFavoriteVariantAsync(string gameCode)
	{
		if (!CanManageFavoriteVariants)
		{
			return;
		}

		var normalizedGameCode = NormalizeVariantCode(gameCode);
		if (string.IsNullOrWhiteSpace(normalizedGameCode))
		{
			return;
		}

		var wasFavorite = _favoriteVariantCodes.Contains(normalizedGameCode);
		if (wasFavorite)
		{
			_favoriteVariantCodes.Remove(normalizedGameCode);
		}
		else
		{
			_favoriteVariantCodes.Add(normalizedGameCode);
		}

		_isUpdatingFavoriteVariants = true;
		_favoriteVariantsError = null;
		StateHasChanged();

		try
		{
			var response = await ProfileApi.UpdateFavoriteVariantsAsync(new UpdateFavoriteVariantsRequest
			{
				FavoriteVariantCodes = _favoriteVariantCodes.OrderBy(code => code, StringComparer.OrdinalIgnoreCase).ToArray()
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				ApplyFavoriteVariants(response.Content);
				return;
			}

			throw new InvalidOperationException();
		}
		catch
		{
			if (wasFavorite)
			{
				_favoriteVariantCodes.Add(normalizedGameCode);
			}
			else
			{
				_favoriteVariantCodes.Remove(normalizedGameCode);
			}

			_favoriteVariantsError = "We couldn't update your favorites. Please try again.";
		}
		finally
		{
			_isUpdatingFavoriteVariants = false;
			StateHasChanged();
		}
	}

	private void ToggleAllowedDealerChoiceGame(string gameCode)
	{
		if (!_allowedDealerChoiceGameCodes.Add(gameCode))
		{
			_allowedDealerChoiceGameCodes.Remove(gameCode);
		}
	}

	private async Task SelectVariantAsync(VariantCard variant, bool isAvailable)
	{
		if (!isAvailable)
		{
			return;
		}

		if (_variantAnimationModule is not null)
		{
			await _variantAnimationModule.InvokeVoidAsync("captureVariantSelectionFlip", _variantsSelectionRegion);
		}

		if (_selectedVariant?.Code == variant.Code)
		{
			_selectedVariant = null;
			_isDealersChoice = false;
			_hasBlinds = false;
			_playVariantFlipAfterRender = true;
			return;
		}

		_selectedVariant = variant.Source ?? new GetAvailablePokerGamesResponse(
			code: DealersChoiceCode,
			description: variant.Description,
			imageName: variant.ImageName ?? string.Empty,
			maximumNumberOfPlayers: variant.MaximumNumberOfPlayers,
			minimumNumberOfPlayers: variant.MinimumNumberOfPlayers,
			name: variant.Name,
			variantType: VariantType.Other
		);
		_isDealersChoice = variant.Code == DealersChoiceCode;
		_hasBlinds = !_isDealersChoice
			 && !IsScrewYourNeighborCode(_selectedVariant.Code)
			 && _selectedVariant.VariantType == VariantType.HoldEm;

		if (_hasBlinds)
		{
			_minBet = _bigBlind;
		}

		SyncBufferedCanCreateInputs();

		_playVariantFlipAfterRender = true;
	}

	private async Task CreateTableAsync()
	{
		ApplyBufferedCanCreateInputs();

		if (!CanCreate || _selectedVariant is null)
		{
			return;
		}

		_isCreating = true;
		_createError = null;
		StateHasChanged();

		try
		{
			var gameId = Guid.CreateVersion7();
			var playerInfos = new List<PlayerInfo>();

			var ante = (_isDealersChoice || _hasBlinds) ? 0 : _ante;
			var minimumBet = _isDealersChoice ? 0 : (_hasBlinds ? _bigBlind : _minBet);

			var command = new CreateGameCommand(ante, _selectedVariant.Code, gameId, _tableName, minimumBet, playerInfos)
			{
				IsDealersChoice = _isDealersChoice,
				SmallBlind = _hasBlinds ? _smallBlind : null,
				BigBlind = _hasBlinds ? _bigBlind : null,
				MaxBuyIn = _maxBuyIn,
				RequiresJoinApproval = _requiresJoinApproval,
				AreOddsVisibleToAllPlayers = _areOddsVisibleToAllPlayers,
				AllowedDealerChoiceGameCodes = _isDealersChoice
					? _allowedDealerChoiceGameCodes.OrderBy(code => code, StringComparer.OrdinalIgnoreCase).ToArray()
					: null
			};

			// Call the appropriate API based on the selected variant
			Guid? createdGameId = null;
			var response = await GamesApi.CreateGameAsync(command);
			if (response.IsSuccessStatusCode && response.Content != Guid.Empty)
			{
				createdGameId = response.Content;
			}

			if (createdGameId.HasValue)
			{
				NavigationManager.NavigateTo("/lobby");
			}
			else
			{
				_createError = "Failed to create the table. Please check your settings and try again.";
			}
		}
		catch (Exception ex)
		{
			_createError = $"An error occurred: {ex.Message}";
		}
		finally
		{
			_isCreating = false;
			StateHasChanged();
		}
	}

	private async Task GenerateTableNameAsync()
	{
		if (_selectedVariant is null || _isGeneratingTableName)
		{
			return;
		}

		_isGeneratingTableName = true;
		_createError = null;
		StateHasChanged();

		try
		{
			var response = await GamesApi.GenericGetGeneratedTableNameAsync(_selectedVariant.Name);

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				var generatedName = response.Content.Name?.Trim() ?? string.Empty;

				if (generatedName.Length > 50)
				{
					generatedName = generatedName[..50];
				}

				_tableName = generatedName;
				_tableNameInput = generatedName;
				return;
			}

			_createError = "Failed to generate a table name. Please try again.";
		}
		catch (Exception ex)
		{
			_createError = $"An error occurred while generating a table name: {ex.Message}";
		}
		finally
		{
			_isGeneratingTableName = false;
			StateHasChanged();
		}
	}

