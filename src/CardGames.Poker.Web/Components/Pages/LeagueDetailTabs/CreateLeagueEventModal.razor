@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Utilities
@using Refit
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@if (Show)
{
	<div class="confirm-dialog-overlay">
		<div class="confirm-dialog league-form-modal one-off-event-modal create-league-event-modal" @onclick:stopPropagation>
			<div class="confirm-dialog-header league-form-modal-header">
				<div class="league-form-modal-title-group">
					<h3 class="confirm-dialog-title mb-0">@ModalTitle</h3>
					<p class="confirm-dialog-message league-form-modal-subtitle mb-0">@ModalSubtitle</p>
				</div>
				<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="Close">
					<i class="fa-solid fa-xmark" aria-hidden="true"></i>
				</button>
			</div>
			<div class="confirm-dialog-body league-form-modal-body text-start">
				@if (!string.IsNullOrWhiteSpace(_errorMessage))
				{
					<div class="alert alert-danger py-2 mb-2" role="alert">@_errorMessage</div>
				}
				<div class="form-floating" data-label="Table name">
					<InputText id="one-off-name" class="form-control league-modal-input" @bind-Value="_name" maxlength="120" placeholder="Table name" />
				</div>
				<div class="league-form-inline-fields league-form-inline-fields-schedule">
					<div class="league-form-inline-field league-form-inline-field-scheduled-date">
						<label class="form-label small" for="one-off-scheduled-date">Scheduled date</label>
						<InputDate id="one-off-scheduled-date" class="form-control league-modal-date-input" @bind-Value="_scheduledDate" />
					</div>
					<div class="league-form-inline-field league-form-inline-field-scheduled-time">
						<label class="form-label small" for="one-off-scheduled-time">Start time</label>
						<input id="one-off-scheduled-time" type="time" class="form-control league-modal-input league-modal-date-input" value="@_scheduledTime" @onchange="OnScheduledTimeChanged" />
					</div>
					<div class="league-form-inline-field league-form-inline-field-time-zone">
						<label class="form-label small" for="one-off-time-zone">Time zone</label>
						<InputSelect id="one-off-time-zone" class="form-select league-modal-input league-modal-date-input" @bind-Value="_selectedTimeZoneId" @bind-Value:after="OnTimeZoneSelectionChanged">
							@foreach (var timeZone in TimeZoneOptions)
							{
								<option value="@timeZone.Id">@timeZone.DisplayName</option>
							}
						</InputSelect>
					</div>
				</div>
				<div class="form-floating" data-label="Game Variant">
					@if (_isLoadingGames)
					{
						<p class="text-muted small">Loading game variants...</p>
					}
					else
					{
						<InputSelect id="one-off-game-type" class="form-control league-modal-input" @bind-Value="_gameTypeCode">
							<option value="">-- Select a game --</option>
							@foreach (var game in _availableGames)
							{
								<option value="@game.Code">@game.Name</option>
							}
						</InputSelect>
					}
				</div>
				<div class="league-form-inline-fields league-form-inline-fields-bets">
					<div class="league-form-inline-field">
						<div class="form-floating" data-label="Ante">
							<InputNumber id="one-off-ante" class="form-control league-modal-input" @bind-Value="_ante" min="1" max="100" />
						</div>
					</div>
					<div class="league-form-inline-field">
						<div class="form-floating" data-label="Minimum Bet">
							<InputNumber id="one-off-min-bet" class="form-control league-modal-input" @bind-Value="_minBet" min="1" max="1000" />
						</div>
					</div>
				</div>
				<div class="form-floating" data-label="Notes (optional)">
					<InputText id="one-off-notes" class="form-control league-modal-input" @bind-Value="_notes" maxlength="512" placeholder="Notes (optional)" />
				</div>
				<div class="league-form-modal-actions">
					<button type="button" class="btn btn-sm btn-secondary league-action-btn" @onclick="Close" disabled="@_isSubmitting">Cancel</button>
					<button class="btn btn-sm btn-primary league-action-btn" @onclick="SaveAsync" disabled="@_isSubmitting">@SubmitLabel</button>
				</div>
			</div>
		</div>
	</div>
}

@code {
	[Parameter, EditorRequired]
	public bool Show { get; set; }

	[Parameter, EditorRequired]
	public LeagueOneOffEventType EventType { get; set; }

	[Parameter, EditorRequired]
	public Guid LeagueId { get; set; }

	[Parameter]
	public LeagueOneOffEventDto? EditingEvent { get; set; }

	[Parameter]
	public string BrowserTimeZoneId { get; set; } = "UTC";

	[Parameter]
	public IReadOnlyList<BrowserTimeZoneOption> AvailableTimeZones { get; set; } = [];

	[Parameter]
	public EventCallback OnClose { get; set; }

	[Parameter]
	public EventCallback OnSaved { get; set; }

	[Inject]
	private ILeaguesApi LeaguesApi { get; set; } = default!;

	[Inject]
	private IAvailablePokerGamesApi AvailableGamesApi { get; set; } = default!;

	[Inject]
	private ILogger<CreateLeagueEventModal> Logger { get; set; } = default!;

	private string _name = string.Empty;
	private DateTime? _scheduledDate = DateTime.UtcNow.Date.AddDays(1);
	private string _scheduledTime = LeagueTimeZoneHelper.DefaultTimeText;
	private string _selectedTimeZoneId = "UTC";
	private string? _notes;
	private string _gameTypeCode = string.Empty;
	private int _ante = 5;
	private int _minBet = 10;
	private bool _isSubmitting;
	private string? _errorMessage;
	private bool _isLoadingGames;
	private List<GetAvailablePokerGamesResponse> _availableGames = [];
	private bool _gamesLoaded;
	private string? _initializedContextKey;
	private string? _autoSelectedTimeZoneId;
	private const string TimeZoneModulePath = "/Components/Pages/LeagueDetail.razor.js";
	private IJSObjectReference? _timeZoneModule;
	private string? _resolvedBrowserTimeZoneId;
	private List<BrowserTimeZoneOption> _resolvedTimeZones = [];

	private bool IsEditMode => EditingEvent is not null;

	private string EffectiveBrowserTimeZoneId => string.IsNullOrWhiteSpace(_resolvedBrowserTimeZoneId)
		? BrowserTimeZoneId
		: _resolvedBrowserTimeZoneId;

	private IReadOnlyList<BrowserTimeZoneOption> TimeZoneOptions => _resolvedTimeZones.Count > 0
		? _resolvedTimeZones
		: AvailableTimeZones.Count > 0
			? AvailableTimeZones
			: [new BrowserTimeZoneOption(EffectiveBrowserTimeZoneId, EffectiveBrowserTimeZoneId)];

	private string ModalTitle => IsEditMode
		? EventType == LeagueOneOffEventType.Tournament
			? "Edit Tournament"
			: "Edit Cash Game"
		: EventType == LeagueOneOffEventType.Tournament
		? "Create Tournament"
		: "Create Cash Game";

	private string ModalSubtitle => IsEditMode
		? "Update the event details before players join the table."
		: EventType == LeagueOneOffEventType.Tournament
		? "Every player starts with the same buy-in, there are no late entries or rebuys, and play continues until one winner remains."
		: "Players can join or leave freely, choose their own buy-in amount, and rebuy as needed, so the game has no fixed ending.";

	private string SubmitLabel => IsEditMode ? "Save Changes" : ModalTitle;

	protected override async Task OnParametersSetAsync()
	{
		if (Show && !_gamesLoaded)
		{
			await LoadAvailableGamesAsync();
		}

		if (!Show)
		{
			_initializedContextKey = null;
			_autoSelectedTimeZoneId = null;
			return;
		}

		await EnsureBrowserTimeZoneSetupAsync();

		var contextKey = EditingEvent?.EventId.ToString() ?? "__create__";
		if (!string.Equals(_initializedContextKey, contextKey, StringComparison.Ordinal))
		{
			InitializeForm();
			_initializedContextKey = contextKey;
		}

		SynchronizeDefaultTimeZone();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!Show || (_resolvedTimeZones.Count > 0 && !string.IsNullOrWhiteSpace(_resolvedBrowserTimeZoneId)))
		{
			return;
		}

		await EnsureBrowserTimeZoneSetupAsync();

		if (!string.IsNullOrWhiteSpace(_resolvedBrowserTimeZoneId))
		{
			SynchronizeDefaultTimeZone();
			StateHasChanged();
		}
	}

	private async Task LoadAvailableGamesAsync()
	{
		_isLoadingGames = true;
		try
		{
			var response = await AvailableGamesApi.GetAvailablePokerGamesAsync(string.Empty);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_availableGames = response.Content.ToList();
				_gamesLoaded = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to load available poker games");
		}
		finally
		{
			_isLoadingGames = false;
		}
	}

	private async Task Close()
	{
		if (_isSubmitting) return;
		ResetForm();
		_initializedContextKey = null;
		await OnClose.InvokeAsync();
	}

	private async Task SaveAsync()
	{
		_errorMessage = null;

		if (string.IsNullOrWhiteSpace(_name))
		{
			_errorMessage = "Table name is required.";
			return;
		}

		if (string.IsNullOrWhiteSpace(_gameTypeCode))
		{
			_errorMessage = "Please select a game variant.";
			return;
		}

		if (!LeagueTimeZoneHelper.TryConvertLocalToUtc(_scheduledDate, _scheduledTime, _selectedTimeZoneId, out var scheduledAtUtc, out var errorMessage))
		{
			_errorMessage = errorMessage;
			return;
		}

		_isSubmitting = true;
		try
		{
			IApiResponse response;
			if (EditingEvent is null)
			{
				response = await LeaguesApi.CreateOneOffEventAsync(LeagueId, new CreateLeagueOneOffEventRequest
				{
					Name = _name.Trim(),
					ScheduledAtUtc = scheduledAtUtc,
					EventType = EventType,
					Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim(),
					GameTypeCode = _gameTypeCode,
					Ante = _ante,
					MinBet = _minBet
				});
			}
			else
			{
				response = await LeaguesApi.UpdateOneOffEventAsync(LeagueId, EditingEvent.EventId, new UpdateLeagueOneOffEventRequest
				{
					Name = _name.Trim(),
					ScheduledAtUtc = scheduledAtUtc,
					EventType = EventType,
					Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim(),
					GameTypeCode = _gameTypeCode,
					Ante = _ante,
					MinBet = _minBet
				});
			}

			if (response.IsSuccessStatusCode)
			{
				ResetForm();
				_initializedContextKey = null;
				await OnSaved.InvokeAsync();
			}
			else
			{
				_errorMessage = IsEditMode ? "Failed to update event. Please try again." : "Failed to create event. Please try again.";
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to save one-off event for league {LeagueId}", LeagueId);
			_errorMessage = IsEditMode ? "Failed to update event. Please try again." : "Failed to create event. Please try again.";
		}
		finally
		{
			_isSubmitting = false;
		}
	}

	private void InitializeForm()
	{
		if (EditingEvent is null)
		{
			ResetForm();
			return;
		}

		_name = EditingEvent.Name;
		_scheduledDate = LeagueTimeZoneHelper.ConvertUtcToLocalDate(EditingEvent.ScheduledAtUtc, EffectiveBrowserTimeZoneId);
		_scheduledTime = LeagueTimeZoneHelper.ConvertUtcToTimeText(EditingEvent.ScheduledAtUtc, EffectiveBrowserTimeZoneId);
		_selectedTimeZoneId = EffectiveBrowserTimeZoneId;
		_autoSelectedTimeZoneId = null;
		_notes = EditingEvent.Notes;
		_gameTypeCode = EditingEvent.GameTypeCode ?? string.Empty;
		_ante = EditingEvent.Ante;
		_minBet = EditingEvent.MinBet;
		_errorMessage = null;
	}

	private void ResetForm()
	{
		_name = string.Empty;
		_scheduledDate = LeagueTimeZoneHelper.GetNextLocalEventDate(EffectiveBrowserTimeZoneId);
		_scheduledTime = LeagueTimeZoneHelper.DefaultTimeText;
		_selectedTimeZoneId = EffectiveBrowserTimeZoneId;
		_autoSelectedTimeZoneId = EffectiveBrowserTimeZoneId;
		_notes = null;
		_gameTypeCode = string.Empty;
		_ante = 5;
		_minBet = 10;
		_errorMessage = null;
	}

	private void OnScheduledTimeChanged(ChangeEventArgs args)
	{
		_scheduledTime = args.Value?.ToString() ?? string.Empty;
	}

	private void OnTimeZoneSelectionChanged()
	{
		_autoSelectedTimeZoneId = null;
	}

	private void SynchronizeDefaultTimeZone()
	{
		if (EditingEvent is not null || string.IsNullOrWhiteSpace(EffectiveBrowserTimeZoneId))
		{
			return;
		}

		if (string.Equals(_selectedTimeZoneId, EffectiveBrowserTimeZoneId, StringComparison.Ordinal))
		{
			_autoSelectedTimeZoneId = EffectiveBrowserTimeZoneId;
			return;
		}

		if (string.IsNullOrWhiteSpace(_selectedTimeZoneId)
			|| string.Equals(_selectedTimeZoneId, "UTC", StringComparison.Ordinal)
			|| string.Equals(_selectedTimeZoneId, _autoSelectedTimeZoneId, StringComparison.Ordinal))
		{
			_selectedTimeZoneId = EffectiveBrowserTimeZoneId;
			_autoSelectedTimeZoneId = EffectiveBrowserTimeZoneId;
		}
	}

	private async Task EnsureBrowserTimeZoneSetupAsync()
	{
		if (_resolvedTimeZones.Count > 0 && !string.IsNullOrWhiteSpace(_resolvedBrowserTimeZoneId))
		{
			return;
		}

		if (!string.Equals(BrowserTimeZoneId, "UTC", StringComparison.Ordinal) && AvailableTimeZones.Count > 1)
		{
			_resolvedBrowserTimeZoneId = BrowserTimeZoneId;
			_resolvedTimeZones = AvailableTimeZones.ToList();
			return;
		}

		try
		{
			_timeZoneModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", TimeZoneModulePath);
			var setup = await _timeZoneModule.InvokeAsync<BrowserTimeZoneSetup>("getTimeZoneSetup");
			_resolvedBrowserTimeZoneId = string.IsNullOrWhiteSpace(setup.BrowserTimeZoneId) ? BrowserTimeZoneId : setup.BrowserTimeZoneId;
			_resolvedTimeZones = setup.TimeZones
				.Where(option => !string.IsNullOrWhiteSpace(option.Id))
				.DistinctBy(option => option.Id)
				.ToList();
		}
		catch (InvalidOperationException)
		{
			// Ignore JS interop errors during SSR.
		}
		catch (JSDisconnectedException)
		{
			// Ignore circuit disconnects during teardown.
		}
		catch (JSException ex)
		{
			Logger.LogDebug(ex, "Failed resolving browser time zone in one-off event modal for league {LeagueId}", LeagueId);
		}
	}

	public async ValueTask DisposeAsync()
	{
		if (_timeZoneModule is not null)
		{
			try
			{
				await _timeZoneModule.DisposeAsync();
			}
			catch (JSDisconnectedException)
			{
				// Ignore circuit disconnects during teardown.
			}
		}
	}
}
