@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Utilities

<div class="league-detail-tab-content">
	<div class="league-schedule-tabs" role="tablist" aria-label="Schedule sections">
		<button type="button"
				class="league-schedule-tab @(IsSeasonsTabActive ? "league-schedule-tab-active" : string.Empty)"
				role="tab"
				aria-selected="@IsSeasonsTabActive"
				@onclick="ShowSeasonsTab">
			<i class="fa-solid fa-layer-group"></i> Seasons
		</button>
		<button type="button"
				class="league-schedule-tab @(!IsSeasonsTabActive ? "league-schedule-tab-active" : string.Empty)"
				role="tab"
				aria-selected="@(!IsSeasonsTabActive)"
				@onclick="ShowOneOffEventsTab">
			<i class="fa-solid fa-sparkles"></i> One-Off Events
		</button>
	</div>

	@if (IsSeasonsTabActive)
	{
		<section class="league-detail-card">
			<div class="league-detail-card-header">
				<h3><i class="fa-solid fa-layer-group"></i> Seasons</h3>
				@if (CanManageLeague)
				{
					<button class="league-detail-btn league-detail-btn-create" @onclick="OpenSeasonModal">
						<i class="fa-solid fa-plus"></i> Create Season
					</button>
				}
			</div>
			@if (Seasons.Count == 0)
			{
				<p class="league-detail-empty">No seasons yet.</p>
			}
			else
			{
				<div class="league-detail-event-list">
					@foreach (var season in Seasons)
					{
						<div class="league-detail-event-row league-detail-season-row @(season.SeasonId == SelectedSeasonId ? "league-detail-season-selected" : "")" @onclick="() => ToggleSeasonAsync(season.SeasonId)">
							<div class="league-detail-event-info">
								<span class="league-detail-event-name">@season.Name</span>
								<span class="league-detail-event-date">@season.Status &bull; @(season.PlannedEventCount?.ToString() ?? "-") planned &bull; @FormatDate(season.StartsAtUtc) - @FormatDate(season.EndsAtUtc)</span>
							</div>
							<div class="league-detail-event-row-actions">
								@if (season.SeasonId == SelectedSeasonId && CanManageLeague)
								{
									<button class="btn btn-sm btn-outline-success league-action-btn" @onclick="OpenSeasonEventModal" @onclick:stopPropagation="true">
											<i class="fa-thin fa-calendar-circle-plus"></i> Create Event
									</button>
								}
							</div>
						</div>
						@if (season.SeasonId == SelectedSeasonId)
						{
							<div class="league-season-events-inline">
								@if (SeasonEvents.Count == 0)
								{
									<p class="league-detail-empty">No season events yet.</p>
								}
								else
								{
									<div class="league-detail-event-list">
										@foreach (var seasonEvent in SeasonEvents)
										{
											<div class="league-detail-event-row">
												<div class="league-detail-event-info">
													<span class="league-detail-event-name">@seasonEvent.Name</span>
													<span class="league-detail-event-date">Seq: @(seasonEvent.SequenceNumber?.ToString() ?? "-") &bull; @FormatDate(seasonEvent.ScheduledAtUtc) &bull; @seasonEvent.Status</span>
												</div>
												<div class="league-detail-event-row-actions">
													@if (CanManageLeague && CanEditSeasonEvent(seasonEvent))
													{
														<button class="btn btn-sm btn-outline-secondary league-action-btn" @onclick="() => EditSeasonEvent.InvokeAsync(seasonEvent)" @onclick:stopPropagation="true">
															<i class="fa-solid fa-pen-to-square"></i> Edit
														</button>
														<button class="btn btn-sm btn-outline-danger league-action-btn" @onclick="() => DeleteSeasonEvent.InvokeAsync(seasonEvent)" @onclick:stopPropagation="true" title="Delete season event">
															<i class="fa-regular fa-trash"></i>
														</button>
													}
													@if (seasonEvent.LaunchedGameId.HasValue)
													{
														<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => OpenTable.InvokeAsync(seasonEvent.LaunchedGameId.Value)">Open Table</button>
													}
													else if (CanManageLeague && IsLaunchWindowOpen(seasonEvent.ScheduledAtUtc))
													{
														<button class="btn btn-sm btn-primary league-action-btn" @onclick="() => LaunchSeasonEvent.InvokeAsync(seasonEvent.EventId)" disabled="@(LaunchingSeasonEventId == seasonEvent.EventId)">Launch Play</button>
													}
												</div>
											</div>
										}
									</div>
								}
							</div>
						}
					}
				</div>
			}
		</section>
	}
	else
	{
		<section class="league-detail-card">
			<div class="league-detail-card-header">
				<h3><i class="fa-solid fa-sparkles"></i> One-Off Events</h3>
				@if (CanManageLeague)
				{
					<button class="league-detail-btn league-detail-btn-create" @onclick="OpenOneOffModal">
						<i class="fa-solid fa-plus"></i> Create Event
					</button>
				}
			</div>
			@if (OneOffEvents.Count == 0)
			{
				<p class="league-detail-empty">No one-off events yet.</p>
			}
			else
			{
				<div class="league-detail-event-list">
					@foreach (var oneOff in OneOffEvents)
					{
						<div class="league-detail-event-row">
							<div class="league-detail-event-info">
								<span class="league-detail-event-name">@oneOff.Name</span>
								<span class="league-detail-event-date">@oneOff.EventType &bull; @FormatDate(oneOff.ScheduledAtUtc) &bull; @oneOff.Status</span>
							</div>
							<div class="league-detail-event-row-actions">
								@if (CanManageLeague && CanEditOneOffEvent(oneOff))
								{
									<button class="btn btn-sm btn-outline-secondary league-action-btn" @onclick="() => EditOneOffEvent.InvokeAsync(oneOff)">
										<i class="fa-solid fa-pen-to-square"></i> Edit
									</button>
									<button class="btn btn-sm btn-outline-danger league-action-btn" @onclick="() => DeleteOneOffEvent.InvokeAsync(oneOff)" title="Delete one-off event">
										<i class="fa-regular fa-trash"></i>
									</button>
								}
								@if (oneOff.LaunchedGameId.HasValue)
								{
									<button class="btn btn-sm btn-outline-primary league-action-btn" @onclick="() => OpenTable.InvokeAsync(oneOff.LaunchedGameId.Value)">Open Table</button>
								}
								else if (CanManageLeague && IsLaunchWindowOpen(oneOff.ScheduledAtUtc))
								{
									<button class="btn btn-sm btn-primary league-action-btn" @onclick="() => LaunchOneOffEvent.InvokeAsync(oneOff.EventId)" disabled="@(LaunchingOneOffEventId == oneOff.EventId)">Launch Play</button>
								}
							</div>
						</div>
					}
				</div>
			}
		</section>
	}
</div>

@code {
	[Parameter]
	public bool IsSeasonsTabActive { get; set; }

	[Parameter]
	public EventCallback ShowSeasonsTab { get; set; }

	[Parameter]
	public EventCallback ShowOneOffEventsTab { get; set; }

	[Parameter]
	public bool CanManageLeague { get; set; }

	[Parameter, EditorRequired]
	public List<LeagueSeasonDto> Seasons { get; set; } = [];

	[Parameter]
	public Guid? SelectedSeasonId { get; set; }

	[Parameter, EditorRequired]
	public List<LeagueSeasonEventDto> SeasonEvents { get; set; } = [];

	[Parameter, EditorRequired]
	public List<LeagueOneOffEventDto> OneOffEvents { get; set; } = [];

	[Parameter]
	public Guid? LaunchingSeasonEventId { get; set; }

	[Parameter]
	public Guid? LaunchingOneOffEventId { get; set; }

	[Parameter]
	public string BrowserTimeZoneId { get; set; } = "UTC";

	[Parameter]
	public EventCallback OpenSeasonModal { get; set; }

	[Parameter]
	public EventCallback<Guid> SelectSeason { get; set; }

	[Parameter]
	public EventCallback OpenSeasonEventModal { get; set; }

	[Parameter]
	public EventCallback<LeagueSeasonEventDto> EditSeasonEvent { get; set; }

	[Parameter]
	public EventCallback<LeagueSeasonEventDto> DeleteSeasonEvent { get; set; }

	[Parameter]
	public EventCallback<Guid> OpenTable { get; set; }

	[Parameter]
	public EventCallback<Guid> LaunchSeasonEvent { get; set; }

	[Parameter]
	public EventCallback OpenOneOffModal { get; set; }

	[Parameter]
	public EventCallback<LeagueOneOffEventDto> EditOneOffEvent { get; set; }

	[Parameter]
	public EventCallback<LeagueOneOffEventDto> DeleteOneOffEvent { get; set; }

	[Parameter]
	public EventCallback<Guid> LaunchOneOffEvent { get; set; }

	[Parameter]
	public EventCallback DeselectSeason { get; set; }

	private Task ToggleSeasonAsync(Guid seasonId)
	{
		if (seasonId == SelectedSeasonId)
			return DeselectSeason.InvokeAsync();
		return SelectSeason.InvokeAsync(seasonId);
	}

	private string FormatDate(DateTimeOffset? value)
	{
		return LeagueTimeZoneHelper.FormatDateTime(value, BrowserTimeZoneId);
	}

	private static bool IsLaunchWindowOpen(DateTimeOffset? scheduledAtUtc)
	{
		if (!scheduledAtUtc.HasValue)
			return false;

		return DateTimeOffset.UtcNow >= scheduledAtUtc.Value.AddHours(-2);
	}

	private static bool CanEditSeasonEvent(LeagueSeasonEventDto seasonEvent)
	{
		return seasonEvent.Status == LeagueSeasonEventStatus.Planned && !seasonEvent.LaunchedGameId.HasValue;
	}

	private static bool CanEditOneOffEvent(LeagueOneOffEventDto oneOffEvent)
	{
		return oneOffEvent.Status == LeagueOneOffEventStatus.Planned && !oneOffEvent.LaunchedGameId.HasValue;
	}
}
