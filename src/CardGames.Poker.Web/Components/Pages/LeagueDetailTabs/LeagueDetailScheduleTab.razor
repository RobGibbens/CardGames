@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Utilities
@inject NavigationManager NavigationManager

<div class="league-detail-tab-content">
	<section class="league-detail-card">
		<div class="league-detail-card-header">
			<h3><i class="fa-solid fa-layer-group"></i> Seasons</h3>
			@if (CanManageLeague)
			{
				<button class="league-detail-btn league-detail-btn-create" @onclick="OpenSeasonModal">
					<i class="fa-solid fa-plus"></i> Create Season
				</button>
			}
		</div>
		@if (Seasons.Count == 0)
		{
			<p class="league-detail-empty">No seasons yet.</p>
		}
		else
		{
			<div class="league-detail-event-list">
				@foreach (var season in Seasons)
				{
					<div class="league-detail-event-row league-detail-season-row @(season.SeasonId == SelectedSeasonId ? "league-detail-season-selected" : string.Empty)" @onclick="() => OpenSeasonDetail(season.SeasonId)">
						<div class="league-detail-event-info">
							<span class="league-detail-event-name">@season.Name</span>
							<span class="league-detail-event-date">@season.Status &bull; @(season.PlannedEventCount?.ToString() ?? "-") planned &bull; @FormatDate(season.StartsAtUtc) - @FormatDate(season.EndsAtUtc)</span>
						</div>
						<div class="league-detail-season-link-hint" aria-hidden="true">
							<span>View Season</span>
							<i class="fa-solid fa-chevron-right"></i>
						</div>
					</div>
				}
			</div>

			<p class="league-detail-empty mt-3">Select a season to open its schedule, results, and standings.</p>
		}
	</section>

	<section class="league-detail-card">
		<div class="league-detail-card-header">
			<h3><i class="fa-solid fa-sparkles"></i> One-Off Events</h3>
			@if (CanManageLeague)
			{
				<button class="league-detail-btn league-detail-btn-create" @onclick="OpenOneOffModal">
					<i class="fa-solid fa-plus"></i> Create Event
				</button>
			}
		</div>
		@if (IsLoadingOneOffEventsPage && OneOffEventsPage.TotalCount == 0)
		{
			<p class="league-detail-empty">Loading one-off events...</p>
		}
		else if (OneOffEventsPage.TotalCount == 0)
		{
			<p class="league-detail-empty">No one-off events yet.</p>
		}
		else
		{
			<div class="league-detail-active-games-list">
				@foreach (var oneOff in OneOffEventsPage.Entries)
				{
					<div class="league-detail-active-game-card league-event-oneoff">
						<div class="league-detail-active-game-top">
							<div class="league-detail-active-game-info">
								<span class="league-detail-active-game-name">@oneOff.Name</span>
								<div class="league-detail-active-game-meta">
									<span class="league-detail-active-game-meta-item">
										<i class="fa-solid @(oneOff.EventType == LeagueOneOffEventType.Tournament ? "fa-ranking-star" : "fa-dice") league-event-type-icon-oneoff"></i> @FormatOneOffEventType(oneOff.EventType)
									</span>
									@if (!string.IsNullOrWhiteSpace(oneOff.GameTypeName))
									{
										<span class="league-detail-active-game-meta-item">
											<i class="fa-solid fa-cards"></i> @oneOff.GameTypeName
										</span>
									}
									<span class="league-detail-active-game-meta-item league-event-badge-oneoff">@oneOff.Status</span>
								</div>
							</div>
						</div>
						<div class="league-detail-active-game-details">
							<div class="league-detail-active-game-detail">
								<i class="fa-solid fa-calendar"></i>
								<span>@FormatDate(oneOff.ScheduledAtUtc)</span>
							</div>
						</div>
						@if ((CanManageLeague && CanEditOneOffEvent(oneOff)) || oneOff.LaunchedGameId.HasValue)
						{
							<div class="league-detail-active-game-actions">
								@if (CanManageLeague && CanEditOneOffEvent(oneOff))
								{
									<button class="btn btn-sm btn-outline-secondary league-action-btn" @onclick="() => EditOneOffEvent.InvokeAsync(oneOff)">
										<i class="fa-solid fa-pen-to-square"></i> Edit
									</button>
									<button class="btn btn-sm btn-danger league-action-btn" @onclick="() => DeleteOneOffEvent.InvokeAsync(oneOff)" title="Delete one-off event">
										<i class="fa-regular fa-trash"></i>
									</button>
									<button class="league-detail-primary-action-btn" @onclick="() => LaunchOneOffEvent.InvokeAsync(oneOff.EventId)" disabled="@(LaunchingOneOffEventId == oneOff.EventId)">
										<i class="fa-solid fa-play"></i> Launch Play
									</button>
								}
								@if (oneOff.LaunchedGameId.HasValue)
								{
									<button class="league-detail-active-game-join-btn" @onclick="() => OpenTable.InvokeAsync(oneOff.LaunchedGameId.Value)">
										<i class="fa-solid fa-right-to-bracket"></i> Join
									</button>
								}
							</div>
						}
					</div>
				}
			</div>
			<div class="league-detail-active-games-footer">
				<div class="league-detail-active-games-meta">
					Showing @OneOffEventsPage.Entries.Count of @OneOffEventsPage.TotalCount one-off event@(OneOffEventsPage.TotalCount != 1 ? "s" : string.Empty). Page @OneOffEventsPage.PageNumber of @OneOffEventsPage.TotalPages.
				</div>
				<div class="league-detail-active-games-pager" role="group" aria-label="One-off events page navigation">
					<button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => LoadOneOffEventsPage.InvokeAsync(1)" disabled="@(IsLoadingOneOffEventsPage || OneOffEventsPage.PageNumber <= 1)">First</button>
					<button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => LoadOneOffEventsPage.InvokeAsync(Math.Max(1, OneOffEventsPage.PageNumber - 1))" disabled="@(IsLoadingOneOffEventsPage || OneOffEventsPage.PageNumber <= 1)">Previous</button>
					<span class="league-detail-active-games-pager-status">Page @OneOffEventsPage.PageNumber of @OneOffEventsPage.TotalPages</span>
					<button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => LoadOneOffEventsPage.InvokeAsync(Math.Min(OneOffEventsPage.TotalPages, OneOffEventsPage.PageNumber + 1))" disabled="@(IsLoadingOneOffEventsPage || OneOffEventsPage.PageNumber >= OneOffEventsPage.TotalPages)">Next</button>
					<button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => LoadOneOffEventsPage.InvokeAsync(OneOffEventsPage.TotalPages)" disabled="@(IsLoadingOneOffEventsPage || OneOffEventsPage.PageNumber >= OneOffEventsPage.TotalPages)">Last</button>
				</div>
			</div>
		}
	</section>
</div>

@code {
	[Parameter]
	public Guid LeagueId { get; set; }

	[Parameter]
	public bool CanManageLeague { get; set; }

	[Parameter, EditorRequired]
	public List<LeagueSeasonDto> Seasons { get; set; } = [];

	[Parameter]
	public Guid? SelectedSeasonId { get; set; }

	[Parameter, EditorRequired]
	public LeagueOneOffEventsPageDto OneOffEventsPage { get; set; } = EmptyOneOffEventsPage();

	[Parameter]
	public bool IsLoadingOneOffEventsPage { get; set; }

	[Parameter]
	public Guid? LaunchingOneOffEventId { get; set; }

	[Parameter]
	public string BrowserTimeZoneId { get; set; } = "UTC";

	[Parameter]
	public EventCallback OpenSeasonModal { get; set; }

	[Parameter]
	public EventCallback<Guid> OpenTable { get; set; }

	[Parameter]
	public EventCallback OpenOneOffModal { get; set; }

	[Parameter]
	public EventCallback<LeagueOneOffEventDto> EditOneOffEvent { get; set; }

	[Parameter]
	public EventCallback<LeagueOneOffEventDto> DeleteOneOffEvent { get; set; }

	[Parameter]
	public EventCallback<Guid> LaunchOneOffEvent { get; set; }

	[Parameter]
	public EventCallback<int> LoadOneOffEventsPage { get; set; }

	private string FormatDate(DateTimeOffset? value)
	{
		return LeagueTimeZoneHelper.FormatDateTime(value, BrowserTimeZoneId);
	}

	private void OpenSeasonDetail(Guid seasonId)
	{
		NavigationManager.NavigateTo($"/leagues/{LeagueId}/seasons/{seasonId}");
	}

	private static string FormatOneOffEventType(LeagueOneOffEventType? eventType)
	{
		return eventType switch
		{
			LeagueOneOffEventType.Tournament => "Tournament",
			LeagueOneOffEventType.CashGame => "Cash Game",
			_ => "One-Off"
		};
	}

	private static bool CanEditOneOffEvent(LeagueOneOffEventDto oneOffEvent)
	{
		return oneOffEvent.Status == LeagueOneOffEventStatus.Planned && !oneOffEvent.LaunchedGameId.HasValue;
	}

	private static LeagueOneOffEventsPageDto EmptyOneOffEventsPage()
	{
		return new LeagueOneOffEventsPageDto
		{
			Entries = [],
			HasMore = false,
			TotalCount = 0,
			PageNumber = 1,
			PageSize = 5,
			TotalPages = 1
		};
	}
}
