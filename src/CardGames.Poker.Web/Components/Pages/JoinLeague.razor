@page "/leagues/join/{Token}"
@attribute [Authorize]
@rendermode InteractiveServer

@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization

@inject ILeaguesApi LeaguesApi
@inject NavigationManager NavigationManager
@inject ILogger<JoinLeague> Logger

<PageTitle>Join League - Dealer's Choice Poker</PageTitle>

<AuthenticatedNavBar />

<main class="lobby-main">
	<div class="lobby-container">
		<section class="cashier-panel join-league-panel">
			<div class="cashier-panel-body d-flex flex-column gap-4 join-league-panel-body">
				<div class="cashier-section-header join-league-header mb-0">
					<div class="join-league-header-copy">
						<h1 class="cashier-section-title mb-0">Join League</h1>
					</div>
				</div>

				@if (_isPreviewLoading)
				{
					<div class="alert alert-light border mb-0 join-league-status" role="status">
						<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
						Loading trust preview...
					</div>
				}
				else if (!string.IsNullOrWhiteSpace(_message))
				{
					<div class="alert @(_isError ? "alert-warning" : "alert-success") mb-0 join-league-status" role="alert">@_message</div>
				}

				@if (_preview is not null)
				{
					<article class="card league-club-card join-league-preview-card">
						<div class="card-body league-club-body d-flex flex-column gap-3 join-league-preview-body">
							<div class="join-league-preview-header">
								<div class="league-club-title-group">
									<span class="join-league-preview-kicker">League invite</span>
									<h2 class="h4 mb-0 fw-semibold league-club-name">@_preview.LeagueName</h2>
									@if (!string.IsNullOrWhiteSpace(_preview.LeagueDescription))
									{
										<p class="small text-muted mb-0 league-club-description">@_preview.LeagueDescription</p>
									}
								</div>
								<span class="stat-pill stat-pill-purple join-league-members-pill">
									<span class="stat-circle">@_preview.ActiveMemberCount</span>
									<span>Current Members</span>
								</span>
							</div>

							<div class="join-league-detail-grid" role="list">
								<div class="join-league-detail-item" role="listitem">
									<span class="join-league-detail-label">Manager</span>
									<span class="join-league-detail-value">@_preview.ManagerDisplayName</span>
								</div>
							</div>
						</div>
					</article>
				}

				<div class="join-league-actions">
					<button class="btn btn-secondary join-league-action-btn" @onclick="Cancel" disabled="@_isSubmitting">
						Cancel
					</button>
					<button class="btn btn-primary join-league-action-btn" @onclick="SubmitRequestAsync" disabled="@(_isSubmitting || _preview is null)">
						@if (_isSubmitting)
						{
							<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
						}
						else
						{
							<i class="fa-solid fa-paper-plane me-2" aria-hidden="true"></i>
						}
						Submit Request
					</button>
				</div>
			</div>
		</section>
	</div>
</main>

@code {
	[Parameter]
	public string Token { get; set; } = string.Empty;

	private bool _isPreviewLoading;
	private bool _isSubmitting;
	private bool _isError;
	private string? _message;
	private LeagueJoinPreviewDto? _preview;

	protected override async Task OnInitializedAsync()
	{
		await LoadPreviewAsync();
	}

	private async Task LoadPreviewAsync()
	{
		_isPreviewLoading = true;
		_isError = false;
		_message = null;
		_preview = null;

		var token = (Token ?? string.Empty).Trim();
		if (string.IsNullOrWhiteSpace(token))
		{
			_message = "Invite code is missing. Please use a valid invite link.";
			_isError = true;
			_isPreviewLoading = false;
			return;
		}

		try
		{
			var response = await LeaguesApi.GetJoinPreviewAsync(token);

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_preview = response.Content;
			}
			else
			{
				_message = "This invite is invalid, revoked, or expired. Ask the league admin for a new link.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to load league trust preview using invite token.");
			_message = "Unable to load trust preview right now.";
			_isError = true;
		}
		finally
		{
			_isPreviewLoading = false;
		}
	}

	private async Task SubmitRequestAsync()
	{
		if (_preview is null)
		{
			_message = "Preview this invite before submitting.";
			_isError = true;
			return;
		}

		var token = (Token ?? string.Empty).Trim();
		if (string.IsNullOrWhiteSpace(token))
		{
			_message = "Invite code is missing. Please use a valid invite link.";
			_isError = true;
			return;
		}

		_isSubmitting = true;
		_isError = false;
		_message = null;

		try
		{
			var response = await LeaguesApi.JoinLeagueAsync(new JoinLeagueRequest
			{
				Token = token
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				if (response.Content.AlreadyMember)
				{
					NavigationManager.NavigateTo($"/leagues/{response.Content.LeagueId}");
					return;
				}

				NavigationManager.NavigateTo($"/leagues/{response.Content.LeagueId}");
			}
			else
			{
				_message = "Unable to submit your request with this invite. Refresh and try again.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to submit league join request from invite flow.");
			_message = "Unable to submit your request right now.";
			_isError = true;
		}
		finally
		{
			_isSubmitting = false;
		}
	}

	private void Cancel()
	{
		NavigationManager.NavigateTo("/leagues");
	}
}