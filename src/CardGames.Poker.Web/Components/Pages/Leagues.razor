@page "/leagues"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Shared
@using CardGames.Poker.Web.Services
@using Microsoft.AspNetCore.Authorization

@inject ILeaguesApi LeaguesApi
@inject LeagueHubClient LeagueHubClient
@inject ILogger<Leagues> Logger
@inject NavigationManager NavigationManager

<PageTitle>Leagues - Friday Night Poker</PageTitle>

<AuthenticatedNavBar />

<main class="lobby-main">
	<div class="lobby-container">
		<div class="lobby-header" style="position: relative;">
			<div class="lobby-header-content">
				<h1 class="lobby-title">
					<i class="fa-solid fa-users"></i>
					Leagues
				</h1>
				<p class="lobby-subtitle">Create a league and view leagues where you are a member.</p>
			</div>
			<div style="position: absolute; top: 1.25rem; right: 1.25rem; display: flex; gap: 0.5rem;">
				<button class="btn btn-primary btn-sm" @onclick="OpenCreateModal">
					<i class="fa-solid fa-plus me-1"></i> Create League
				</button>
				<button class="btn btn-outline-primary btn-sm" @onclick="OpenJoinModal">
					<i class="fa-solid fa-right-to-bracket me-1"></i> Join League
				</button>
			</div>
		</div>

		<section class="cashier-panel">
			<div class="cashier-panel-body d-flex flex-column gap-3">
				<div class="d-flex flex-column gap-2">
					<div class="cashier-section-header mb-0">
						<h2 class="cashier-section-title mb-0 fw-bold">My Leagues</h2>
						<button class="btn btn-sm btn-outline-secondary" @onclick="LoadLeaguesAsync"
								disabled="@_isLoading" aria-label="Refresh my leagues" title="Refresh my leagues">
							<i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
						</button>
					</div>
					<div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
						<span class="stat-pill stat-pill-blue">
							<span class="stat-circle">@_leagues.Count</span>
							<span>Leagues</span>
						</span>
						<span class="stat-pill stat-pill-purple">
							<span class="stat-circle">@(_adminLeagueCount + _managerLeagueCount)</span>
							<span>Manager/Admin</span>
						</span>
						@if (_isLoadingPendingActions)
						{
							<span class="stat-pill stat-pill-grey">
								<span class="stat-circle">...</span>
								<span>Pending</span>
							</span>
						}
						else
						{
							<span class="stat-pill stat-pill-grey">
								<span class="stat-circle">@_totalPendingJoinActions</span>
								<span>Pending</span>
							</span>
						}
					</div>
				</div>
				<br>
				<div class="mt-4">
					@if (_isLoading)
					{
						<p class="mb-0 text-muted">Loading leagues...</p>
					}
					else if (_leagues.Count == 0)
					{
						<p class="mb-0 text-muted">You are not in any leagues yet.</p>
					}
					else
					{
						<div
							style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
							@foreach (var league in _leagues)
							{
								<div>
									<article class="card league-club-card h-100">
										<div class="card-body league-club-body d-flex flex-column">
											<div class="league-club-header league-club-header-inline">
												<div class="league-club-title-group">
													<h2 class="h5 mb-0 fw-semibold text-break league-club-name">@league.Name
													</h2>
													<p class="card-text small text-muted mb-0 league-club-description">
														@GetTruncatedDescription(league.Description)</p>
													</div>
													<!-- <span class="badge ms-1 league-role-badge @GetRolePillClass(league.Role)">@GetRolePillLabel(league.Role)</span> -->
													<span class="stat-pill stat-pill-purple">
														<span class="stat-circle">1</span>
														<span>@league.Role</span>
													</span>
												</div>
												<div class="mt-auto pt-3"></div>
											</div>
											<div class="card-footer league-club-footer bg-white border-0 pt-0">
												<button class="btn btn-primary w-100"
														@onclick="() => OpenLeagueDetail(league.LeagueId)">
													Open League
												</button>
											</div>
										</article>
									</div>
								}
							</div>
						}
					</div>
				</div>
			</section>

			@if (_selectedLeague is not null)
			{
				<section class="cashier-panel">
					<div class="cashier-panel-body d-flex flex-column gap-3">
						<h2 class="cashier-section-title">Manage @_selectedLeague.Name</h2>

						@if (_leagueDetail is not null)
						{
							<div class="small text-muted">
								Created by @_leagueDetail.CreatedByUserId • Active members: @_leagueDetail.ActiveMemberCount
							</div>
						}

						<div>
							<h3 class="h6">Members</h3>
							@if (_memberSummaries.Count == 0)
							{
								<p class="text-muted mb-0">No members found.</p>
							}
							else
							{
								<ul class="list-group">
									@foreach (var member in _memberSummaries)
									{
										<li class="list-group-item d-flex justify-content-between align-items-center gap-2">
											<div>
												<div class="fw-semibold">@member.UserId</div>
												<div class="small text-muted">Role: @member.Role • Joined:
													@member.JoinedAtUtc.ToLocalTime().ToString("g")</div>
												</div>
												@if (CanManageSelectedLeague && member.IsActive && member.Role != LeagueRole.Admin)
												{
													<button class="btn btn-sm btn-warning" @onclick="() => PromoteMemberAsync(member.UserId)"
															disabled="@_isSubmittingPromote">Promote</button>
												}
											</li>
										}
									</ul>
								}
							</div>

							@if (CanManageSelectedLeague)
							{
								<div class="auth-form">
									<h3 class="h6">Create Invite Link</h3>
									<div class="form-floating mb-3" data-label="Expiry (UTC)">
										<InputDate id="invite-expiry" class="form-control" @bind-Value="_inviteExpiryDate" />
									</div>
									<button class="btn btn-sm btn-primary" @onclick="CreateInviteAsync"
											disabled="@_isSubmittingInvite">Create Invite</button>
									@if (!string.IsNullOrWhiteSpace(_createdInviteUrl))
									{
										<div class="alert alert-success mt-3 mb-0" role="alert">
											Invite link: <a href="@_createdInviteUrl">@_createdInviteUrl</a>
										</div>
									}
								</div>
							}

							<div>
								<h3 class="h6">Invites</h3>
								@if (_inviteSummaries.Count == 0)
								{
									<p class="text-muted mb-0">No invites yet.</p>
								}
								else
								{
									<ul class="list-group">
										@foreach (var invite in _inviteSummaries)
										{
											<li class="list-group-item small">
												Status: @invite.Status • Expires: @invite.ExpiresAtUtc.ToLocalTime().ToString("g")
											</li>
										}
									</ul>
								}
							</div>
						</div>
					</section>
				}
			</div>
		</main>

		@* ── Create League Modal ── *@
		@if (_showCreateModal)
		{
			<div class="confirm-dialog-overlay" @onclick="CloseCreateModal">
				<div class="confirm-dialog league-form-modal" @onclick:stopPropagation>
					<div class="confirm-dialog-header league-form-modal-header">
						<h3 class="confirm-dialog-title mb-0">Create League</h3>
						<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="CloseCreateModal">
							<i class="fa-solid fa-xmark" aria-hidden="true"></i>
						</button>
					</div>
					<div class="confirm-dialog-body league-form-modal-body text-start">
						@if (!string.IsNullOrWhiteSpace(_message))
						{
							<div class="alert @(_isError ? "alert-warning" : "alert-success") py-2 mb-2" role="alert">@_message</div>
						}
						<div class="form-floating" data-label="League Name">
							<InputText id="league-name" class="form-control league-modal-input" @bind-Value="_name" maxlength="120"
									   placeholder="League Name" disabled="@_isSubmitting" />
						</div>
						<div class="form-floating" data-label="Description (optional)">
							<InputText id="league-description" class="form-control league-modal-input" @bind-Value="_description"
									   maxlength="512" placeholder="Description (optional)" disabled="@_isSubmitting" />
						</div>
					</div>
					<div class="confirm-dialog-footer">
						<button class="confirm-dialog-btn btn btn-secondary" @onclick="CloseCreateModal"
								disabled="@_isSubmitting">Cancel</button>
						<button class="confirm-dialog-btn btn btn-primary" @onclick="CreateLeagueAsync" disabled="@_isSubmitting">
							@if (_isSubmitting)
							{
								<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
							}
							Create
						</button>
					</div>
				</div>
			</div>
		}

		@* ── Join League Modal ── *@
		@if (_showJoinModal)
		{
			<div class="confirm-dialog-overlay" @onclick="CloseJoinModal">
				<div class="confirm-dialog league-form-modal" @onclick:stopPropagation>
					<div class="confirm-dialog-header league-form-modal-header">
						<h3 class="confirm-dialog-title mb-0">Join League</h3>
						<button type="button" class="league-modal-close-btn" aria-label="Close" @onclick="CloseJoinModal">
							<i class="fa-solid fa-xmark" aria-hidden="true"></i>
						</button>
					</div>
					<div class="confirm-dialog-body league-form-modal-body text-start">
						<div class="form-floating" data-label="League Code">
							<InputText id="league-code" class="form-control league-modal-input" @bind-Value="JoinCode"
									   maxlength="128" placeholder="League Code" disabled="@_isPreviewLoading" />
						</div>

						<div class="d-flex flex-wrap gap-2 mt-2">
							@if (!IsCurrentCodePreviewed || _isPreviewLoading)
							{
								<button class="btn btn-sm btn-outline-primary" @onclick="LoadJoinPreviewAsync"
										disabled="@_isPreviewLoading">
									@if (_isPreviewLoading)
									{
										<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
									}
									Preview
								</button>
							}

							@if (_joinPreview is not null && IsCurrentCodePreviewed)
							{
								<article class="card league-club-card h-100">
									<div class="card-body league-club-body d-flex flex-column" style="position: relative;">
										<h4 class="medium fw-bold mb-2 text-truncate" style="padding-right: 8rem;"
											title="@(_joinPreview.LeagueName)">
											@(_joinPreview.LeagueName)
										</h4>
										@if (!string.IsNullOrWhiteSpace(_joinPreview.LeagueDescription))
										{
											<div class="small text-muted fst-italic">@_joinPreview.LeagueDescription</div>
										}
										<div class="small text-muted">
											<div><strong>Manager:</strong> @_joinPreview.ManagerDisplayName</div>
											<div><strong>Active members:</strong> @_joinPreview.ActiveMemberCount</div>
										</div>
									</div>
								</article>
							}
						</div>

						@if (!string.IsNullOrWhiteSpace(_joinMessage))
						{
							<div class="alert @(_isJoinError ? "alert-warning" : "alert-success") mt-2 mb-0" role="alert">
								@_joinMessage</div>
							}
						</div>
						<div class="confirm-dialog-footer join-league-dialog-footer">
							<button class="confirm-dialog-btn btn btn-secondary" 
							   @onclick="CloseJoinModal">Cancel</button>
							<button
								class="confirm-dialog-btn btn btn-primary join-league-submit-btn"
								title="Submit join request" @onclick="() => SubmitJoinByCodeAsync()" disabled="@_isJoinSubmitting">
								<i class="fa-solid fa-paper-plane"></i>
								Submit Request
							</button>
						</div>
					</div>
				</div>
			}

@code {
	private bool _isLoading;
	private bool _isSubmitting;
	private bool _isError;
	private string? _message;
	private string _name = string.Empty;
	private string? _description;
	private bool _showCreateModal;
	private bool _showJoinModal;
	private List<LeagueSummaryDto> _leagues = [];
	private LeagueSummaryDto? _selectedLeague;
	private LeagueDetailDto? _leagueDetail;
	private Guid? _selectedLeagueId;
	private DateTime _inviteExpiryDate = DateTime.UtcNow.Date.AddDays(7);
	private bool _isSubmittingInvite;
	private bool _isSubmittingPromote;
	private string? _createdInviteUrl;
	private List<LeagueMemberDto> _memberSummaries = [];
	private List<LeagueInviteSummaryDto> _inviteSummaries = [];
	private string _joinCode = string.Empty;
	private string? _lastPreviewedJoinCode;
	private LeagueJoinPreviewDto? _joinPreview;
	private bool _isPreviewLoading;
	private bool _isJoinSubmitting;
	private bool _isJoinError;
	private string? _joinMessage;
	private Dictionary<Guid, int> _pendingJoinActionsByLeagueId = [];
	private bool _isLoadingPendingActions;
	private string _quickSwitchLeagueId = string.Empty;
	// Restored missing fields
	private int _adminLeagueCount;
	private int _managerLeagueCount;
	private int _totalPendingJoinActions;

	private void OpenCreateModal()
	{
		_showJoinModal = false;
		_name = string.Empty;
		_description = null;
		_message = null;
		_isError = false;
		_showCreateModal = true;
	}

	private void CloseCreateModal()
	{
		_showCreateModal = false;
	}

	private void OpenJoinModal()
	{
		_showCreateModal = false;
		JoinCode = string.Empty;
		_joinPreview = null;
		_joinMessage = null;
		_isJoinError = false;
		_showJoinModal = true;
	}

	private void CloseJoinModal()
	{
		_showJoinModal = false;
	}

	private string JoinCode
	{
		get => _joinCode;
		set
		{
			var normalized = value ?? string.Empty;
			if (string.Equals(_joinCode, normalized, StringComparison.Ordinal))
			{
				return;
			}

			_joinCode = normalized;
			_lastPreviewedJoinCode = null;
			_joinPreview = null;
			_joinMessage = null;
			_isJoinError = false;
		}
	}

	private bool IsCurrentCodePreviewed =>
		!string.IsNullOrWhiteSpace(_joinCode)
		&& string.Equals(_joinCode.Trim(), _lastPreviewedJoinCode, StringComparison.Ordinal);

	// Restored computed property
	private bool CanManageSelectedLeague => _selectedLeague is not null
		&& (_selectedLeague.Role == LeagueRole.Admin || _selectedLeague.Role == LeagueRole.Manager || _selectedLeague.Role ==
LeagueRole.Owner);

	protected override async Task OnInitializedAsync()
	{
		await LoadLeaguesAsync();
		await ConnectToLeagueHubAsync();
	}

	private async Task LoadLeaguesAsync()
	{
		_isLoading = true;

		try
		{
			var response = await LeaguesApi.GetMyLeaguesAsync();
			if (response is { IsSuccessStatusCode: true, Content: not null })
			{
				_leagues = response.Content.ToList();
				_adminLeagueCount = _leagues.Count(x => x.Role == LeagueRole.Admin);
				_managerLeagueCount = _leagues.Count(x => x.Role == LeagueRole.Manager);
				if (string.IsNullOrWhiteSpace(_quickSwitchLeagueId) || !_leagues.Any(x => x.LeagueId.ToString() ==
_quickSwitchLeagueId))
				{
					_quickSwitchLeagueId = _leagues.FirstOrDefault()?.LeagueId.ToString() ?? string.Empty;
				}

				await LoadPendingJoinActionsAsync();
				if (_selectedLeagueId.HasValue)
				{
					_selectedLeague = _leagues.FirstOrDefault(x => x.LeagueId == _selectedLeagueId.Value);
				}
			}
			else
			{
				_leagues = [];
				_pendingJoinActionsByLeagueId = [];
				_totalPendingJoinActions = 0;
				_adminLeagueCount = 0;
				_managerLeagueCount = 0;
				_quickSwitchLeagueId = string.Empty;
				_message = "No leagues right now.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to load leagues");
			_leagues = [];
			_pendingJoinActionsByLeagueId = [];
			_totalPendingJoinActions = 0;
			_adminLeagueCount = 0;
			_managerLeagueCount = 0;
			_quickSwitchLeagueId = string.Empty;
			_message = "Unable to load leagues right now.";
			_isError = true;
		}
		finally
		{
			await SyncManagedLeaguesSubscriptionsAsync();
			_isLoading = false;
		}
	}

	private async Task ConnectToLeagueHubAsync()
	{
		try
		{
			LeagueHubClient.OnLeagueJoinRequestSubmitted += HandleLeagueJoinRequestSubmittedAsync;
			LeagueHubClient.OnLeagueJoinRequestUpdated += HandleLeagueJoinRequestUpdatedAsync;
			await LeagueHubClient.ConnectAsync();
			await SyncManagedLeaguesSubscriptionsAsync();
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to connect to leagues hub.");
		}
	}

	private async Task SyncManagedLeaguesSubscriptionsAsync()
	{
		var manageableLeagueIds = _leagues
			.Where(x => x.Role == LeagueRole.Admin || x.Role == LeagueRole.Manager || x.Role == LeagueRole.Owner)
			.Select(x => x.LeagueId)
			.ToList();

		await LeagueHubClient.SetManagedLeaguesAsync(manageableLeagueIds);
	}

	private async Task LoadPendingJoinActionsAsync()
	{
		_pendingJoinActionsByLeagueId = [];
		_totalPendingJoinActions = 0;

		var manageableLeagues = _leagues
			.Where(x => x.Role == LeagueRole.Admin || x.Role == LeagueRole.Manager || x.Role == LeagueRole.Owner)
			.Select(x => x.LeagueId)
			.ToList();

		if (manageableLeagues.Count == 0)
		{
			return;
		}

		_isLoadingPendingActions = true;
		try
		{
			foreach (var leagueId in manageableLeagues)
			{
				await RefreshPendingJoinActionsForLeagueAsync(leagueId);
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed to load pending join requests for one or more leagues.");
		}
		finally
		{
			_isLoadingPendingActions = false;
		}
	}

	private async Task RefreshPendingJoinActionsForLeagueAsync(Guid leagueId)
	{
		var response = await LeaguesApi.GetPendingJoinRequestsAsync(leagueId);
		if (response.IsSuccessStatusCode && response.Content is not null)
		{
			_pendingJoinActionsByLeagueId[leagueId] = response.Content.Count(x => x.Status == LeagueJoinRequestStatus.Pending);
		}
		else
		{
			_pendingJoinActionsByLeagueId[leagueId] = 0;
		}

		_totalPendingJoinActions = _pendingJoinActionsByLeagueId.Values.Sum();
	}

	private async Task HandleLeagueJoinRequestSubmittedAsync(CardGames.Contracts.SignalR.LeagueJoinRequestSubmittedDto
payload)
	{
		await InvokeAsync(async () =>
		{
			if (!_leagues.Any(x => x.LeagueId == payload.LeagueId && (x.Role == LeagueRole.Admin || x.Role == LeagueRole.Manager ||
x.Role == LeagueRole.Owner)))
			{
				return;
			}

			await RefreshPendingJoinActionsForLeagueAsync(payload.LeagueId);
			StateHasChanged();
		});
	}

	private async Task HandleLeagueJoinRequestUpdatedAsync(CardGames.Contracts.SignalR.LeagueJoinRequestUpdatedDto payload)
	{
		await InvokeAsync(async () =>
		{
			if (!_leagues.Any(x => x.LeagueId == payload.LeagueId && (x.Role == LeagueRole.Admin || x.Role == LeagueRole.Manager ||
x.Role == LeagueRole.Owner)))
			{
				return;
			}

			await RefreshPendingJoinActionsForLeagueAsync(payload.LeagueId);
			StateHasChanged();
		});
	}

	private int GetPendingJoinActionsCount(Guid leagueId)
	{
		return _pendingJoinActionsByLeagueId.TryGetValue(leagueId, out var count)
			? count
			: 0;
	}

	private static string GetRolePillClass(LeagueRole role)
	{
		return role is LeagueRole.Manager or LeagueRole.Admin or LeagueRole.Owner
			? "rounded-pill stat-pill-purple"
			: "rounded-pill text-bg-light text-dark";
	}

	private static string GetRolePillLabel(LeagueRole role)
	{
		return role is LeagueRole.Manager or LeagueRole.Admin or LeagueRole.Owner
			? "Manager/Admin"
			: "Member";
	}

	private static string GetTruncatedDescription(string? description)
	{
		if (string.IsNullOrWhiteSpace(description))
		{
			return "No description provided.";
		}

		var trimmed = description.Trim();
		const int maxLength = 140;
		return trimmed.Length <= maxLength
			? trimmed
			: $"{trimmed[..(maxLength - 1)]}…";
	}

	private Task OpenQuickSwitchLeagueAsync()
	{
		if (Guid.TryParse(_quickSwitchLeagueId, out var leagueId))
		{
			OpenLeagueDetail(leagueId);
		}

		return Task.CompletedTask;
	}

	private async Task SelectLeagueAsync(LeagueSummaryDto league)
	{
		_selectedLeague = league;
		_selectedLeagueId = league.LeagueId;
		_leagueDetail = null;
		_memberSummaries = [];
		_createdInviteUrl = null;
		await LoadLeagueDetailAsync();
		await LoadMembersAsync();
		await LoadInvitesAsync();
	}

	private async Task LoadLeagueDetailAsync()
	{
		if (_selectedLeague is null)
		{
			_leagueDetail = null;
			return;
		}

		try
		{
			var response = await LeaguesApi.GetLeagueDetailAsync(_selectedLeague.LeagueId);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_leagueDetail = response.Content;
			}
			else
			{
				_leagueDetail = null;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to load league detail for {LeagueId}", _selectedLeague.LeagueId);
			_leagueDetail = null;
		}
	}

	private async Task LoadMembersAsync()
	{
		if (_selectedLeague is null)
		{
			_memberSummaries = [];
			return;
		}

		try
		{
			var response = await LeaguesApi.GetLeagueMembersAsync(_selectedLeague.LeagueId);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_memberSummaries = response.Content.ToList();
			}
			else
			{
				_memberSummaries = [];
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to load league members for {LeagueId}", _selectedLeague.LeagueId);
			_memberSummaries = [];
		}
	}

	private async Task LoadInvitesAsync()
	{
		if (_selectedLeague is null)
		{
			_inviteSummaries = [];
			return;
		}

		try
		{
			var response = await LeaguesApi.GetInvitesAsync(_selectedLeague.LeagueId);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_inviteSummaries = response.Content.ToList();
			}
			else
			{
				_inviteSummaries = [];
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to load invites for league {LeagueId}", _selectedLeague.LeagueId);
			_inviteSummaries = [];
		}
	}

	private async Task CreateInviteAsync()
	{
		if (_selectedLeague is null)
		{
			return;
		}

		_isSubmittingInvite = true;
		try
		{
			var expiryUtc = new DateTimeOffset(DateTime.SpecifyKind(_inviteExpiryDate, DateTimeKind.Utc));
			var response = await LeaguesApi.CreateInviteAsync(_selectedLeague.LeagueId, new CreateLeagueInviteRequest
			{
				ExpiresAtUtc = expiryUtc
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_createdInviteUrl = NavigationManager.ToAbsoluteUri(response.Content.InviteUrl).ToString();
				await LoadInvitesAsync();
				_message = "Invite created.";
				_isError = false;
			}
			else
			{
				_message = "Failed to create invite.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create invite for league {LeagueId}", _selectedLeague.LeagueId);
			_message = "Failed to create invite.";
			_isError = true;
		}
		finally
		{
			_isSubmittingInvite = false;
		}
	}

	private async Task PromoteMemberAsync(string memberUserId)
	{
		if (_selectedLeague is null || string.IsNullOrWhiteSpace(memberUserId))
		{
			return;
		}

		_isSubmittingPromote = true;
		try
		{
			var response = await LeaguesApi.PromoteMemberToAdminAsync(_selectedLeague.LeagueId, memberUserId.Trim());
			if (response.IsSuccessStatusCode)
			{
				_message = "Member promoted to admin.";
				_isError = false;
				await LoadMembersAsync();
				await LoadLeaguesAsync();
			}
			else
			{
				_message = "Failed to promote member.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to promote member in league {LeagueId}", _selectedLeague.LeagueId);
			_message = "Failed to promote member.";
			_isError = true;
		}
		finally
		{
			_isSubmittingPromote = false;
		}
	}

	private async Task LeaveLeagueAsync(Guid leagueId)
	{
		try
		{
			var response = await LeaguesApi.LeaveLeagueAsync(leagueId);
			if (response.IsSuccessStatusCode)
			{
				if (_selectedLeagueId == leagueId)
				{
					_selectedLeagueId = null;
					_selectedLeague = null;
					_leagueDetail = null;
					_memberSummaries = [];
					_inviteSummaries = [];
				}

				_message = "League left.";
				_isError = false;
				await LoadLeaguesAsync();
			}
			else
			{
				_message = "Failed to leave league.";
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to leave league {LeagueId}", leagueId);
			_message = "Failed to leave league.";
			_isError = true;
		}
	}

	private async Task CreateLeagueAsync()
	{
		_message = null;
		_isError = false;

		if (string.IsNullOrWhiteSpace(_name))
		{
			_message = "League name is required.";
			_isError = true;
			return;
		}

		_isSubmitting = true;

		try
		{
			var request = new CreateLeagueRequest
			{
				Name = _name.Trim(),
				Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim()
			};

			var response = await LeaguesApi.CreateLeagueAsync(request);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_name = string.Empty;
				_description = null;
				_message = null;
				_isError = false;
				_showCreateModal = false;
				await LoadLeaguesAsync();
			}
			else
			{
				var errorContent = response.Error?.Content;
				if (string.IsNullOrWhiteSpace(errorContent))
				{
					_message = $"Failed to create league (HTTP {(int)response.StatusCode}).";
				}
				else
				{
					_message = $"Failed to create league (HTTP {(int)response.StatusCode}): {errorContent[..Math.Min(200,
errorContent.Length)]}";
				}
				_isError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to create league");
			_message = "Failed to create league.";
			_isError = true;
		}
		finally
		{
			_isSubmitting = false;
		}
	}

	private void OpenLeagueDetail(Guid leagueId)
	{
		NavigationManager.NavigateTo($"/leagues/{leagueId}");
	}

	private async Task LoadJoinPreviewAsync()
	{
		_joinMessage = null;
		_isJoinError = false;
		_joinPreview = null;
		_lastPreviewedJoinCode = null;

		var token = (_joinCode ?? string.Empty).Trim();
		if (string.IsNullOrWhiteSpace(token))
		{
			_joinMessage = "Enter a league code to continue.";
			_isJoinError = true;
			return;
		}

		_isPreviewLoading = true;
		try
		{
			var response = await LeaguesApi.GetJoinPreviewAsync(token);
			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				_joinPreview = response.Content;
				_joinCode = token;
				_lastPreviewedJoinCode = token;
			}
			else
			{
				_joinMessage = GetJoinErrorMessage(response.Error?.Content, "That code is invalid or expired. Ask the league admin for a new code.");
				_isJoinError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to load league join preview for code flow.");
			_joinMessage = "Unable to preview this league right now.";
			_isJoinError = true;
		}
		finally
		{
			_isPreviewLoading = false;
		}
	}

	private async Task SubmitJoinByCodeAsync()
	{
		_joinMessage = null;
		_isJoinError = false;

		var token = (_joinCode ?? string.Empty).Trim();
		if (_joinPreview is null || string.IsNullOrWhiteSpace(token) || !IsCurrentCodePreviewed)
		{
			_joinMessage = "Preview a valid code before submitting your request.";
			_isJoinError = true;
			return;
		}

		_isJoinSubmitting = true;
		try
		{
			var response = await LeaguesApi.JoinLeagueAsync(new JoinLeagueRequest
			{
				Token = token
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				var leagueId = response.Content.LeagueId;
				if (response.Content.AlreadyMember)
				{
					_joinMessage = "You are already a member of this league.";
				}
				else
				{
					_joinMessage = "Join request accepted.";
				}

				NavigationManager.NavigateTo($"/leagues/{leagueId}");
			}
			else
			{
				_joinMessage = GetJoinErrorMessage(response.Error?.Content, "Unable to submit your request with this code.");
				_isJoinError = true;
			}
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to submit league join request from code flow.");
			_joinMessage = "Unable to submit your request right now.";
			_isJoinError = true;
		}
		finally
		{
			_isJoinSubmitting = false;
		}
	}

	private static string GetJoinErrorMessage(string? errorContent, string fallback)
	{
		if (string.IsNullOrWhiteSpace(errorContent))
		{
			return fallback;
		}

		return errorContent.Length > 200
			? errorContent[..200]
			: errorContent;
	}

	public async ValueTask DisposeAsync()
	{
		LeagueHubClient.OnLeagueJoinRequestSubmitted -= HandleLeagueJoinRequestSubmittedAsync;
		LeagueHubClient.OnLeagueJoinRequestUpdated -= HandleLeagueJoinRequestUpdatedAsync;

		try
		{
			await LeagueHubClient.SetManagedLeaguesAsync([]);
			await LeagueHubClient.DisconnectAsync();
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Error disconnecting leagues hub on dispose.");
		}
	}
}
