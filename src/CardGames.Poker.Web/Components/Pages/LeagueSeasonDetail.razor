	private void ResetSeasonEventDraft()
	{
		_editingSeasonEventId = null;
		_seasonEventName = string.Empty;
		_seasonEventSequence = null;
		var defaultSchedule = LeagueTimeZoneHelper.GetDefaultLocalScheduledDateTime(BrowserTimeZoneId);
		_seasonEventScheduledDate = defaultSchedule.Date;
		_seasonEventScheduledTime = defaultSchedule.TimeText;
		_seasonEventTimeZoneId = BrowserTimeZoneId;
		_seasonEventNotes = null;
		_seasonEventGameTypeCode = string.Empty;
		_seasonEventAnte = 10;
		_seasonEventMinBet = 20;
		_seasonEventSmallBlind = 5;
		_seasonEventBigBlind = 10;
