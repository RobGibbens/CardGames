	}

	private bool IsLaunchingSeasonEvent(Guid eventId)
	{
		return _launchingSeasonEventId.HasValue && _launchingSeasonEventId.Value == eventId;
	}

	private static string BuildLeagueTablePath(string tablePath)
	{
		if (string.IsNullOrWhiteSpace(tablePath))
		{
			return tablePath;
		}

		if (tablePath.Contains("autojoin=", StringComparison.OrdinalIgnoreCase))
		{
			return tablePath;
		}

		return tablePath.Contains('?', StringComparison.Ordinal)
			? $"{tablePath}&autojoin=1"
			: $"{tablePath}?autojoin=1";
	}

	private static string? TryExtractApiErrorMessage(Refit.IApiResponse response)
	{
		var content = response.Error?.Content;
		if (string.IsNullOrWhiteSpace(content))
		{
			return response.Error?.Message;
		}

		try
		{
			using var document = JsonDocument.Parse(content);
			if (document.RootElement.ValueKind == JsonValueKind.Object)
			{
				if (document.RootElement.TryGetProperty("message", out var messageProperty))
				{
					return messageProperty.GetString();
				}

				if (document.RootElement.TryGetProperty("Message", out var messagePascalCaseProperty))
				{
					return messagePascalCaseProperty.GetString();
				}
			}
		}
		catch (JsonException)
		{
		}

		return content;
	}

	public async ValueTask DisposeAsync()
	{
		if (_isLeagueHubSubscriptionInitialized)
		{
			LeagueHubClient.OnLeagueEventChanged -= HandleLeagueEventChangedAsync;
			LeagueHubClient.OnLeagueEventSessionLaunched -= HandleLeagueEventSessionLaunchedAsync;
			_isLeagueHubSubscriptionInitialized = false;
		}

		if (_leagueSeasonDetailModule is not null)
		{
			try
			{
				await _leagueSeasonDetailModule.InvokeVoidAsync("disposeCalendarEventHighlights", _calendarHost);
				await _leagueSeasonDetailModule.DisposeAsync();
			}
			catch (JSDisconnectedException)
			{
			}
		}
	}
}