	private async Task ConfirmDeleteEventAsync()
	{
		if (_pendingEventDeletion is null || _isDeletingEvent)
		{
			return;
		}

		_isDeletingEvent = true;
		try
		{
			var response = await LeaguesApi.DeleteSeasonEventAsync(LeagueId, SeasonId, _pendingEventDeletion.EventId);
			if (response.IsSuccessStatusCode)
			{
				await LoadSeasonEventsAsync();
				await LoadStandingsAsync();
				_message = "Season event deleted.";
				_isError = false;
				CancelDeleteEvent();
				return;
			}

			_message = TryExtractApiErrorMessage(response) ?? "Failed to delete event.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed deleting league season event {LeagueId}/{SeasonId}/{EventId}", LeagueId, SeasonId, _pendingEventDeletion.EventId);
			_message = "Failed to delete event.";
			_isError = true;
		}
		finally
		{
			_isDeletingEvent = false;
			_showDeleteEventConfirmation = false;
			_pendingEventDeletion = null;
		}
	}

	private void CancelDeleteEvent()
	{
		if (_isDeletingEvent)
		{
			return;
		}

		_showDeleteEventConfirmation = false;
		_pendingEventDeletion = null;
	}

	private async Task LaunchSeasonEventAsync(Guid eventId)
	{
		_launchingSeasonEventId = eventId;
		await LaunchSeasonEventCoreAsync(eventId, $"Failed to launch table from season event {eventId} in league {LeagueId} season {SeasonId}");
	}

	private async Task LaunchSeasonEventCoreAsync(Guid eventId, string logMessage)
	{
		try
		{
			var seasonEvent = _seasonEvents.FirstOrDefault(candidate => candidate.EventId == eventId);
			var response = await LeaguesApi.LaunchSeasonEventSessionAsync(LeagueId, SeasonId, eventId, new LaunchLeagueEventSessionRequest
			{
				GameCode = seasonEvent?.GameTypeCode ?? "FIVECARDDRAW",
				Ante = seasonEvent?.Ante ?? 10,
				MinBet = seasonEvent?.MinBet ?? 20,
				SmallBlind = seasonEvent?.SmallBlind,
				BigBlind = seasonEvent?.BigBlind,
				HostStartingChips = seasonEvent?.TournamentBuyIn ?? DefaultTournamentBuyIn
			});

			if (response.IsSuccessStatusCode && response.Content is not null)
			{
				NavigationManager.NavigateTo(BuildLeagueTablePath(response.Content.TablePath));
				return;
			}

			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, logMessage);
			_message = "Failed to launch table from season event.";
			_isError = true;
		}
		finally
		{
			_launchingSeasonEventId = null;
		}
	}

	private async Task OpenTable(Guid gameId)
	{
		try
		{
			var cashierSummary = await ProfileApi.GetCashierSummaryAsync();
			if (cashierSummary.IsSuccessStatusCode && (cashierSummary.Content?.CurrentBalance ?? 0) <= 0)
			{
				NavigationManager.NavigateTo(BuildLeagueTablePath($"/table/{gameId}"));
				return;
			}
		}
		catch (Exception ex)
		{
			Logger.LogWarning(ex, "Failed to check chip balance before opening table from league season page");
		}

		NavigationManager.NavigateTo(BuildLeagueTablePath($"/table/{gameId}"));
	}

