@page "/Account/Cashier"
@attribute [Authorize]
@rendermode InteractiveServer

@using CardGames.Poker.Api.Clients
@using CardGames.Poker.Api.Contracts
@using CardGames.Poker.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization

@inject IProfileApi ProfileApi
@inject ILogger<Cashier> Logger

<PageTitle>Cashier - Dealer's Choice Poker</PageTitle>

<AuthenticatedNavBar />

<main class="lobby-main">
    <div class="lobby-container">
        <div class="lobby-header">
            <div class="lobby-header-content">
                <h1 class="lobby-title">
                    <i class="fa-solid fa-coins"></i>
                    Cashier
                </h1>
                <p class="lobby-subtitle">Manage your account chips and review your transaction history.</p>
            </div>
        </div>

        <BbCard>
            <BbCardHeader>
                <div class="flex items-center justify-between">
                    <div>
                        <div class="flex items-center gap-2">
                            <BbCardTitle>Chip Balance</BbCardTitle>
                            <BbBadge>@_summary?.CurrentBalance.ToString("N0")</BbBadge>
                        </div>
                        <BbCardDescription>Manage your chip balance and transactions.</BbCardDescription>
                    </div>

                    <BbPopover @bind-Open="_isAddChipsPopoverOpen">
                        <BbPopoverTrigger AsChild>
                            <BbButton Variant="ButtonVariant.Outline"><i class="fa-solid fa-plus me-1"></i> Add Chips
                            </BbButton>
                        </BbPopoverTrigger>
                        <BbPopoverContent class="w-80">
                            <div class="grid gap-4">
                                <div class="flex items-center justify-between">
                                    <BbFormFieldNumericInput TValue="int" @bind-Value="_chipAmount" Label="Amount"
                                                             ShowButtons="true" Step="100" DecimalPlaces="0" Min="1"
                                                             HelperText="Use buttons or type a value" />
                                </div>
                                <BbButton OnClick="SubmitAddChipsAsync">Add Chips</BbButton>
                            </div>
                        </BbPopoverContent>
                    </BbPopover>


                    
                </div>
            </BbCardHeader>
            <BbCardContent class="space-y-3">
                @foreach (var entry in _ledgerEntries)
                {
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <BbAvatar class="h-8 w-8">
                                <BbAvatarFallback><i class="fa-solid fa-plus"></i></BbAvatarFallback>
                            </BbAvatar>
                            <div>
                                <p class="text-sm font-medium">@FormatDelta(entry.AmountDelta)</p>
                                <p class="text-xs text-muted-foreground">@FormatTimestamp(entry.OccurredAtUtc)</p>
                            </div>
                        </div>
                        <BbBadge Variant="BadgeVariant.Secondary">@FormatContext(entry)</BbBadge>
                    </div>
                    <BbSeparator />
                }

            </BbCardContent>
            <BbCardFooter class="flex items-center justify-between">
                <BbPagination>
                    <BbPaginationContent>
                        <BbPaginationItem>
                            <BbPaginationFirst OnClick="@LoadFirstPageAsync" />
                        </BbPaginationItem>
                        <BbPaginationItem>
                            <BbPaginationPrevious OnClick="@LoadPreviousPageAsync" />
                        </BbPaginationItem>

                        <BbPaginationItem>
                            <BbPaginationNext OnClick="@LoadNextPageAsync" />
                        </BbPaginationItem>
                        <BbPaginationItem>
                            <BbPaginationLast OnClick="@LoadLastPageAsync" />
                        </BbPaginationItem>
                    </BbPaginationContent>
                </BbPagination>
            </BbCardFooter>
        </BbCard>

    </div>
</main>

<BlazorBlueprint.Primitives.Services.BbPortalHost />
<BlazorBlueprint.Primitives.Services.BbOverlayPortalHost />

@code {
    private const int DefaultPageSize = 10;
    private static readonly int[] PageSizeOptions = [10, 25, 50, 100];

    private bool _isLoading;
    private string? _error;
    private CashierSummaryDto? _summary;
    private List<CashierLedgerEntryDto> _ledgerEntries = [];
    private int _pageNumber = 1;
    private int _pageSize = DefaultPageSize;
    private int _totalCount;

    private int _chipAmount = 500;
    private string? _chipReason;
    private bool _isAddChipsPopoverOpen;
    private bool _isSubmittingAddChips;
    private string? _addChipsMessage;
    private bool _addChipsMessageIsError;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)_pageSize));
    private bool HasPreviousPage => _pageNumber > 1;
    private bool HasNextPage => _pageNumber < TotalPages;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            var summaryResponse = await ProfileApi.GetCashierSummaryAsync();
            if (summaryResponse.IsSuccessStatusCode && summaryResponse.Content is not null)
            {
                _summary = summaryResponse.Content;
            }
            else
            {
                _summary = new CashierSummaryDto
                {
                    CurrentBalance = 0,
                    PendingBalanceChange = 0,
                    LastTransactionAtUtc = null
                };
                _error = "Cashier summary is not available right now.";
            }

            var ledgerResponse = await ProfileApi.GetCashierLedgerPageAsync(_pageSize, _pageNumber);
            if (ledgerResponse.IsSuccessStatusCode && ledgerResponse.Content is not null)
            {
                _ledgerEntries = ledgerResponse.Content.Entries.ToList();
                _pageNumber = ledgerResponse.Content.PageNumber;
                _pageSize = ledgerResponse.Content.PageSize;
                _totalCount = ledgerResponse.Content.TotalCount;
            }
            else
            {
                _ledgerEntries = [];
                _totalCount = 0;
                _error ??= "Cashier ledger is not available right now.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load cashier page data");
            _summary = new CashierSummaryDto
            {
                CurrentBalance = 0,
                PendingBalanceChange = 0,
                LastTransactionAtUtc = null
            };
            _ledgerEntries = [];
            _totalCount = 0;
            _error = "Unable to load cashier data right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubmitAddChipsAsync()
    {
        _addChipsMessage = null;
        _addChipsMessageIsError = false;

        if (_chipAmount <= 0)
        {
            _addChipsMessage = "Please enter a positive amount.";
            _addChipsMessageIsError = true;
            return;
        }

        _isSubmittingAddChips = true;

        try
        {
            var request = new AddAccountChipsRequest
            {
                Amount = _chipAmount,
                Reason = string.IsNullOrWhiteSpace(_chipReason) ? null : _chipReason.Trim()
            };

            var response = await ProfileApi.AddAccountChipsAsync(request);
            if (response.IsSuccessStatusCode && response.Content is not null)
            {
                _chipAmount = 500;
                _chipReason = null;
                _isAddChipsPopoverOpen = false;
                _pageNumber = 1;
                _addChipsMessage = response.Content.Message;
                await LoadAsync();
            }
            else
            {
                _addChipsMessage = "Failed to add chips. Please try again.";
                _addChipsMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to add account chips from cashier");
            _addChipsMessage = "Failed to add chips. Please try again.";
            _addChipsMessageIsError = true;
        }
        finally
        {
            _isSubmittingAddChips = false;
        }
    }

    private async Task LoadPreviousPageAsync()
    {
        if (!HasPreviousPage)
        {
            return;
        }

        _pageNumber = Math.Max(1, _pageNumber - 1);
        await LoadAsync();
    }

    private async Task LoadNextPageAsync()
    {
        if (!HasNextPage)
        {
            return;
        }

        _pageNumber += 1;
        await LoadAsync();
    }

    private async Task LoadFirstPageAsync()
    {
        if (!HasPreviousPage)
        {
            return;
        }

        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadLastPageAsync()
    {
        if (!HasNextPage)
        {
            return;
        }

        _pageNumber = TotalPages;
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(ChangeEventArgs args)
    {
        if (args.Value is not string rawValue || !int.TryParse(rawValue, out var pageSize))
        {
            return;
        }

        var normalizedPageSize = Math.Clamp(pageSize, 1, 100);
        if (_pageSize == normalizedPageSize)
        {
            return;
        }

        _pageSize = normalizedPageSize;
        _pageNumber = 1;
        await LoadAsync();
    }

    private static string GetDeltaClass(int delta)
    {
        if (delta > 0)
        {
            return "text-success";
        }

        if (delta < 0)
        {
            return "text-danger";
        }

        return "text-muted";
    }

    private static string FormatDelta(int delta)
    {
        return delta > 0 ? $"+{delta:N0}" : delta.ToString("N0");
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("g") ?? "-";
    }

    private static string FormatLedgerType(string? rawType)
    {
        if (string.IsNullOrWhiteSpace(rawType))
        {
            return "-";
        }

        return System.Text.RegularExpressions.Regex.Replace(
            rawType,
            "(?<=[a-z0-9])(?=[A-Z])|(?<=[A-Z])(?=[A-Z][a-z])",
            " ");
    }

    private static string FormatContext(CashierLedgerEntryDto entry)
    {
        if (string.IsNullOrWhiteSpace(entry.ReferenceType))
        {
            return "-";
        }

        return entry.ReferenceId.HasValue
            ? $"{entry.ReferenceType} ({entry.ReferenceId})"
            : entry.ReferenceType;
    }
}
