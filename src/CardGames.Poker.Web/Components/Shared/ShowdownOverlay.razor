    {
        return symbol switch
        {
            CardSymbol.Ace => 1,
            CardSymbol.Deuce => 2,
            CardSymbol.Three => 3,
            CardSymbol.Four => 4,
            CardSymbol.Five => 5,
            CardSymbol.Six => 6,
            CardSymbol.Seven => 7,
            CardSymbol.Eight => 8,
            CardSymbol.Nine => 9,
            CardSymbol.Ten => 10,
            CardSymbol.Jack => 11,
            CardSymbol.Queen => 12,
            CardSymbol.King => 13,
            _ => 99
        };
    }

    private static string GetRazzRankLabel(Card card)
    {
        return card.Symbol switch
        {
            Symbol.Ace => "Ace",
