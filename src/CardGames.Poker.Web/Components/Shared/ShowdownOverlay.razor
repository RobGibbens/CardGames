@using CardGames.Poker.Api.Contracts
@using CardGames.Core.Extensions
@using CardGames.Core.French.Cards
@using CardGames.Poker.Evaluation
@using CardGames.Poker.Hands
@using CardGames.Poker.Hands.HandTypes
@using CardGames.Poker.Hands.Strength
@using CardGames.Poker.Hands.DrawHands
@using CardGames.Poker.Hands.StudHands
@using CardGames.Contracts.SignalR

@using System.Globalization

<div class="table-overlay showdown-overlay" role="dialog" aria-modal="true" aria-label="Showdown results">
    <div class="overlay-content showdown-content @(ShowdownWon ? "showdown-won" : "")">
        <header class="showdown-header">
            <div class="showdown-header-main">
                <div class="showdown-icon" aria-hidden="true">
                    <i class="fa-solid fa-trophy"></i>
                </div>
                <div class="showdown-heading">
                    <h2 class="showdown-title">Showdown</h2>
                    <div class="showdown-subtitle">@GetOutcomeSubtitle()</div>
                </div>
            </div>
            <button type="button"
                    class="btn btn-link btn-sm showdown-close"
                    title="Close showdown"
                    aria-label="Close showdown"
                    @onclick="OnClose">
                <i class="fa-solid fa-xmark game-info-overlay-close-icon"></i>
            </button>
        </header>

        @if (ShowdownResult is null)
        {
            <p class="showdown-empty">No showdown data.</p>
        }
        else
        {
            var isRazz = IsRazzGame;
            var winnerHand = GetPrimaryWinnerHand(ShowdownResult);
            var otherHands = GetLoserHands(ShowdownResult, winnerHand);
            var sharedCommunityCards = SharedCommunityCards is { Count: > 0 }
                ? SharedCommunityCards
                : GetSharedCommunityCards(winnerHand);
            var winnerCards = winnerHand is not null ? GetDisplayCardsForShowdown(winnerHand, sharedCommunityCards, isRazz) : [];
            var winnerName = GetWinnerDisplayName(ShowdownResult, winnerHand);
            var winnerDescription = GetWinnerDescription(ShowdownResult, winnerHand, isRazz);
            var winnerAmount = GetWinnerAmount(ShowdownResult, winnerHand);
            var winnerVerb = GetWinnerVerb(ShowdownResult, winnerHand);

            <section class="showdown-stage" aria-label="Showdown summary">
                <section class="showdown-winner" aria-label="Winner">
                    <div class="winner-banner @(ShowdownWon ? "winner-banner-celebrate" : "")">
                        @if (ShowdownWon)
                        {
                            <div class="winner-celebration" aria-hidden="true">
                                <span class="winner-ribbon">Winner</span>
                                <i class="fa-solid fa-sparkles celebration-star celebration-star-left"></i>
                                <i class="fa-solid fa-sparkles celebration-star celebration-star-right"></i>
                                @for (var i = 0; i < 14; i++)
                                {
                                    <span class="celebration-confetti" style="--i:@i"></span>
                                }
                            </div>
                        }

                        <div class="winner-main">
                            <div class="winner-copy">

                                <div class="winner-headline">
                                    @if (ShowdownWon)
                                    {
                                        <span class="winner-crown" aria-hidden="true"><i class="fa-solid fa-crown"></i></span>
                                    }
                                    <h3 class="winner-first">@winnerName</h3>
                                    <span class="winner-rest">@winnerVerb</span>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(winnerDescription))
                                {
                                    <p class="winner-hand-callout">@winnerDescription</p>
                                }

                                @if (!string.IsNullOrWhiteSpace(winnerDescription) || winnerAmount > 0)
                                {
                                    <div class="winner-pills">
                                        @if (!string.IsNullOrWhiteSpace(winnerDescription))
                                        {
                                            <span class="sd-pill sd-pill-muted">Best hand</span>
                                        }
                                        @if (winnerAmount > 0)
                                        {
                                            <span class="sd-pill sd-pill-gold">+@winnerAmount chips</span>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="winner-illustration-shell" aria-hidden="true">
                                <div class="winner-illustration-frame">
                                    <img class="winner-illustration" src="@(ShowdownLost ? "/images/loser.png" : "/images/winner.png")" alt="" />
                                </div>
                            </div>
                        </div>

                        @if (winnerCards.Count > 0)
                        {
                            <div class="winner-hand-stage">
                                <div class="winner-hand-header">
                                    <span class="winner-hand-label">Winning cards</span>
                                    @if (!string.IsNullOrWhiteSpace(winnerDescription))
                                    {
                                        <span class="winner-hand-detail">@winnerDescription</span>
                                    }
                                </div>

                                <div class="showdown-cards winner-cards" aria-label="Winning cards">
                                    @for (var i = 0; i < winnerCards.Count; i++)
                                    {
                                        var (card, isWild) = winnerCards[i];
                                        <div class="sd-card-wrapper" style="--i:@i" @key="GetShowdownCardRenderKey(card, i, isWild)">
                                            <playing-card class="showdown-card showdown-card-winner" rank="@GetPlayingCardRank(card)" suit="@GetPlayingCardSuit(card)" suitcolor="@(isWild ? "green" : null)" rankcolor="@(isWild ? "green" : null)" courtcolor="@(isWild ? "green" : null)"></playing-card>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <div class="showdown-sidepanels">
                    @if (IsBobBarkerGame && ShowdownState?.BobBarker is { } bobBarker)
                    {
                        <section class="showdown-others showdown-others-showcase" aria-label="Bob Barker showcase results">
                            <div class="showdown-section-heading">
                                <h3 class="showdown-section-title">Showcase Results</h3>
                                <p class="showdown-section-subtitle">Dealer target and player showcase cards</p>
                            </div>

                            <div class="other-hand-row bob-barker-showcase-row">
                                <div class="bob-barker-showcase-item bob-barker-showcase-item-dealer">
                                    <div class="other-hand-info">
                                        <span class="other-hand-name">Dealer target</span>
                                    </div>
                                    @if (bobBarker.DealerCard is not null)
                                    {
                                        <div class="showdown-cards other-cards bob-barker-showcase-cards">
                                            <div>
                                                <playing-card class="showdown-card showdown-card-loser" rank="@bobBarker.DealerCard.Rank" suit="@bobBarker.DealerCard.Suit"></playing-card>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="bob-barker-showcase-spacer" aria-hidden="true"></div>

                                @foreach (var player in GetBobBarkerPlayers())
                                {
                                    <div class="bob-barker-showcase-item">
                                        <div class="other-hand-info">
                                            <span class="other-hand-name">@GetPlayerDisplayName(player)</span>
                                        </div>
                                        @if (player.ShowcaseCard is not null)
                                        {
                                            <div class="showdown-cards other-cards bob-barker-showcase-cards">
                                                <div>
                                                    <playing-card class="showdown-card showdown-card-loser" rank="@player.ShowcaseCard.Rank" suit="@player.ShowcaseCard.Suit"></playing-card>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (otherHands.Count > 0)
                    {
                        <section class="showdown-others showdown-others-grid" aria-label="Other hands">
                            <div class="showdown-section-heading">
                                <h3 class="showdown-section-title">Other Hands</h3>
                                <p class="showdown-section-subtitle">Every revealed hand remains visible for comparison</p>
                            </div>

                            @foreach (var hand in otherHands)
                            {
                                var handCards = GetDisplayCardsForShowdown(hand, sharedCommunityCards, isRazz);
                                <div class="other-hand-row">
                                    <div class="other-hand-info">
                                        <span class="other-hand-name">@DisplayFirstName(hand)</span>
                                        @if (hand.IsEliminatedByUgly == true)
                                        {
                                            <span class="sd-pill sd-pill-muted">Dead Hand (The Ugly)</span>
                                        }
                                        else if (isRazz || !string.IsNullOrWhiteSpace(hand.HandType) || !string.IsNullOrWhiteSpace(hand.HandDescription))
                                        {
                                            <span class="sd-pill sd-pill-muted">@GetDetailedHandDescription(hand, isRazz)</span>
                                        }
                                        @if (hand.AmountWon.GetValueOrDefault() > 0)
                                        {
                                            <span class="sd-pill sd-pill-gold">+@hand.AmountWon.GetValueOrDefault() chips</span>
                                        }
                                    </div>
                                    @if (handCards.Count > 0)
                                    {
                                        <div class="showdown-cards other-cards">
                                            @foreach (var (c, isWild) in handCards)
                                            {
                                                <div @key="GetShowdownCardRenderKey(c, hand.PlayerName, isWild)">
                                                    <playing-card class="showdown-card showdown-card-loser" rank="@GetPlayingCardRank(c)" suit="@GetPlayingCardSuit(c)" suitcolor="@(isWild ? "green" : null)" rankcolor="@(isWild ? "green" : null)" courtcolor="@(isWild ? "green" : null)"></playing-card>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </section>
                    }
                </div>
            </section>
        }

        <div class="showdown-countdown">
            @if (IsGameEnded)
            {
                <p class="showdown-hint">Returning to lobby in <strong>@SecondsUntilNextHand</strong> seconds...</p>
            }
            else if (SecondsUntilNextHand > 0)
            {
                <p class="showdown-hint">Next hand starts in <strong>@SecondsUntilNextHand</strong> seconds...</p>
            }
            else
            {
                <p class="showdown-hint">Starting next hand...</p>
            }
        </div>
    </div>
</div>

@code {
            [Parameter]
            public PerformShowdownSuccessful? ShowdownResult { get; set; }

            [Parameter]
            public bool ShowdownWon { get; set; }

            [Parameter]
            public bool ShowdownLost { get; set; }

            [Parameter]
            public int SecondsUntilNextHand { get; set; }

            [Parameter]
            public bool IsGameEnded { get; set; }

            [Parameter]
            public string? GameTypeCode { get; set; }

            [Parameter]
            public IReadOnlyList<TableCanvas.WildCardDisplay>? ActiveWildCards { get; set; }

            [Parameter]
            public IReadOnlyList<ShowdownCard>? SharedCommunityCards { get; set; }

            [Parameter]
            public ShowdownPublicDto? ShowdownState { get; set; }

            [Parameter]
            public EventCallback OnClose { get; set; }

    private bool IsRazzGame => string.Equals(GameTypeCode, "RAZZ", StringComparison.OrdinalIgnoreCase);
    private bool IsBobBarkerGame => string.Equals(GameTypeCode, "BOBBARKER", StringComparison.OrdinalIgnoreCase);
    private bool IsPairPressureGame => string.Equals(GameTypeCode, "PAIRPRESSURE", StringComparison.OrdinalIgnoreCase);

    private IEnumerable<ShowdownPlayerResultDto> GetBobBarkerPlayers()
    {
        return (ShowdownState?.PlayerResults ?? Enumerable.Empty<ShowdownPlayerResultDto>())
            .Where(player => player.ShowcaseCard is not null)
            .OrderByDescending(player => player.IsShowcaseWinner)
            .ThenByDescending(player => player.ShowcaseAmountWon)
            .ThenBy(player => player.PlayerName);
    }

    private List<(ShowdownCard Card, bool IsWild)> GetDisplayCardsForShowdown(
        ShowdownPlayerHand hand,
        IReadOnlyList<ShowdownCard>? sharedCommunityCards,
        bool isRazz)
    {
        var displayCards = GetDisplayCards(hand, sharedCommunityCards, isRazz);

        if (IsBobBarkerGame && !isRazz && displayCards.Count != 5)
        {
            displayCards = GetBobBarkerDisplayCards(hand, sharedCommunityCards, GetBobBarkerShowcaseCard(hand), displayCards);
        }

        return ApplyPairPressureWildHighlighting(displayCards);
    }

    private List<(ShowdownCard Card, bool IsWild)> ApplyPairPressureWildHighlighting(
        List<(ShowdownCard Card, bool IsWild)> displayCards)
    {
        if (!IsPairPressureGame || ActiveWildCards is not { Count: > 0 })
        {
            return displayCards;
        }

        return displayCards
            .Select(entry => (
                entry.Card,
                IsWild: WildCardDisplayMatcher.IsActiveWildCard(
                    GetPlayingCardRank(entry.Card),
                    GetPlayingCardSuit(entry.Card),
                    ActiveWildCards)))
            .ToList();
    }

    private ShowdownCard? GetBobBarkerShowcaseCard(ShowdownPlayerHand hand)
    {
        var showcaseCard = ShowdownState?.PlayerResults?
            .FirstOrDefault(player => string.Equals(player.PlayerName, hand.PlayerName, StringComparison.OrdinalIgnoreCase))?
            .ShowcaseCard;

        return ToShowdownCard(showcaseCard);
    }

    private static string GetPlayerDisplayName(ShowdownPlayerResultDto player)
    {
        return !string.IsNullOrWhiteSpace(player.PlayerFirstName)
            ? player.PlayerFirstName
            : GetDisplayNameFromPlayerName(player.PlayerName);
    }

    private static ShowdownPlayerHand? GetPrimaryWinnerHand(PerformShowdownSuccessful result)
    {
        if (result.PlayerHands is null || result.PlayerHands.Count == 0)
        {
            return null;
        }

        return result.PlayerHands
            .Where(h => h is not null)
            .Select(h => EnrichHand(h, result.Payouts))
            .OrderByDescending(h => h.IsWinner == true)
            .ThenByDescending(h => h.AmountWon ?? 0)
            .ThenByDescending(h => h.HandStrength ?? 0)
            .FirstOrDefault();
    }

    private static List<ShowdownPlayerHand> GetLoserHands(PerformShowdownSuccessful result, ShowdownPlayerHand? winner)
    {
        if (result.PlayerHands is null)
        {
            return [];
        }

        var hands = result.PlayerHands
            .Where(h => h is not null)
            .Select(h => EnrichHand(h, result.Payouts))
            .ToList();

        if (winner is not null)
        {
            var toRemove = hands.FirstOrDefault(h => h.PlayerName == winner.PlayerName);
            if (toRemove is not null)
            {
                hands.Remove(toRemove);
            }

            hands = hands.Where(h => h.IsWinner != true).ToList();
        }
        else
        {
            hands = hands.Where(h => h.IsWinner != true).ToList();
        }

        return hands
            .OrderByDescending(h => h.AmountWon ?? 0)
            .ThenBy(h => h.PlayerName)
            .ToList();
    }

    private static string GetWinnerDisplayName(PerformShowdownSuccessful result, ShowdownPlayerHand? winnerHand)
    {
        if (winnerHand is not null)
        {
            return DisplayFirstName(winnerHand);
        }

        if (result.Payouts is not null && result.Payouts.Count > 0)
        {
            var winnerName = result.Payouts.First().Key;
            if (!string.IsNullOrWhiteSpace(winnerName))
            {
                var matchingHand = result.PlayerHands?
                    .FirstOrDefault(h => string.Equals(h.PlayerName, winnerName, StringComparison.OrdinalIgnoreCase));

                if (matchingHand is not null)
                {
                    return DisplayFirstName(matchingHand);
                }

                return GetDisplayNameFromPlayerName(winnerName);
            }
        }

        return "Winner";
    }

    private static int GetWinnerAmount(PerformShowdownSuccessful result, ShowdownPlayerHand? winnerHand)
    {
        if (winnerHand?.AmountWon is > 0)
        {
            return winnerHand.AmountWon.Value;
        }

        if (result.Payouts is not null && result.Payouts.Count > 0)
        {
            return result.Payouts.First().Value;
        }

        return 0;
    }

    private static string GetWinnerDescription(PerformShowdownSuccessful result, ShowdownPlayerHand? winnerHand, bool isRazz)
    {
        if (winnerHand is not null)
        {
            return GetDetailedHandDescription(winnerHand, isRazz);
        }

        return result.WonByFold == true ? "Won by fold" : string.Empty;
    }

    private static string GetWinnerVerb(PerformShowdownSuccessful result, ShowdownPlayerHand? winnerHand)
    {
        if (result.WonByFold == true)
        {
            return "wins by fold";
        }

        if (IsDeckHand(winnerHand))
        {
            return "wins this hand";
        }

        return "wins the hand";
    }

    private static bool IsDeckHand(ShowdownPlayerHand? hand)
    {
        return string.Equals(hand?.PlayerName, "The Deck", StringComparison.OrdinalIgnoreCase);
    }

    private static IReadOnlyList<ShowdownCard> GetSharedCommunityCards(ShowdownPlayerHand? winnerHand)
    {
        // Community-card showdowns keep hole cards first, followed by shared board cards.
        if (winnerHand?.Cards is null || winnerHand.Cards.Count <= 2)
        {
            return [];
        }

        return winnerHand.Cards.Skip(2).ToList();
    }

    private static ShowdownPlayerHand EnrichHand(ShowdownPlayerHand hand, IDictionary<string, int>? payouts)
    {
        if (payouts is not null && payouts.TryGetValue(hand.PlayerName, out var amount))
        {
            // Always prefer the value in Payouts if it's larger (or if AmountWon is missing/zero)
            var current = hand.AmountWon ?? 0;
            if (amount > current)
            {
                return hand with { AmountWon = amount };
            }
        }
        return hand;
    }

    /// <summary>
    /// Gets the cards to display for a player's hand.
    /// For Seven Card Stud (7 cards), returns only the best 5 cards.
    /// Uses BestCardIndexes if provided by API, otherwise computes client-side.
    /// For other games, returns all cards sorted by symbol.
    /// </summary>
    private static List<(ShowdownCard Card, bool IsWild)> GetDisplayCards(ShowdownPlayerHand hand, IReadOnlyList<ShowdownCard>? sharedCommunityCards = null, bool isRazz = false)
    {
        if (hand.Cards is null || hand.Cards.Count == 0)
        {
            return [];
        }

        var cardsList = hand.Cards.ToList();

        // Some Hold the Baseball loser payloads contain only hole cards while BestCardIndexes
        // still reference hole+community indexes. Rehydrate with shared community cards so
        // every player shows the same board cards.
        var reconstructedCommunityCards = cardsList.Count == 2
            && sharedCommunityCards is { Count: > 0 }
            && ((hand.BestCardIndexes is not null && hand.BestCardIndexes.Any(idx => idx >= 2))
                || sharedCommunityCards.Count >= 3);

        if (reconstructedCommunityCards)
        {
            cardsList.AddRange(sharedCommunityCards!);
        }

        var wildSet = hand.WildCardIndexes is not null
            ? new HashSet<int>(hand.WildCardIndexes)
            : new HashSet<int>();

        // If BestCardIndexes is provided and valid, use only those cards.
        // Razz always computes client-side low cards because BestCardIndexes
        // may refer to a high-hand evaluation from other game variants.
        if (!isRazz && hand.BestCardIndexes is not null)
        {
            var validBestIndexes = hand.BestCardIndexes
                .Where(idx => idx >= 0 && idx < cardsList.Count)
                .Distinct()
                .ToList();

            if (validBestIndexes.Count == 5)
            {
                return validBestIndexes
                .Select(idx => (Card: cardsList[idx], IsWild: wildSet.Contains(idx)))
                .OrderBy(x => GetCardDisplayOrder(x.Card))
                .ToList();
            }
        }

        // For wild-card hands, show all cards to avoid incorrect best-5 selection client-side
        if (hand.WildCardIndexes is not null && hand.WildCardIndexes.Count > 0 && cardsList.Count > 5)
        {
            return cardsList
                .Select((c, i) => (Card: c, IsWild: wildSet.Contains(i)))
                .OrderBy(x => GetCardDisplayOrder(x.Card))
                .ToList();
        }

        if (isRazz && cardsList.Count >= 5)
        {
            var coreCards = cardsList
                .Where(c => c is { Suit: not null, Symbol: not null })
                .Select(c => new Card(MapSuit(c.Suit!.Value), MapSymbol(c.Symbol!.Value)))
                .ToList();

            if (coreCards.Count >= 5)
            {
                var razzHand = new RazzHand([], coreCards, []);
                var bestLowCards = razzHand.GetBestLowHand();

                var neededByLowValue = bestLowCards
                    .GroupBy(GetRazzDisplayValue)
                    .ToDictionary(g => g.Key, g => g.Count());

                var result = new List<(ShowdownCard Card, bool IsWild)>();

                // Prefer the earliest matching card instance from the original list so
                // duplicates (like two sixes) are selected predictably for display.
                for (var i = 0; i < cardsList.Count; i++)
                {
                    var showdownCard = cardsList[i];
                    if (showdownCard.Symbol is null)
                    {
                        continue;
                    }

                    var lowValue = GetRazzDisplayValue(showdownCard.Symbol.Value);
                    if (neededByLowValue.TryGetValue(lowValue, out var neededCount) && neededCount > 0)
                    {
                        result.Add((showdownCard, wildSet.Contains(i)));
                        neededByLowValue[lowValue] = neededCount - 1;
                    }
                }

                return result
                    .OrderBy(x => GetRazzDisplayValue(x.Card.Symbol ?? CardSymbol.Ace))
                    .ToList();
            }
        }

        // For 7-card hands (Seven Card Stud), compute best 5 cards client-side
        if (cardsList.Count == 7)
        {
            var coreCards = cardsList
                .Where(c => c is { Suit: not null, Symbol: not null })
                .Select(c => new Card(MapSuit(c.Suit!.Value), MapSymbol(c.Symbol!.Value)))
                .ToList();

            if (coreCards.Count == 7)
            {
                var studHand = new StudHand([], coreCards, []);
                var bestCards = studHand.GetBestHand();

                // Map back to ShowdownCards by matching suit and symbol
                // Use a list to track which cards have been used (to handle potential duplicates)
                var result = new List<(ShowdownCard Card, bool IsWild)>();
                var usedIndexes = new HashSet<int>();

                foreach (var bc in bestCards)
                {
                    for (var i = 0; i < cardsList.Count; i++)
                    {
                        if (usedIndexes.Contains(i))
                        {
                            continue;
                        }

                        var sc = cardsList[i];
                        if (sc.Suit.HasValue && sc.Symbol.HasValue &&
                            MapSuit(sc.Suit.Value) == bc.Suit &&
                            MapSymbol(sc.Symbol.Value) == bc.Symbol)
                        {
                            result.Add((sc, wildSet.Contains(i)));
                            usedIndexes.Add(i);
                            break;
                        }
                    }
                }

                return result.OrderBy(x => x.Card.Symbol).ToList();
            }
        }

        // Fall back to showing all cards (for 5-card games)
        return cardsList
            .Select((c, i) => (Card: c, IsWild: wildSet.Contains(i)))
            .OrderBy(x => x.Card.Symbol)
            .ToList();
    }

    private static List<(ShowdownCard Card, bool IsWild)> GetBobBarkerDisplayCards(
        ShowdownPlayerHand hand,
        IReadOnlyList<ShowdownCard>? sharedCommunityCards,
        ShowdownCard? showcaseCard,
        List<(ShowdownCard Card, bool IsWild)> fallbackCards)
    {
        if (hand.Cards is null || hand.Cards.Count == 0)
        {
            return [];
        }

        var allCards = hand.Cards.ToList();
        var communityCards = sharedCommunityCards?.ToList() ?? [];
        var playerCards = allCards;
        var hasValidSharedSuffix = communityCards.Count == 5 && CardsEndWith(allCards, communityCards);

        if (hasValidSharedSuffix)
        {
            playerCards = allCards.Take(allCards.Count - communityCards.Count).ToList();
        }
        else if (allCards.Count >= 9)
        {
            communityCards = allCards.Skip(5).ToList();
            playerCards = allCards.Take(5).ToList();
        }

        if (showcaseCard is { } showcase)
        {
            var showcaseIndex = playerCards.FindIndex(card => CardsMatch(card, showcase));
            if (showcaseIndex >= 0)
            {
                playerCards.RemoveAt(showcaseIndex);
            }
        }

        if (playerCards.Count != 4 || communityCards.Count < 3)
        {
            return fallbackCards;
        }

        var holeCards = playerCards
            .Where(card => card is { Suit: not null, Symbol: not null })
            .Select(card => (Card: card, Core: new Card(MapSuit(card.Suit!.Value), MapSymbol(card.Symbol!.Value))))
            .ToList();
        var boardCards = communityCards
            .Where(card => card is { Suit: not null, Symbol: not null })
            .Select(card => (Card: card, Core: new Card(MapSuit(card.Suit!.Value), MapSymbol(card.Symbol!.Value))))
            .ToList();

        if (holeCards.Count != 4 || boardCards.Count < 3)
        {
            return fallbackCards;
        }

        List<(ShowdownCard Card, Card Core)>? bestCombo = null;
        long bestStrength = long.MinValue;

        foreach (var holePair in holeCards.SubsetsOfSize(2))
        {
            foreach (var communityTriple in boardCards.SubsetsOfSize(3))
            {
                var combo = holePair.Concat(communityTriple).ToList();
                var coreCards = combo.Select(entry => entry.Core).ToList();
                var handType = HandTypeDetermination.DetermineHandType(coreCards);
                var strength = HandStrength.Calculate(coreCards, handType, HandTypeStrengthRanking.Classic);

                if (strength > bestStrength)
                {
                    bestStrength = strength;
                    bestCombo = combo;
                }
            }
        }

        return bestCombo is null
            ? fallbackCards
            : bestCombo
                .Select(entry => (entry.Card, IsWild: false))
                .OrderBy(entry => GetCardDisplayOrder(entry.Card))
                .ToList();
    }

    private static bool CardsEndWith(IReadOnlyList<ShowdownCard> cards, IReadOnlyList<ShowdownCard> suffix)
    {
        if (suffix.Count == 0 || cards.Count < suffix.Count)
        {
            return false;
        }

        var offset = cards.Count - suffix.Count;
        for (var i = 0; i < suffix.Count; i++)
        {
            if (!CardsMatch(cards[offset + i], suffix[i]))
            {
                return false;
            }
        }

        return true;
    }

    private static bool CardsMatch(ShowdownCard left, ShowdownCard right)
    {
        return left.Suit == right.Suit && left.Symbol == right.Symbol;
    }

    private static ShowdownCard? ToShowdownCard(CardPublicDto? card)
    {
        if (card is null || !TryMapPublicSuit(card.Suit, out var suit) || !TryMapPublicRank(card.Rank, out var symbol))
        {
            return null;
        }

        return new ShowdownCard(suit, symbol);
    }

    private static bool TryMapPublicSuit(string? suit, out CardSuit mappedSuit)
    {
        mappedSuit = suit?.Trim() switch
        {
            "Hearts" => CardSuit.Hearts,
            "Diamonds" => CardSuit.Diamonds,
            "Clubs" => CardSuit.Clubs,
            "Spades" => CardSuit.Spades,
            _ => default
        };

        return suit is "Hearts" or "Diamonds" or "Clubs" or "Spades";
    }

    private static bool TryMapPublicRank(string? rank, out CardSymbol mappedSymbol)
    {
        mappedSymbol = rank?.Trim().ToUpperInvariant() switch
        {
            "A" or "ACE" => CardSymbol.Ace,
            "K" or "KING" => CardSymbol.King,
            "Q" or "QUEEN" => CardSymbol.Queen,
            "J" or "JACK" => CardSymbol.Jack,
            "10" => CardSymbol.Ten,
            "9" => CardSymbol.Nine,
            "8" => CardSymbol.Eight,
            "7" => CardSymbol.Seven,
            "6" => CardSymbol.Six,
            "5" => CardSymbol.Five,
            "4" => CardSymbol.Four,
            "3" => CardSymbol.Three,
            "2" => CardSymbol.Deuce,
            _ => default
        };

        return rank?.Trim().ToUpperInvariant() is "A" or "ACE"
            or "K" or "KING"
            or "Q" or "QUEEN"
            or "J" or "JACK"
            or "10"
            or "9"
            or "8"
            or "7"
            or "6"
            or "5"
            or "4"
            or "3"
            or "2";
    }

