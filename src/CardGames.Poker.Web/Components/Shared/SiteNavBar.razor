@namespace CardGames.Poker.Web.Components.Shared
@rendermode InteractiveServer
@inherits ThemeToggleComponentBase

@inject IServiceScopeFactory ServiceScopeFactory

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Http.Extensions
@using Microsoft.Extensions.DependencyInjection
@using CardGames.Poker.Web.Data
@using System.Security.Claims

<!-- Navigation Header -->
<header class="nav-header">
    <nav class="nav-container">
        <a href="/" class="nav-logo">
            <span class="nav-logo-icon"><i class="fa-thin fa-spade"></i></span>
            <span>Dealer's Choice Poker</span>
        </a>

        <ul class="nav-links @(isMobileMenuOpen ? "active" : "")" id="navLinks">
            <li><a href="/lobby">Lobby</a></li>
            <li><a href="/leagues">Leagues</a></li>
            <li><a href="/account/cashier">Cashier</a></li>
        </ul>

        <div class="nav-actions">
            <button class="theme-toggle" @onclick="ToggleThemeAsync" title="@ThemeToggleTitle" aria-label="@ThemeToggleAriaLabel">
                <span><i class="@ThemeIconClass"></i></span>
            </button>

            <AuthorizeView>
                <Authorized>
                    <div class="user-menu">
                        <button class="user-menu-trigger" @onclick="ToggleUserMenu" @onclick:stopPropagation="true">
                            <span class="user-avatar">
                                @if (!string.IsNullOrWhiteSpace(CurrentUserAvatarUrl))
                                {
                                    <img class="user-avatar-img" src="@CurrentUserAvatarUrl" alt="" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    @UserProfileDisplayHelpers.GetUserInitial(CurrentUserName ?? context.User.Identity?.Name)
                                }
                            </span>
                            <span class="user-name">@(CurrentUserName ?? context.User.Identity?.Name)</span>
                            <span class="user-menu-arrow"><i class="fa-solid fa-angle-down"></i></span>
                        </button>
                        @if (isUserMenuOpen)
                        {
                            <div class="user-menu-dropdown">
                                <a href="/Account/Manage" class="user-menu-item">
                                    <i class="fa-thin fa-gear"></i> Settings
                                </a>
                                <a href="/Account/Manage/Email" class="user-menu-item">
                                    <i class="fa-thin fa-envelope"></i> Email
                                </a>
                                <a href="/Account/Manage" class="user-menu-item">
                                    <i class="fa-thin fa-user"></i> Profile
                                </a>
                                <a href="/Account/Cashier" class="user-menu-item">
                                    <i class="fa-thin fa-cash-register"></i> Cashier
                                </a>
                                <hr class="user-menu-divider" />
                                <form method="post" action="/Account/Logout">
                                    <AntiforgeryToken />
                                    <input type="hidden" name="ReturnUrl" value="@GetReturnUrl()" />
                                    <button type="submit" class="user-menu-item user-menu-logout">
                                        <i class="fa-solid fa-right-from-bracket"></i> Sign Out
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/Account/Login" class="btn btn-secondary btn-sm">Sign In</a>
                    <a href="/Account/Register" class="btn btn-primary btn-sm">Get Started</a>
                </NotAuthorized>
            </AuthorizeView>

            <button class="mobile-menu-toggle" @onclick="ToggleMobileMenu" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>
</header>

@code {
    private bool isMobileMenuOpen;
    private bool isUserMenuOpen;

    private string? loadedUserId;
    private string? CurrentUserAvatarUrl;
    private string? CurrentUserName;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string GetReturnUrl()
    {
        var pathAndQuery = HttpContext?.Request.GetEncodedPathAndQuery();
        return string.IsNullOrWhiteSpace(pathAndQuery) ? string.Empty : pathAndQuery.TrimStart('/');
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        var userId = UserProfileDisplayHelpers.GetUserId(principal);
        if (string.IsNullOrWhiteSpace(userId))
        {
            loadedUserId = null;
            CurrentUserAvatarUrl = null;
            CurrentUserName = null;
            return;
        }

        loadedUserId = userId;

        var user = await LoadUserAsync(principal);
        CurrentUserName = UserProfileDisplayHelpers.PreferFirstName(user?.FirstName) ?? principal.Identity?.Name;
        CurrentUserAvatarUrl = UserProfileDisplayHelpers.BuildAvatarApiPath(userId);
    }

    private async Task<ApplicationUser?> LoadUserAsync(ClaimsPrincipal principal)
    {
        await using var scope = ServiceScopeFactory.CreateAsyncScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        return await userManager.GetUserAsync(principal);
    }

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
    }

    private void ToggleUserMenu()
    {
        isUserMenuOpen = !isUserMenuOpen;
    }

}
