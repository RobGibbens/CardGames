@namespace CardGames.Poker.Web.Components.Shared

@using CardGames.Contracts.SignalR
@using Microsoft.JSInterop
@using static CardGames.Poker.Web.Components.Pages.TablePlay

@inject IJSRuntime JSRuntime

<div @ref="_panelRef" class="draw-panel @(IsSubmitting ? "submitting" : "") @(IsAnimating ? "animating" : "") @(IsReadOnly ? "read-only" : "")">
    <!-- Header (also serves as drag handle) -->
    <div @ref="_handleRef" class="draw-panel-header drag-handle">
        <div class="draw-panel-title">
            <i class="@TitleIcon"></i>
            <span>@Title</span>
        </div>
        <div class="draw-panel-subtitle">
            @if (!string.IsNullOrWhiteSpace(DrawingSpecialRules))
            {
                <text>@DrawingSpecialRules</text>
            }
            else if (MinDiscards > 0 && MinDiscards == MaxDiscards)
            {
                <text>Select exactly @MinDiscards cards to discard</text>
            }
            else if (MinDiscards > 0 && MinDiscards < MaxDiscards)
            {
                <text>Select @MinDiscards–@MaxDiscards cards to discard</text>
            }
            else if (MaxDiscards == 4)
            {
                <text>Select cards to discard (0-4 cards - Ace bonus!)</text>
            }
            else if (!IsReadOnly)
            {
                <text>Select cards to discard (0-@MaxDiscards cards)</text>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(HandDescription))
        {
            <div class="hand-eval-text">@HandDescription</div>
        }
    </div>

    <!-- Turn timer -->
    @if (!IsReadOnly)
    {
        <div class="draw-turn-timer">
            <div class="draw-timer-bar">
                <div class="draw-timer-fill" style="width: @GetTimerPercentage()%"></div>
            </div>
            <span class="draw-timer-text">@GetSecondsRemaining() s</span>
        </div>
    }

    <!-- Cards Display -->
    <div class="draw-cards-container">
        @{
            var orderedCards = GetOrderedCards().ToList();
            var hasExplicitWildFlags = Cards.Any(c => c.IsWild);
            var lowestNonKingRankValueForWild = EnableKingsAndLowsWildCardHighlighting
                ? GetLowestNonKingRankValueForWild(Cards)
                : null;
        }

        @for (var i = 0; i < orderedCards.Count; i++)
        {
            var displayIndex = i;
            var index = orderedCards[i].Index;
            var card = orderedCards[i].Card;
            var isSelected = SelectedIndices.Contains(index);
            var isWildForDisplay = IsWildForDisplay(card, lowestNonKingRankValueForWild, EnableKingsAndLowsWildCardHighlighting, hasExplicitWildFlags);

            <div class="draw-card-wrapper @(isSelected ? "selected" : "") @(IsDiscarding && isSelected ? "discarding" : "") @(IsDrawing && NewCardIndices.Contains(index) ? "drawing" : "") @(IsReadOnly ? "readonly" : "")"
                 @key="GetCardRenderKey(card, index)"
                 @onclick="() => ToggleCardSelectionAsync(index)"
                 @onclick:stopPropagation="@IsReadOnly">

                <div class="draw-card @(isSelected ? "selected" : "")">
                    <playing-card rank="@GetPlayingCardRank(card)" suit="@card.Suit" style="height:92px;width:64px;" suitcolor="@(isWildForDisplay ? "green" : null)" rankcolor="@(isWildForDisplay ? "green" : null)" courtcolor="@(isWildForDisplay ? "green" : null)"></playing-card>
                </div>

                @if (!HideCardIndices)
                {
                    <div class="card-index">@(displayIndex + 1)</div>
                }
                @if (isSelected)
                {
                    <div class="discard-badge">
                        <i class="fa-solid fa-xmark"></i>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Selection Info -->
    <div class="draw-selection-info">
        @if (IsReadOnly && !string.IsNullOrWhiteSpace(ReadOnlyMessage))
        {
            <span class="selection-hint">@ReadOnlyMessage</span>
        }
        else if (SelectedCount == 0)
        {
            @if (MinDiscards > 0 && MinDiscards == MaxDiscards)
            {
                <span class="selection-hint">You must discard exactly @MinDiscards card(s)</span>
            }
            else if (MinDiscards > 0)
            {
                <span class="selection-hint">Select @MinDiscards to @MaxDiscards cards to discard</span>
            }
            else
            {
                <span class="selection-hint">Click cards to select them for discard, or stand pat</span>
            }
        }
        else
        {
            <span class="selection-count">@SelectedCount card(s) selected for discard</span>
        }
    </div>

    <!-- Action Buttons (hidden in read-only mode) -->
    @if (!IsReadOnly)
    {
        <div class="draw-actions">
            @if (MinDiscards == 0)
            {
                <button class="draw-btn stand-pat-btn" 
                        @onclick="HandleStandPat" 
                        disabled="@(IsSubmitting || SelectedCount > 0)">
                    <i class="fa-regular fa-hand"></i>
                    <span>@StandPatLabel</span>
                </button>
            }

                    <button class="draw-btn discard-btn @(SelectedCount > 0 ? "active" : "")" 
                            @onclick="HandleDiscard" 
                            disabled="@(IsSubmitting || SelectedCount == 0 || SelectedCount > MaxDiscards || SelectedCount < MinDiscards)">
                        <i class="fa-regular fa-arrows-rotate"></i>
                        @if (MinDiscards > 0 && MinDiscards == MaxDiscards)
                        {
                            <span>@DiscardLabel @SelectedCount</span>
                        }
                        else
                        {
                            <span>@DiscardLabel @SelectedCount & Draw</span>
                        }
                    </button>
                </div>

                @if (SelectedCount > MaxDiscards)
                {
                    <div class="draw-warning">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        @if (MaxDiscards == 4)
                        {
                            <text>Maximum 4 cards can be discarded when you hold an Ace</text>
                        }
                        else
                        {
                            <text>Maximum @MaxDiscards cards can be discarded</text>
                        }
                    </div>
                }
                else if (SelectedCount > 0 && SelectedCount < MinDiscards)
                {
                    <div class="draw-warning">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <text>You must select at least @MinDiscards cards to discard</text>
                    </div>
                }
            }

            @if (IsSubmitting)
    {
        <div class="draw-submitting">
           
            @if (IsDiscarding)
            {
                <span class="loading-spinner-small"></span>
                <span>Discarding cards...</span>
            }
            else if (CardsDrawn)
            {
                <span>New cards drawn...</span>
            }
            else if (IsDrawing)
            {
                <span class="loading-spinner-small"></span>
                <span>Drawing new cards...</span>
            }
            else
            {
                <span class="loading-spinner-small"></span>
                <span>Processing...</span>
            }
        </div>
    }
</div>

@code {
    private const int DefaultTimerDurationSeconds = 60;
    private const string PanelStorageKey = "cardGames.panelPosition.drawPanel";
    private string? _autoActionTimerKey;
    private bool _isAutoActionInFlight;
    private string? _lastCardsKey;
    private bool _cardsChangedWhileBusy;

    private ElementReference _panelRef;
    private ElementReference _handleRef;
    private bool _dragInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_dragInitialized)
        {
            _dragInitialized = true;
            await JSRuntime.InvokeVoidAsync("draggablePanel.init", _panelRef, _handleRef, PanelStorageKey);
        }
    }

    [Parameter]
    public List<CardInfo> Cards { get; set; } = [];

    [Parameter]
    public string? HandDescription { get; set; }

    [Parameter]
    public HashSet<int> SelectedIndices { get; set; } = [];

    [Parameter]
    public EventCallback<int> OnToggleSelection { get; set; }

    [Parameter]
    public EventCallback<List<int>> OnDraw { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public bool IsAnimating { get; set; }

    [Parameter]
    public bool IsDiscarding { get; set; }

    [Parameter]
    public bool IsDrawing { get; set; }

    [Parameter]
    public bool CardsDrawn { get; set; }

    [Parameter]
    public List<int> NewCardIndices { get; set; } = [];

    [Parameter]
    public int MaxDiscards { get; set; } = 3;

    /// <summary>
    /// Minimum number of cards that must be discarded. When > 0, stand pat is disabled.
    /// When MinDiscards == MaxDiscards, the discard button omits "&amp; Draw" label.
    /// </summary>
    [Parameter]
    public int MinDiscards { get; set; } = 0;

    [Parameter]
    public string? DrawingSpecialRules { get; set; }

    /// <summary>
    /// Custom title for the panel header. Defaults to "Draw Phase".
    /// </summary>
    [Parameter]
    public string Title { get; set; } = "Draw Phase";

    /// <summary>
    /// Custom icon class for the header. Defaults to "fa-regular fa-cards".
    /// </summary>
    [Parameter]
    public string TitleIcon { get; set; } = "fa-regular fa-cards";

    /// <summary>
    /// Custom label for the stand pat button. Defaults to "Stand Pat".
    /// </summary>
    [Parameter]
    public string StandPatLabel { get; set; } = "Stand Pat";

    /// <summary>
    /// Custom label for the discard button (without count). Defaults to "Discard".
    /// </summary>
    [Parameter]
    public string DiscardLabel { get; set; } = "Discard";

    /// <summary>
    /// When true, hides action buttons and shows cards in read-only mode.
    /// Used for showing deck cards to non-decision makers.
    /// </summary>
    [Parameter]
    public bool IsReadOnly { get; set; }

    /// <summary>
    /// Optional message to show in read-only mode (e.g., "Waiting for Player to decide...").
    /// </summary>
    [Parameter]
    public string? ReadOnlyMessage { get; set; }

    /// <summary>
    /// When true, hides the card index numbers below cards.
    /// Useful for non-decision makers viewing the deck hand.
    /// </summary>
    [Parameter]
    public bool HideCardIndices { get; set; }

    /// <summary>
    /// The action timer state from SignalR.
    /// </summary>
    [Parameter]
    public ActionTimerStateDto? ActionTimer { get; set; }

    /// <summary>
    /// Enables Kings and Lows wild card highlighting logic (kings + lowest non-king rank).
    /// Keep false for other game types.
    /// </summary>
    [Parameter]
    public bool EnableKingsAndLowsWildCardHighlighting { get; set; }

    private int SelectedCount => SelectedIndices.Count;

    protected override async Task OnParametersSetAsync()
    {
        ClearStaleSelectionIfNeeded();
        await TrySubmitTimeoutDefaultActionAsync();
    }

    private void ClearStaleSelectionIfNeeded()
    {
        var cardsKey = ComputeCardsKey();
        var cardsChanged = _lastCardsKey is not null
            && !string.Equals(_lastCardsKey, cardsKey, StringComparison.Ordinal);
        var isBusy = IsSubmitting || IsAnimating || IsDiscarding || IsDrawing;

        if (SelectedIndices.Count > 0 && (Cards.Count == 0 || SelectedIndices.Any(i => i < 0 || i >= Cards.Count)))
        {
            SelectedIndices.Clear();
            _cardsChangedWhileBusy = false;
        }
        else if (SelectedIndices.Count > 0 && cardsChanged)
        {
            if (isBusy)
            {
                _cardsChangedWhileBusy = true;
            }
            else
            {
                SelectedIndices.Clear();
                _cardsChangedWhileBusy = false;
            }
        }
        else if (SelectedIndices.Count > 0 && !isBusy && _cardsChangedWhileBusy)
        {
            SelectedIndices.Clear();
            _cardsChangedWhileBusy = false;
        }
        else if (!isBusy)
        {
            _cardsChangedWhileBusy = false;
        }

        _lastCardsKey = cardsKey;
    }

    private static string GetCardRenderKey(CardInfo card, int index)
    {
        return $"{index}:{card.DealOrder}:{card.Rank}:{card.Suit}:{card.IsWild}";
    }

    private string ComputeCardsKey()
    {
        return string.Join("|", Cards.Select(c => $"{c.DealOrder}:{c.Rank}:{c.Suit}"));
    }

    private int GetSecondsRemaining()
    {
        return ActionTimer?.SecondsRemaining ?? DefaultTimerDurationSeconds;
    }

    private int GetTimerDuration()
    {
        return ActionTimer?.DurationSeconds ?? DefaultTimerDurationSeconds;
    }

    private double GetTimerPercentage()
    {
        var duration = GetTimerDuration();
        if (duration <= 0) return 100;
        return (GetSecondsRemaining() / (double)duration) * 100;
    }

    private async Task ToggleCardSelectionAsync(int index)
    {
        if (IsReadOnly || IsSubmitting || IsAnimating)
            return;

        if (OnToggleSelection.HasDelegate)
        {
            await OnToggleSelection.InvokeAsync(index);
        }
    }

    private async Task HandleStandPat()
    {
        if (IsReadOnly || IsSubmitting || SelectedCount > 0 || MinDiscards > 0)
            return;

        await OnDraw.InvokeAsync([]);
    }

    private async Task HandleDiscard()
    {
        if (IsSubmitting || SelectedCount == 0 || SelectedCount > MaxDiscards || SelectedCount < MinDiscards)
            return;

        var selectedIndices = Cards
            .Select((c, i) => (Card: c, Index: i))
            .Where(x => SelectedIndices.Contains(x.Index))
            .Select(x => x.Index)
            .ToList();

        await OnDraw.InvokeAsync(selectedIndices);
    }

    private async Task TrySubmitTimeoutDefaultActionAsync()
    {
        if (ActionTimer is null || !ActionTimer.IsActive || ActionTimer.SecondsRemaining > 0 || IsReadOnly)
        {
            _autoActionTimerKey = null;
            return;
        }

        if (IsSubmitting || IsAnimating || _isAutoActionInFlight)
        {
            return;
        }

        var timerKey = $"{ActionTimer.PlayerSeatIndex}:{ActionTimer.StartedAtUtc.UtcTicks}";
        if (_autoActionTimerKey == timerKey)
        {
            return;
        }

        _autoActionTimerKey = timerKey;
        _isAutoActionInFlight = true;

        try
        {
            await OnDraw.InvokeAsync([]);
        }
        finally
        {
            _isAutoActionInFlight = false;
        }
    }

    private static string GetSuitColorClass(string? suit)
    {
        return suit?.ToLower() switch
        {
            "hearts" or "diamonds" => "suit-red",
            _ => "suit-black"
        };
    }

    private static string GetSuitSymbol(string? suit)
    {
        return suit?.ToLower() switch
        {
            "hearts" => "fa-heart",
            "diamonds" => "fa-diamond",
            "clubs" => "fa-club",
            "spades" => "fa-spade",
            _ => "fa-question"
        };
    }

    private IEnumerable<IndexedCard> GetOrderedCards()
    {
        if (Cards.Count == 0)
        {
            return [];
        }

        // Sort known face-up cards by value (2..A). Keep unknown/blank ranks stable.
        return Cards
            .Select((card, index) => new IndexedCard(card, index))
            .OrderBy(x => string.IsNullOrWhiteSpace(x.Card.Rank) ? 1 : 0)
            .ThenBy(x => GetRankValue(x.Card.Rank))
            .ThenBy(x => GetSuitValue(x.Card.Suit))
            .ThenBy(x => x.Index);
    }

    private string? GetPlayingCardRank(CardInfo card)
    {
        var rank = card.Rank switch
        {
            "J" => "Jack",
            "Q" => "Queen",
            "K" => "King",
            "A" => "Ace",
            _ => card.Rank
        };

        return rank;
    }
    
    private static int GetRankValue(string? rank)
    {
        if (string.IsNullOrWhiteSpace(rank))
        {
            return int.MaxValue;
        }

        return rank.Trim().ToUpperInvariant() switch
        {
            "2" or "TWO" or "DEUCE" => 2,
            "3" or "THREE" => 3,
            "4" or "FOUR" => 4,
            "5" or "FIVE" => 5,
            "6" or "SIX" => 6,
            "7" or "SEVEN" => 7,
            "8" or "EIGHT" => 8,
            "9" or "NINE" => 9,
            "10" or "T" or "TEN" => 10,
            "J" or "JACK" => 11,
            "Q" or "QUEEN" => 12,
            "K" or "KING" => 13,
            "A" or "ACE" => 14,
            _ => int.MaxValue
        };
    }

    private static int GetSuitValue(string? suit)
    {
        if (string.IsNullOrWhiteSpace(suit))
        {
            return int.MaxValue;
        }

        return suit.Trim().ToLowerInvariant() switch
        {
            "clubs" or "c" => 0,
            "diamonds" or "d" => 1,
            "hearts" or "h" => 2,
            "spades" or "s" => 3,
            _ => int.MaxValue
                };
            }

    private static bool IsWildForDisplay(CardInfo card, int? lowestNonKingRankValue, bool enableKingsAndLowsWildCardHighlighting, bool hasExplicitWildFlags)
    {
        if (card.IsWild)
        {
            return true;
        }

        if (hasExplicitWildFlags)
        {
            return false;
        }

        if (!enableKingsAndLowsWildCardHighlighting)
        {
            return false;
        }

        var rankValue = GetRankValue(card.Rank);
        if (rankValue == 13)
        {
            return true;
        }

        return lowestNonKingRankValue.HasValue && rankValue == lowestNonKingRankValue.Value;
    }

    private static int? GetLowestNonKingRankValueForWild(IReadOnlyList<CardInfo> cards)
    {
        var lowest = cards
            .Where(c => !string.IsNullOrWhiteSpace(c.Rank))
            .Select(c => GetRankValue(c.Rank))
            .Where(value => value != int.MaxValue && value != 13)
            .DefaultIfEmpty(int.MaxValue)
            .Min();

        return lowest == int.MaxValue ? null : lowest;
    }

            private sealed record IndexedCard(CardInfo Card, int Index);
        }
