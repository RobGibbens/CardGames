@namespace CardGames.Poker.Web.Components.Shared

@using CardGames.Poker.Api.Contracts

<div class="table-overlay dealer-choice-overlay">
	<div class="dealer-choice-modal">
		<div class="dealer-choice-header">
			<div class="dealer-choice-icon"><i class="fa-thin fa-cards"></i></div>
			<h2>Dealer's Choice</h2>
			<p>You're the dealer! Pick a game variant for this hand.</p>
		</div>

		@if (_isLoading)
		{
			<div class="dealer-choice-loading">
				<div class="loading-spinner"></div>
				<p>Loading variants...</p>
			</div>
		}
		else
		{
		   <div class="dealer-choice-search dc-setting">
			   <label for="dc-search">Search Variants</label>
			   <input type="text"
					  id="dc-search"
					  placeholder="Search by game name"
					  @bind="_variantSearch"
					  @bind:event="oninput" />
		   </div>

			<!-- Variant Grid -->
			<div class="dealer-choice-variants">
				@foreach (var group in VariantGroups)
				{
					if (group.Games.Count == 0)
					{
						continue;
					}

					<section class="dealer-choice-variant-group">
						<h3 class="dc-variant-group-title">@group.Title</h3>
						@foreach (var game in group.Games)
						{
							<button class="dealer-choice-variant @(_selectedCode == game.Code ? "selected" : "")"
									@onclick="() => SelectVariant(game.Code, game.Name)">
								<span class="dc-variant-name">@game.Name</span>
								<span class="dc-variant-desc">@game.Description</span>
								@if (_selectedCode == game.Code)
								{
									<span class="dc-variant-check"><i class="fa-solid fa-check"></i></span>
								}
							</button>
						}
					</section>
				}
			</div>

			<!-- Ante / Min Bet -->
			@if (_selectedCode is not null)
			{
				<div class="dealer-choice-settings animate-fade-in-up">
					@if (IsBlindBasedGame(_selectedCode))
					{
						<div class="dc-setting">
							<label for="dc-sb">Small Blind</label>
							<input type="number" id="dc-sb" min="1" max="500"
								   @bind-value="_smallBlind" @bind-value:event="oninput" />
						</div>
						<div class="dc-setting">
							<label for="dc-bb">Big Blind</label>
							<input type="number" id="dc-bb" min="1" max="1000"
								   @bind-value="_bigBlind" @bind-value:event="oninput" />
						</div>
					}
					else
					{
						<div class="dc-setting">
							<label for="dc-ante">Ante</label>
							<input type="number" id="dc-ante" min="0" max="100"
								   @bind-value="_ante" @bind-value:event="oninput" />
						</div>
						<div class="dc-setting">
							<label for="dc-minbet">Min Bet</label>
							<input type="number" id="dc-minbet" min="1" max="1000"
								   @bind-value="_minBet" @bind-value:event="oninput" />
						</div>
					}
				</div>

				<button class="btn btn-primary btn-lg dealer-choice-confirm"
						@onclick="ConfirmChoiceAsync"
						disabled="@(_isSubmitting || (IsBlindBasedGame(_selectedCode) ? _bigBlind < 1 : _minBet < 1))">
					@if (_isSubmitting)
					{
						<span class="loading-spinner-small"></span>
						<span>Confirming...</span>
					}
					else
					{
						<i class="fa-regular fa-check"></i>
						<span>Deal @_selectedName</span>
					}
				</button>
			}

			@if (_error is not null)
			{
				<div class="dealer-choice-error">
					<i class="fa-regular fa-circle-exclamation"></i> @_error
				</div>
			}
		}
	</div>
</div>

@code {
	[Parameter, EditorRequired]
	public IReadOnlyList<GetAvailablePokerGamesResponse> AvailableGames { get; set; } = [];

	[Parameter, EditorRequired]
	public bool IsLoading { get; set; }

	[Parameter, EditorRequired]
	public EventCallback<DealerChoiceSelection> OnGameChosen { get; set; }

	private string? _selectedCode;
	private string? _selectedName;
	private int _ante = 5;
	private int _minBet = 10;
	private int _smallBlind = 5;
	private int _bigBlind = 10;
 private string _variantSearch = string.Empty;
	private bool _isSubmitting;
	private bool _isLoading;
	private string? _error;

	private const string HoldEmVariantsTitle = "Hold 'Em variants";
	private const string DrawVariantsTitle = "Draw variants";
	private const string StudVariantsTitle = "Stud variants";
	private const string OtherVariantsTitle = "Other variants";

	private IEnumerable<VariantGroup> VariantGroups
	{
		get
		{
			var games = AvailableGames
               .Where(g => _selectedCode is not null
					? g.Code == _selectedCode
					: MatchesVariantSearch(g.Name))
				.OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase);

			return new[]
			{
				CreateGroup(HoldEmVariantsTitle, games, VariantType.HoldEm),
				CreateGroup(DrawVariantsTitle, games, VariantType.Draw),
				CreateGroup(StudVariantsTitle, games, VariantType.Stud),
				CreateGroup(OtherVariantsTitle, games, VariantType.Other)
			};
		}
	}

	protected override void OnParametersSet()
	{
		_isLoading = IsLoading;
	}

	private void SelectVariant(string code, string name)
	{
		if (_selectedCode == code)
		{
			_selectedCode = null;
			_selectedName = null;
		}
		else
		{
			_selectedCode = code;
			_selectedName = name;
		}
		_error = null;
	}

	private static VariantGroup CreateGroup(string title, IEnumerable<GetAvailablePokerGamesResponse> games, VariantType variantType)
	{
		return new VariantGroup(title, games.Where(g => g.VariantType == variantType).ToList());
	}

	private static bool IsBlindBasedGame(string? code) =>
		string.Equals(code, "HOLDEM", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(code, "REDRIVER", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(code, "OMAHA", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(code, "NEBRASKA", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(code, "IRISHHOLDEM", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(code, "HOLDTHEBASEBALL", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(code, "PHILSMOM", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(code, "CRAZYPINEAPPLE", StringComparison.OrdinalIgnoreCase);

	private bool MatchesVariantSearch(string gameName)
	{
		return string.IsNullOrWhiteSpace(_variantSearch)
			|| gameName.Contains(_variantSearch, StringComparison.OrdinalIgnoreCase);
	}

	private async Task ConfirmChoiceAsync()
	{
		if (_selectedCode is null)
			return;

		if (IsBlindBasedGame(_selectedCode) ? _bigBlind < 1 : _minBet < 1)
			return;

		_isSubmitting = true;
		_error = null;
		StateHasChanged();

		try
		{
			if (IsBlindBasedGame(_selectedCode))
			{
				await OnGameChosen.InvokeAsync(new DealerChoiceSelection(_selectedCode, 0, _bigBlind, _smallBlind, _bigBlind));
			}
			else
			{
				await OnGameChosen.InvokeAsync(new DealerChoiceSelection(_selectedCode, _ante, _minBet));
			}
		}
		catch (Exception ex)
		{
			_error = ex.Message;
		}
		finally
		{
			_isSubmitting = false;
			StateHasChanged();
		}
	}

	public record DealerChoiceSelection(string GameTypeCode, int Ante, int MinBet, int? SmallBlind = null, int? BigBlind = null);

	private sealed record VariantGroup(string Title, IReadOnlyList<GetAvailablePokerGamesResponse> Games);
}
