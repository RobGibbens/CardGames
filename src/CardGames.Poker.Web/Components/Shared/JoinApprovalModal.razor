@using CardGames.Contracts.SignalR

@if (PendingRequests.Count > 0)
{
	<div class="confirm-dialog-overlay join-approval-overlay">
		<div class="confirm-dialog league-form-modal join-buy-in-modal join-approval-modal" @onclick:stopPropagation>
			<div class="confirm-dialog-header league-form-modal-header">
				<h3 class="confirm-dialog-title mb-0">Join Requests</h3>
			</div>
			<div class="confirm-dialog-body league-form-modal-body text-start">
				@if (!string.IsNullOrWhiteSpace(ErrorMessage))
				{
					<p class="join-approval-error mb-3">@ErrorMessage</p>
				}

				<div class="join-approval-list">
					@foreach (var request in PendingRequests)
					{
						<div class="join-approval-item">
							<div class="join-approval-item-copy">
								<div class="join-approval-item-title-row">
									<strong>@(request.PlayerFirstName ?? request.PlayerName)</strong>
								</div>
								<p class="confirm-dialog-message mb-2">Requested buy-in: <strong>@request.RequestedBuyIn.ToString("N0")</strong></p>
								<label class="form-label mb-1" for="@GetInputId(request.JoinRequestId)">Approved buy-in</label>
								<input id="@GetInputId(request.JoinRequestId)"
									class="form-control join-buy-in-input"
									type="number"
									min="1"
									max="@request.RequestedBuyIn"
									step="1"
									value="@GetApprovedBuyIn(request.JoinRequestId, request.RequestedBuyIn)"
									@oninput="eventArgs => OnApprovedBuyInInput(request.JoinRequestId, request.RequestedBuyIn, eventArgs)"
									disabled="@(BusyJoinRequestId == request.JoinRequestId)" />
							</div>
							<div class="join-approval-item-actions">
								<button class="btn btn-secondary confirm-dialog-btn"
									type="button"
									@onclick="() => ResolveAsync(request, false)"
									disabled="@(BusyJoinRequestId == request.JoinRequestId)">
									Deny
								</button>
								<button class="btn btn-primary confirm-dialog-btn"
									type="button"
									@onclick="() => ResolveAsync(request, true)"
									disabled="@(BusyJoinRequestId == request.JoinRequestId)">
									@if (BusyJoinRequestId == request.JoinRequestId)
									{
										<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
									}
									Approve
								</button>
							</div>
						</div>
					}
				</div>
			</div>
		</div>
	</div>
}

@code {
	[Parameter]
	public IReadOnlyList<GameJoinRequestReceivedDto> PendingRequests { get; set; } = [];

	[Parameter]
	public Guid? BusyJoinRequestId { get; set; }

	[Parameter]
	public string? ErrorMessage { get; set; }

	[Parameter]
	public EventCallback<JoinApprovalAction> OnResolveRequested { get; set; }

	private readonly Dictionary<Guid, int> _approvedBuyIns = [];

	protected override void OnParametersSet()
	{
		var validIds = PendingRequests.Select(x => x.JoinRequestId).ToHashSet();
		foreach (var request in PendingRequests)
		{
			if (!_approvedBuyIns.ContainsKey(request.JoinRequestId))
			{
				_approvedBuyIns[request.JoinRequestId] = request.RequestedBuyIn;
			}
		}

		foreach (var staleId in _approvedBuyIns.Keys.Where(id => !validIds.Contains(id)).ToList())
		{
			_approvedBuyIns.Remove(staleId);
		}
	}

	private int GetApprovedBuyIn(Guid joinRequestId, int requestedBuyIn)
	{
		return _approvedBuyIns.TryGetValue(joinRequestId, out var value)
			? value
			: requestedBuyIn;
	}

	private void OnApprovedBuyInInput(Guid joinRequestId, int requestedBuyIn, ChangeEventArgs eventArgs)
	{
		var parsed = requestedBuyIn;
		if (int.TryParse(eventArgs.Value?.ToString(), out var value))
		{
			parsed = Math.Clamp(value, 1, requestedBuyIn);
		}

		_approvedBuyIns[joinRequestId] = parsed;
	}

	private async Task ResolveAsync(GameJoinRequestReceivedDto request, bool approved)
	{
		int? approvedBuyIn = approved ? GetApprovedBuyIn(request.JoinRequestId, request.RequestedBuyIn) : null;
		await OnResolveRequested.InvokeAsync(new JoinApprovalAction(request.GameId, request.JoinRequestId, approved, approvedBuyIn));
	}

	private static string GetInputId(Guid joinRequestId) => $"join-approval-{joinRequestId:N}";
}