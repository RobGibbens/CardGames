{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Aspire AppHost (CardGames.AppHost)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CardGames.AppHost/bin/Debug/net10.0/CardGames.AppHost.dll",
      "cwd": "${workspaceFolder}/CardGames.AppHost",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "stopAtEntry": false,
      "env": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ],
  "compounds": [
    
  ]
}
